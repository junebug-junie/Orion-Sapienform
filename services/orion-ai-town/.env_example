# Orion AI Town — self-hosted Convex mesh deploy
# Copy to .env and fill secrets before: docker compose up -d --build

# Upstream pin (documented in README; clone into ./upstream before build).
# Pinned to the SHA the tracked patches in ./patches were generated against — the
# patches carry exact context and will not apply to a moved a16z `main`.
AITOWN_UPSTREAM_REF=7b242334bfbfef02f7718bded120d431e8f307df

# Convex backend
PORT=3210
SITE_PROXY_PORT=3211
DASHBOARD_PORT=6791
FRONTEND_PORT=5173
URL_BASE=http://127.0.0.1

# Required: generate a strong secret for production mesh nodes
INSTANCE_SECRET=

# Optional instance label
INSTANCE_NAME=orion-aitown

# Mesh LLM — set via convex env after bootstrap (see README)
# OLLAMA_HOST=http://<mesh-ollama-host>:11434
OLLAMA_PORT=11434

# Optional SQL backend (empty = SQLite volume)
DATABASE_URL=

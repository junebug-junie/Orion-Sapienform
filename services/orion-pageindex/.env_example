SERVICE_NAME=orion-pageindex
SERVICE_VERSION=0.1.0
NODE_NAME=athena
PORT=8360

JOURNAL_PG_DSN=postgresql://postgres:postgres@orion-athena-sql-db:5432/conjourney
PAGEINDEX_SQL_DATABASE_URL=
ENDOGENOUS_RUNTIME_SQL_DATABASE_URL=
SQL_DATABASE_URL=
# Expected to point at the enriched denormalized index table (journal_entry_index).
JOURNAL_INDEX_TABLE=journal_entry_index

PAGEINDEX_IMPL=actual
PAGEINDEX_INSTALLATION_MODE=cli
PAGEINDEX_REPO_PATH=/opt/PageIndex
PAGEINDEX_RUN_SCRIPT=run_pageindex.py
PAGEINDEX_PYTHON_BIN=python3
PAGEINDEX_BUILD_ARGS=--md_path {md_path}
PAGEINDEX_QUERY_ARGS=--md_path {md_path}
PAGEINDEX_TIMEOUT_SEC=120
PAGEINDEX_ALLOW_EMPTY_REBUILD=false
PAGEINDEX_DATA_DIR=/data/pageindex
CHAT_EPISODES_MARKDOWN_PATH=/data/pageindex/chat_episodes/chat_episode_corpus.md
PAGEINDEX_REPO_URL=https://github.com/VectifyAI/PageIndex.git
PAGEINDEX_REF=main

PROJECT=orion-athena
SERVICE_NAME=orion-harness-governor
SERVICE_VERSION=0.1.0
NODE_NAME=athena
HARNESS_GOVERNOR_PORT=7156

ORION_BUS_ENABLED=true
ORION_BUS_ENFORCE_CATALOG=false
ORION_BUS_URL=redis://100.x.x.x:6379/0
ORION_HARNESS_GOVERNOR_ENABLED=true

CHANNEL_HARNESS_RUN_REQUEST=orion:harness:run:request
CHANNEL_HARNESS_RUN_ARTIFACT=orion:harness:run:artifact
CHANNEL_HARNESS_RESULT_PREFIX=orion:harness:run:result:
CHANNEL_HARNESS_RUN_STEP=orion:harness:run:step
# Hub publishes here on WS disconnect / turn abort so orphaned FCC claude motors die.
CHANNEL_HARNESS_RUN_CANCEL=orion:harness:run:cancel
CHANNEL_GRAMMAR_EVENT=orion:grammar:event
# Background exec lane — finalize must not queue behind interactive chat on legacy intake.
CHANNEL_CORTEX_EXEC_REQUEST=orion:cortex:exec:request:background
CHANNEL_CORTEX_EXEC_RESULT_PREFIX=orion:exec:result
CHANNEL_FINALIZE_APPRAISAL_REQUEST=orion:substrate:finalize_appraisal:request
CHANNEL_FINALIZE_APPRAISAL_RESULT_PREFIX=orion:substrate:finalize_appraisal:result:
CHANNEL_POST_TURN_CLOSURE=orion:substrate:post_turn_closure

HARNESS_FCC_TIMEOUT_SEC=900
FINALIZE_REFLECT_TIMEOUT_SEC=180
VOICE_FINALIZE_TIMEOUT_SEC=300
SUBSTRATE_FINALIZE_TIMEOUT_SEC=5
FINALIZE_QUICK_GATE_EPSILON=0.08

HARNESS_FCC_ENV_PATH=/root/.fcc/.env
HARNESS_FCC_AUTH_TOKEN=
HARNESS_FCC_SERVER_URL=http://host.docker.internal:8082
HARNESS_FCC_WORKSPACE=/mnt/scripts/Orion-Sapienform
HARNESS_FCC_CLAUDE_BIN=claude
HARNESS_FCC_CLAUDE_BIN_HOST=
# Absolute host path to repo root for workspace + volume mount (required when compose runs from a git worktree)
HARNESS_REPO_MOUNT=/mnt/scripts/Orion-Sapienform
# Orion-mode FCC MCP — secrets in ~/.fcc/.env (see config/fcc.env_example)
HARNESS_FCC_MCP_ENABLED=true
# FCC Claude spawns set ENABLE_TOOL_SEARCH=true via orion.fcc.context_budget.extend_fcc_subprocess_env
# (defers MCP schema load on custom ANTHROPIC_BASE_URL). Override only for debug: false | auto | auto:N
# Optional override when git remote is unavailable in workspace mount
ORION_GITHUB_OWNER=
ORION_GITHUB_REPO=
# Root in Docker skips --dangerously-skip-permissions without this; avoids "requires approval" dead-ends
HARNESS_FCC_SKIP_PERMISSIONS=true
# Must stay in lockstep with the active FCC/deep-cognition llama.cpp profile's ctx_size
# in config/llm_profiles.yaml (currently 131072 on the Circe monster-FCC profile).
HARNESS_FCC_MAX_CONTEXT_TOKENS=131072
HARNESS_FCC_FILE_READ_MAX_TOKENS=8192
HARNESS_FCC_AUTOCOMPACT_PCT_OVERRIDE=70
# Context pressure nudge when motor fill exceeds this percent of max context (default 70).
HARNESS_FCC_CONTEXT_PRESSURE_PCT=70
# Max silence between Claude stream-json events before the governor kills the
# one FCC subprocess and returns fcc_idle_timeout. Set 0 to use the full
# HARNESS_FCC_TIMEOUT_SEC as the idle budget.
HARNESS_FCC_STREAM_IDLE_TIMEOUT_SEC=180
# Ask Claude Code to emit upstream token deltas as stream-json `stream_event`
# records. The harness folds those partials into runtime evidence while
# throttling progress publication, preventing local FCC streams from looking
# hung while bytes are moving.
HARNESS_FCC_INCLUDE_PARTIAL_MESSAGES=true
# Max time spent receiving only partial token deltas without a complete Claude
# event. On timeout, the run fails as fcc_partial_stream_timeout and the partial
# text is marked unsafe so finalize will not polish local-model loops.
HARNESS_FCC_PARTIAL_STREAM_TIMEOUT_SEC=90
# Seconds between synthetic progress steps while partial token deltas are
# arriving. Set 0 to keep partials internal-only.
HARNESS_FCC_PARTIAL_PROGRESS_INTERVAL_SEC=15
# Force local llama.cpp FCC model ids through FCC's no-thinking gateway model.
# This prevents Claude Code 2.1 from asking the local rail for unsupported
# extended-thinking stream blocks. Set false only when testing FCC thinking.
HARNESS_FCC_FORCE_NO_THINKING_MODEL=true
# MCP proxy truncates individual tool text payloads above this char count (default 12000).
ORION_FCC_MCP_TOOL_RESULT_MAX_CHARS=12000
HARNESS_AITOWN_ENABLED=true
# Semantic self-indexing (design: 2026-07-11 semantic self-indexing proposal).
# GitNexus code-graph MCP (gitnexus@1.6.9 pinned in the image). Requires a
# host-built index: run `gitnexus analyze --index-only --name orion` from the
# repo root on the host. Off by default; fail-open (FCC falls back to rg/Read).
HARNESS_FCC_GITNEXUS_ENABLED=true
# Context Mode MCP-only stage (context-mode@1.0.169 pinned in the image).
# Virtualizes bulk tool output outside the live context. Off by default.
HARNESS_FCC_CONTEXT_MODE_ENABLED=true
# Writable Context Mode storage root inside the container (Docker volume
# harness-context-mode; operational working data, not an Orion memory store).
HARNESS_FCC_CONTEXT_MODE_DIR=/var/lib/orion/context-mode
# Context Mode hook mode (Stage B): replaces the standalone context-mode MCP
# server with the Claude Code plugin (PreToolUse/PostToolUse/PreCompact/
# SessionStart/Stop hooks; session continuity across compaction).
HARNESS_FCC_CONTEXT_MODE_HOOKS_ENABLED=true
# Bridge-network harness cannot use 127.0.0.1 from ~/.fcc; override Convex reachability here
HARNESS_AITOWN_CONVEX_URL=http://host.docker.internal:3210
# (D) embodiment: emit a deliberate approach intent on the turn correlation_id after a
# finalized relational turn (mind->sprite bridge). Default-off, fail-open.
EMBODIMENT_D_FINALIZE_ENABLED=false

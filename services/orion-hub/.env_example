# ───────────────────────────────────────────────────────────────
# 🎧 Orion Hub — Voice + Web Gateway
# ───────────────────────────────────────────────────────────────
#
# Docker Compose: hub `docker-compose.yml` uses optional `env_file: .env` and passes
# variables through the `environment:` block. For `${VAR}` substitution in that block,
# either run `docker compose` from `services/orion-hub/`, or from the repo root use:
#   docker compose --env-file services/orion-hub/.env -f services/orion-hub/docker-compose.yml ...
#

# --- Service Identity ---
PROJECT=orion-athena
SERVICE_NAME=hub
SERVICE_VERSION=0.4.0
HUB_PORT=8080
HUB_API_BASE_OVERRIDE=
HUB_WS_BASE_OVERRIDE=
# Mounted repo root in Docker (config/memory_graph, ontology shapes). Default in compose: /repo
ORION_REPO_ROOT=/repo
# Knowledge Forge — in-container path (repo bind-mount at /repo). Local host .env: use host path to orion-knowledge/
ORION_KNOWLEDGE_ROOT=/repo/orion-knowledge

# --- Bus Configuration ---
ORION_BUS_ENABLED=true
ORION_BUS_ENFORCE_CATALOG=true
ORION_BUS_URL=redis://100.92.216.81:6379/0

# --- Landing Pad ---
LANDING_PAD_TIMEOUT_SEC=10

# --- Topic Foundry ---
TOPIC_FOUNDRY_BASE_URL=http://127.0.0.1:8615
# World Pulse is not intended to be directly exposed.
# In Tailscale deployments, expose it only through the Hub/proxy path.
# Browser clients should use relative Hub routes (/api/world-pulse/*) or a path proxy (/world-pulse/*).
# Host-network dev (default hub docker-compose): use 127.0.0.1 + world-pulse published port (8628 in orion-world-pulse compose).
WORLD_PULSE_BASE_URL=http://127.0.0.1:8628
# Docker bridge/service DNS (only when hub is not using host network mode):
# WORLD_PULSE_BASE_URL=http://orion-world-pulse:8628
WORLD_PULSE_PROXY_TIMEOUT_SEC=10
WORLD_PULSE_UI_FIXTURE_RUN_ENABLED=false

# --- Knowledge Forge ---
KNOWLEDGE_FORGE_BASE_URL=http://127.0.0.1:8630
# Docker bridge/service DNS (only when hub is not using host network mode):
# KNOWLEDGE_FORGE_BASE_URL=http://orion-knowledge-forge:8630
KNOWLEDGE_FORGE_PROXY_TIMEOUT_SEC=15

# --- Substrate tier telemetry (Hub → orion-substrate-telemetry HTTP only; not the Redis bus) ---
# Base URL of the telemetry read API, e.g. http://orion-athena-substrate-telemetry:8395 (compose service DNS).
SUBSTRATE_TELEMETRY_BASE_URL=
# Optional shared secret: only if you set SUBSTRATE_TELEMETRY_READ_API_TOKEN on the telemetry service.
# Leave empty on internal Docker networks — Hub will not send X-Telemetry-Token and telemetry accepts unsigned reads.
SUBSTRATE_TELEMETRY_READ_TOKEN=

# --- Social Memory ---
SOCIAL_MEMORY_BASE_URL=http://127.0.0.1:8765
SELF_EXPERIMENTS_BASE_URL=http://127.0.0.1:7172
SELF_EXPERIMENTS_TIMEOUT_SEC=6

# --- Biometrics Cache (Hub) ---
BIOMETRICS_ENABLED=true
BIOMETRICS_STALE_AFTER_SEC=60
BIOMETRICS_NO_SIGNAL_AFTER_SEC=600
BIOMETRICS_ROLE_WEIGHTS_JSON={"atlas":0.6,"athena":0.4}
BIOMETRICS_PUSH_INTERVAL_SEC=5

# --- Organ signal inspect (Hub; Phase 2b) ---
# Subscribes to gateway output pattern; latest OrionSignalV1 per organ + optional trace cache.
SIGNALS_INSPECT_ENABLED=true
SIGNALS_INSPECT_SUBSCRIBE_PATTERN=orion:signals:*
SIGNALS_INSPECT_WINDOW_SEC=45
SIGNALS_TRACE_CACHE_ENABLED=true
TRACE_CACHE_MAX_TRACES=200
TRACE_CACHE_TTL_SEC=300
TRACE_CACHE_MAX_SIGNALS_PER_TRACE=64

# --- Cognition trace cache (Runtime Trace Nexus A4) ---
# Subscribes to cortex-exec CognitionTracePayload on orion:cognition:trace.
COGNITION_TRACE_CACHE_ENABLED=true
COGNITION_TRACE_CACHE_MAX=200
COGNITION_TRACE_CACHE_TTL_SEC=300
COGNITION_TRACE_SUBSCRIBE_CHANNEL=orion:cognition:trace
# When true, GET /api/cognition/trace/{id} may return full step payloads (operator-only).
COGNITION_TRACE_API_DEBUG=false

# OpenTelemetry / Grafana: Hub deep links to Tempo in Grafana Explore (32-char hex otel_trace_id).
# Example when running services/orion-signal-gateway docker-compose (Grafana on host 3001):
# HUB_OTEL_GRAFANA_BASE_URL=http://127.0.0.1:3001
HUB_OTEL_GRAFANA_BASE_URL=
HUB_OTEL_GRAFANA_DATASOURCE_UID=tempo
HUB_OTEL_GRAFANA_ORG_ID=1

# --- In-app Notifications (Hub) ---
NOTIFY_IN_APP_ENABLED=true
NOTIFY_IN_APP_CHANNEL=orion:notify:in_app
NOTIFY_IN_APP_MAX=200
NOTIFY_TOAST_SECONDS=8
NOTIFY_BASE_URL=http://127.0.0.1:7140
NOTIFY_API_TOKEN=

# --- Cortex Gateway Integration (Titanium) ---
CORTEX_GATEWAY_REQUEST_CHANNEL=orion:cortex:gateway:request
CORTEX_GATEWAY_RESULT_PREFIX=orion:cortex:gateway:result

# --- TTS Integration (Titanium) ---
TTS_REQUEST_CHANNEL=orion:tts:intake
TTS_RESULT_PREFIX=orion:tts:result

# --- STT Integration (Titanium) ---
STT_REQUEST_CHANNEL=orion:stt:intake
STT_RESULT_PREFIX=orion:stt:result

# --- Legacy / Deprecated Channels (Preserved for compatibility) ---
WHISPER_MODEL_SIZE=distil-small.en
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float32
CHANNEL_VOICE_TRANSCRIPT=orion:voice:transcript
CHANNEL_VOICE_LLM=orion:voice:llm
CHANNEL_VOICE_TTS=orion:voice:tts
CHANNEL_TTS_INTAKE=orion:tts:intake
CHANNEL_COLLAPSE_INTAKE=orion:collapse:intake
CHANNEL_COLLAPSE_TRIAGE=orion:collapse:triage
LLM_GATEWAY_SERVICE_NAME=LLMGatewayService
EXEC_REQUEST_PREFIX=orion:exec:request
CHANNEL_LLM_INTAKE=orion:exec:request:LLMGatewayService
CHANNEL_LLM_REPLY_PREFIX=orion:llm:reply:
CORTEX_REQUEST_CHANNEL=orion:cortex:request
CORTEX_RESULT_PREFIX=orion:cortex:result
AGENT_CHAIN_REQUEST_CHANNEL=orion:exec:request:AgentChainService
AGENT_CHAIN_RESULT_PREFIX=orion:exec:result:AgentChainService
CHAT_HISTORY_LOG_CHANNEL=orion:chat:history:log
CHANNEL_CHAT_HISTORY_LOG=orion:chat:history:log
CHANNEL_COUNCIL_INTAKE=orion:agent-council:intake
CHANNEL_COUNCIL_REPLY_PREFIX=orion:agent-council:reply
CHANNEL_RECALL_REQUEST=orion:exec:request:RecallService
CHANNEL_RECALL_DEFAULT_REPLY_PREFIX=orion:exec:result:RecallService
RECALL_DEFAULT_MAX_ITEMS=16
RECALL_DEFAULT_TIME_WINDOW_DAYS=30
RECALL_DEFAULT_MODE=hybrid
HUB_RECALL_SERVICE_URL=http://127.0.0.1:8260
RECALL_SERVICE_URL=http://127.0.0.1:8260
HUB_RECALL_SHADOW_EVAL_TIMEOUT_SEC=45
HUB_RECALL_SHADOW_EVAL_MAX_ROWS_PER_RUN=128
HUB_RECALL_SHADOW_EVAL_DEFAULT_CORPUS_LIMIT=24

# --- Memory cards (Hub Memory tab + /api/memory/*) ---
# Hub startup runs idempotent DDL (includes CREATE EXTENSION IF NOT EXISTS pgcrypto); DB role must allow it.
# If unset or pool creation fails, /api/memory/* returns HTTP 503 with detail "memory_store_unavailable".
# Hub compose defaults to network_mode: host — use 127.0.0.1 and POSTGRES_PORT (55432 in orion-sql-db compose),
# not a Docker DNS name. In bridge-network Hub, use e.g. postgresql://...@orion-athena-sql-db:5432/conjourney
RECALL_PG_DSN=postgresql://postgres:postgres@127.0.0.1:55432/conjourney

# --- Memory crystallization Graphiti/FalkorDB (additive temporal projection; NOT RDF memory_graph) ---
GRAPHITI_ENABLED=false
GRAPHITI_URL=
FALKORDB_URI=

# --- Memory crystallization projections ---
CRYSTALLIZER_VECTOR_COLLECTION=orion_memory_crystallizations
CRYSTALLIZER_EMBED_HOST_URL=
CRYSTALLIZER_EMBED_MODE=http
CRYSTALLIZER_EMBED_TIMEOUT_MS=8000
CRYSTALLIZER_AUTO_PROJECT_ON_APPROVE=true

# Chroma query host for active-packet semantic rail (orion-vector-db HTTP)
CHROMA_HOST=
CHROMA_PORT=8000

# Graphiti additive adapter (NOT RDF memory_graph)
GRAPHITI_ADAPTER_URL=http://orion-athena-graphiti-adapter:8000

# --- Global graph / RDF store (Fuseki; Hub memory-graph approve + substrate SPARQL) ---
GRAPH_BACKEND=fuseki
RDF_STORE_BACKEND=fuseki
RDF_STORE_BASE_URL=http://127.0.0.1:3030
RDF_STORE_DATASET=orion
RDF_STORE_QUERY_URL=http://127.0.0.1:3030/orion/query
RDF_STORE_UPDATE_URL=http://127.0.0.1:3030/orion/update
RDF_STORE_GRAPH_STORE_URL=http://127.0.0.1:3030/orion/data
# Local Fuseki dev auth:
# services/orion-rdf-store/.env sets FUSEKI_ADMIN_PASSWORD=orion.
# Therefore local update credentials are admin/orion, not admin/admin.
# Production should override these with real secrets.
RDF_STORE_USER=admin
RDF_STORE_PASS=orion
# Memory graph approve: auto uses RDF_STORE_GRAPH_STORE_URL + RDF_STORE_UPDATE_URL; graphdb = legacy only.
MEMORY_GRAPH_APPROVAL_BACKEND=auto
# Legacy GraphDB (explicit MEMORY_GRAPH_APPROVAL_BACKEND=graphdb only):
# GRAPHDB_URL=http://127.0.0.1:7200
GRAPHDB_URL=
GRAPHDB_REPO=collapse
GRAPHDB_USER=
GRAPHDB_PASS=
# Hub operator goal archive (Autonomy Runtime panel); nightly automation still runs in orion-actions.
AUTONOMY_GRAPH_QUERY_URL=http://orion-athena-fuseki:3030/orion/query
AUTONOMY_GRAPH_UPDATE_URL=http://orion-athena-fuseki:3030/orion/update
AUTONOMY_GRAPH_TIMEOUT_SEC=30
# Default named graph IRI for POST /api/memory/graph/approve when the UI omits named_graph_iri
MEMORY_GRAPH_DEFAULT_NAMED_GRAPH=https://orion.example/ns/memory/ng/session/local

# POST /api/memory/graph/suggest — grounded Quick primary, Brain escalation on hard failures.
# Requires a live Orion bus + cortex gateway client (503 if unavailable), unlike /validate which is local-only.
MEMORY_GRAPH_SUGGEST_PRIMARY_ROUTE=quick
# Retry label only — still uses quick LLM lane (not Hub UI Brain / grounded-small chat mode).
MEMORY_GRAPH_SUGGEST_ESCALATION_ROUTE=brain
MEMORY_GRAPH_SUGGEST_ENABLE_ESCALATION=true
MEMORY_GRAPH_SUGGEST_INCLUDE_GROUNDING=true
# Verb budget (ms); matches orion/cognition/verbs/memory_graph_suggest.yaml timeout_ms.
MEMORY_GRAPH_SUGGEST_VERB_TIMEOUT_MS=180000
# Per-route hub waits (seconds). 0 = derive from verb budget (Quick+Brain share 180s when escalation on).
MEMORY_GRAPH_SUGGEST_BRAIN_TIMEOUT_SEC=0
MEMORY_GRAPH_SUGGEST_QUICK_TIMEOUT_SEC=0
# Hub UI fetch AbortController (ms). 0 = auto (server budget + buffer, typically 205000).
MEMORY_GRAPH_SUGGEST_CLIENT_FETCH_TIMEOUT_MS=0
MEMORY_GRAPH_SUGGEST_CLIENT_FETCH_BUFFER_SEC=25
# After probe_structured_output.py: json_object_schema | json_schema_schema | json_object_only | none
MEMORY_GRAPH_SUGGEST_STRUCTURED_OUTPUT_METHOD=json_object_schema
MEMORY_GRAPH_SUGGEST_MAX_TOKENS=4096
# Context turns passed to the LLM for graph extraction — kept low to avoid context-window overflow.
MEMORY_GRAPH_SUGGEST_CONTEXT_TURNS=3
# diagnostic / options.diagnostic on suggest requests returns full raw model text — trusted paths only.
GDB_CLIENT_ENABLED=false

# --- Runtime / Mode ---
MODE=dev
# Bus RPC (Hub→gateway, …); keep ≥ CORTEX_GATEWAY_RPC_TIMEOUT_SEC so multi-step chat verbs can finish.
TIMEOUT_SEC=400
# Voice STT/TTS bus RPC caps (should exceed whisper-tts worker timeouts).
HUB_STT_TIMEOUT_SEC=120
HUB_TTS_TIMEOUT_SEC=180

# --- Hub Prompt Context (UI-side rolling history) ---
# Number of *turns* (user+assistant pairs) to include as inline context
HUB_CONTEXT_TURNS=12
# Hard cap to avoid runaway prompts when users paste long text
HUB_CONTEXT_MAX_CHARS=12000                                                     

# --- Recall Debugging ---
# When true, allows POST /api/substrate/mutation-runtime/recall-eval-suite/record (still requires SUBSTRATE_MUTATION_OPERATOR_TOKEN).
HUB_RECALL_EVAL_RECORDING_ENABLED=false
HUB_DEBUG_RECALL=false
HUB_DEBUG_COUNCIL=false
HUB_SOCIAL_SKILLS_ENABLED=true
HUB_SOCIAL_SKILLS_ALLOWLIST=social_artifact_dialogue,social_summarize_thread,social_safe_recall,social_self_ground,social_followup_question,social_room_reflection,social_exit_or_pause
HUB_SOCIAL_STYLE_ADAPTATION_ENABLED=true
HUB_SOCIAL_ROOM_RITUALS_ENABLED=true
HUB_SOCIAL_STYLE_CONFIDENCE_FLOOR=0.35
ORION_PRESENCE_SESSION_TTL_SECONDS=14400
ORION_PRESENCE_DEFAULT_REQUESTOR=Juniper
ORION_PRESENCE_PERSIST_ALLOWED=false
ORION_SITUATION_ENABLED=true
ORION_SITUATION_TTL_SECONDS=300
ORION_SITUATION_TIMEZONE=America/Denver
ORION_SITUATION_WEATHER_PROVIDER=stub

# --- No-Write Debug Mode ---
HUB_DEFAULT_NO_WRITE=false
HUB_AUTO_DEFAULT_ENABLED=false
# Autonomy compact/debug availability denominator: two (orion+relationship) or three (legacy juniper row)
HUB_AUTONOMY_SUBJECT_DISPLAY=two
# Phase 3 operator goal promote/dismiss/complete routes (default off).
AUTONOMY_GOAL_EXECUTION_ENABLED=false

# --- Hub Docker networking posture ---
# Hub docker-compose uses network_mode: "host" by default.
# In host mode, Docker service DNS names (for example "orion-athena-sql-db") do NOT resolve.
# Use a host-reachable Postgres host instead: 127.0.0.1, LAN IP, Tailscale IP, etc.
HUB_DOCKER_NETWORK_MODE=host

# --- Substrate control-plane SQL source (Phase 20c parity) ---
# Precedence for Hub control-plane reads:
# 1) SUBSTRATE_CONTROL_PLANE_POSTGRES_URL
# 2) SUBSTRATE_POLICY_POSTGRES_URL
# 3) DATABASE_URL
# Prefer shared operational Postgres over local sqlite seams.
# for a host-networked Hub, the right DB URL is:
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55432/conjourney
# Grammar Atlas read API (/api/substrate/atlas/*). Optional override; defaults to DATABASE_URL.
GRAMMAR_ATLAS_ENABLED=true
GRAMMAR_ATLAS_POLL_INTERVAL_MS=3000
# GRAMMAR_ATLAS_POSTGRES_URI=

# Substrate Lattice: per-layer freshness threshold in seconds (default 60)
# SUBSTRATE_LATTICE_FRESHNESS_THRESHOLD_SEC=60
SUBSTRATE_CONTROL_PLANE_POSTGRES_URL=
SUBSTRATE_POLICY_POSTGRES_URL=
SUBSTRATE_REVIEW_QUEUE_SQL_DB_PATH=
# Optional sqlite file for review telemetry when Postgres is not used (parity with queue seam).
SUBSTRATE_REVIEW_TELEMETRY_SQL_DB_PATH=
SUBSTRATE_AUTONOMY_ENABLED=false
SUBSTRATE_AUTONOMY_PROPOSALS_ENABLED=true
SUBSTRATE_AUTONOMY_APPLY_ENABLED=false
SUBSTRATE_AUTONOMY_MONITOR_ENABLED=true
SUBSTRATE_AUTONOMY_ROUTING_PROPOSALS_ENABLED=true
SUBSTRATE_AUTONOMY_COGNITIVE_PROPOSALS_ENABLED=false
SUBSTRATE_AUTONOMY_ROUTING_APPLY_ENABLED=false
SUBSTRATE_AUTONOMY_ROUTING_ROLLBACK_DELTA_THRESHOLD=-0.05
SUBSTRATE_AUTONOMY_INTERVAL_SEC=30
SUBSTRATE_MUTATION_RETENTION_MAX_BLOCKED_APPLIES=500
SUBSTRATE_MUTATION_RETENTION_MAX_ROLLBACKS=500
SUBSTRATE_MUTATION_CONTROL_SQL_DB_PATH=
SUBSTRATE_MUTATION_OPERATOR_TOKEN=

# --- Substrate semantic graph (Fuseki / SPARQL or legacy GraphDB) ---
# RDF Store V1: Hub docker-compose defaults SUBSTRATE_STORE_BACKEND=sparql with Athena Fuseki URLs; override for host mode (127.0.0.1).
# Query/update URLs fall back to RDF_STORE_QUERY_URL / RDF_STORE_UPDATE_URL when SUBSTRATE_GRAPH_* are unset.
# With HUB_DOCKER_NETWORK_MODE=host, use 127.0.0.1 + published Fuseki port (3030), not Docker service DNS.
SUBSTRATE_STORE_BACKEND=sparql
SUBSTRATE_GRAPH_QUERY_URL=http://orion-athena-fuseki:3030/orion/query
SUBSTRATE_GRAPH_UPDATE_URL=http://orion-athena-fuseki:3030/orion/update
SUBSTRATE_GRAPH_URI=http://conjourney.net/graph/substrate
SUBSTRATE_GRAPH_TIMEOUT_SEC=5.0
SUBSTRATE_GRAPH_USER=admin
SUBSTRATE_GRAPH_PASS=orion
# Legacy GraphDB substrate (explicit SUBSTRATE_STORE_BACKEND=graphdb only):
# SUBSTRATE_GRAPHDB_ENDPOINT=http://127.0.0.1:7200/repositories/collapse
SUBSTRATE_GRAPHDB_ENDPOINT=
SUBSTRATE_GRAPHDB_GRAPH_URI=http://conjourney.net/graph/orion/substrate
SUBSTRATE_GRAPHDB_TIMEOUT_SEC=5.0
SUBSTRATE_GRAPHDB_USER=
SUBSTRATE_GRAPHDB_PASS=

# --- Substrate operator seed (optional) ---
# One-shot demo nodes/edges into the configured graph backend (legacy script name: seed_substrate_graphdb.py).
# In a running hub container with the repo mounted at /repo, use a neutral cwd so Python
# loads orion from the mount (WORKDIR /app shadows orion on PYTHONPATH=/repo:/app):
#   docker exec <hub> sh -c 'cd /tmp && env PYTHONPATH=/repo python3 /repo/services/orion-hub/scripts/seed_substrate_graphdb.py'
# After a new image build, the script also lives under /app/scripts/ when not using /repo.

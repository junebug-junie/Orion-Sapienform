# ───────────────────────────────────────────────────────────────
# ✍️  Orion RDF Writer — bus → triples → RDF store (GraphDB, Fuseki, …)
# ───────────────────────────────────────────────────────────────

# --- Stack / compose placeholders (match other Orion services) ---
PROJECT=orion-athena
NET=app-net
NODE_NAME=athena
BATCH_SIZE=100
# Redis on app-net: use the bus compose alias (see services/orion-bus/docker-compose.yml), not container_name.
ORION_BUS_URL=redis://bus-core:6379/0

# --- Service Identity ---
SERVICE_NAME=orion-rdf-writer
SERVICE_VERSION=1.0.0
PORT=8020

# --- Orion Bus Integration ---
ORION_BUS_ENABLED=true
ORION_BUS_ENFORCE_CATALOG=true

# --- Bus Listener Channels ---
# Defines all channels this service will subscribe to.
CHANNEL_RDF_ENQUEUE=orion:rdf:enqueue
CHANNEL_EVENTS_COLLAPSE=orion:collapse:intake
CHANNEL_EVENTS_TAGGED=orion:tags:enriched
CHANNEL_EVENTS_TAGGED_CHAT=orion:tags:chat:enriched
CHANNEL_CORE_EVENTS=orion:core:events
# CHANNEL_WORKER_RDF removed 2026-07-18: orion:rdf:worker has zero real
# producers anywhere in the repo despite the channel registry claiming one;
# rdf-writer no longer subscribes or handles the kind.
# CORTEX_LOG_CHANNEL removed 2026-07-18: orion:cortex:telemetry has zero
# producers anywhere, not even registered in channels.yaml.
CHANNEL_COGNITION_TRACE_PUB=orion:cognition:trace
CHANNEL_CHAT_HISTORY_TURN=orion:chat:history:turn
CHANNEL_CHAT_HISTORY_LOG=orion:chat:history:log
# CHANNEL_MEMORY_IDENTITY_SNAPSHOT / CHANNEL_MEMORY_GOALS_PROPOSED removed
# 2026-07-18: zero live Fuseki triples ever recorded despite real producers
# existing; Postgres/orion-substrate-runtime already durably own this data.
# CHANNEL_MEMORY_DRIVES_AUDIT removed 2026-07-15: drive audits are Postgres-only
# (`drive_audits` via orion-sql-writer); rdf-writer no longer subscribes or handles the kind.
# CHANNEL_WORLD_PULSE_GRAPH removed 2026-07-18: WORLD_PULSE_GRAPH_ENABLED was
# false live (fully inert); rdf-writer no longer subscribes or handles the kind.

# --- Bus Publish Channels ---
CHANNEL_RDF_CONFIRM=orion:rdf:confirm
CHANNEL_RDF_ERROR=orion:rdf:error
CHANNEL_GRAPH_COMPRESSION_STALE=orion:graph:compression:stale

# Graph compression bus schemas (orion/schemas/registry.py)
SCHEMA_COMPRESSION_STALENESS_MARK_V1=CompressionStalenessMarkV1
MESSAGE_KIND_GRAPH_COMPRESSION_STALE=graph.compression.stale.v1

# === RDF Store V1 Cutover ===
# Canonical general RDF write sink: ``orion-rdf-writer`` (this service). Backend-neutral envs:
# RDF_STORE_BACKEND=fuseki
# RDF_STORE_BASE_URL=http://orion-athena-fuseki:3030
# RDF_STORE_DATASET=orion
# RDF_STORE_GRAPH_STORE_URL=http://orion-athena-fuseki:3030/orion/data
# RDF_STORE_QUERY_URL=http://orion-athena-fuseki:3030/orion/query
# RDF_STORE_UPDATE_URL=http://orion-athena-fuseki:3030/orion/update
# RDF_STORE_TIMEOUT_SEC=10.0
# Optional: reduce duplicate chat graph volume during V1 cutover
# RDF_SKIP_KINDS=chat.history.message.v1
# Legacy GraphDB for this service only when RDF_STORE_BACKEND=graphdb (see below).

# --- Global graph mode (active stack: Fuseki / SPARQL) ---
GRAPH_BACKEND=fuseki
GDB_CLIENT_ENABLED=false

# --- GraphDB (legacy explicit only: RDF_STORE_BACKEND=graphdb) ---
# GRAPHDB_URL=http://${PROJECT}-graphdb:7200
GRAPHDB_URL=
GRAPHDB_REPO=collapse
GRAPHDB_USER=
GRAPHDB_PASS=

# --- RDF store (backend-neutral) ---
# graphdb: set RDF_STORE_BACKEND=graphdb and set GRAPHDB_URL + GRAPHDB_REPO above.
# fuseki (Athena default): orion-athena-fuseki on app-net.
# generic/rdf4j: set explicit RDF_STORE_GRAPH_STORE_URL and/or RDF_STORE_UPDATE_URL.
RDF_STORE_BACKEND=fuseki
RDF_STORE_BASE_URL=http://orion-athena-fuseki:3030
RDF_STORE_DATASET=orion
RDF_STORE_QUERY_URL=http://orion-athena-fuseki:3030/orion/query
RDF_STORE_UPDATE_URL=http://orion-athena-fuseki:3030/orion/update
RDF_STORE_GRAPH_STORE_URL=http://orion-athena-fuseki:3030/orion/data
# Local Fuseki dev auth:
# services/orion-rdf-store/.env sets FUSEKI_ADMIN_PASSWORD=orion.
# Therefore local update credentials are admin/orion, not admin/admin.
# Production should override these with real secrets.
RDF_STORE_USER=admin
RDF_STORE_PASS=orion
RDF_STORE_TIMEOUT_SEC=10.0
# When true, GraphDB ?context= uses normalize_graph_name(); default false preserves legacy compact URIs.
RDF_STORE_NORMALIZE_GRAPHDB_CONTEXT=false

# Async writer (decouples bus handlers from store HTTP latency)
RDF_WRITE_ASYNC_ENABLED=true
RDF_WRITE_QUEUE_MAXSIZE=5000
RDF_WRITE_WORKERS=8
RDF_WRITE_MAX_IN_FLIGHT=32
RDF_WRITE_HTTP_MAX_CONNECTIONS=64
RDF_WRITE_HTTP_MAX_KEEPALIVE=32
RDF_WRITE_RETRY_ATTEMPTS=3
RDF_WRITE_RETRY_BASE_DELAY_SEC=0.25
RDF_WRITE_RETRY_MAX_DELAY_SEC=5.0
RDF_WRITE_DEAD_LETTER_ENABLED=true
RDF_WRITE_DEAD_LETTER_PATH=/app/logs/orion-rdf-writer-deadletter.ndjson

# --- RDF store disk layout (Fuseki host paths; operator stack: services/orion-rdf-store) ---
RDF_STORE_DATA_ROOT=/mnt/graphdb/rdf-store
FUSEKI_DATA_DIR=${RDF_STORE_DATA_ROOT}/fuseki
FUSEKI_BACKUP_DIR=${RDF_STORE_DATA_ROOT}/fuseki-backups
FUSEKI_ADMIN_PASSWORD=orion
FUSEKI_PORT=3030
FUSEKI_JVM_XMS=4g
FUSEKI_JVM_XMX=32g
FUSEKI_JVM_GC_OPTS=-XX:+UseG1GC -XX:MaxGCPauseMillis=200
FUSEKI_EXTRA_JAVA_OPTS=
FUSEKI_JVM_ARGS=-Xms${FUSEKI_JVM_XMS} -Xmx${FUSEKI_JVM_XMX} ${FUSEKI_JVM_GC_OPTS} ${FUSEKI_EXTRA_JAVA_OPTS}

# --- Runtime ---
LOG_LEVEL=INFO
# memory.drives.audit.v1 is no longer listed: the handler was deleted 2026-07-15 (Postgres-only via orion-sql-writer).
# memory.identity.snapshot.v1 / memory.goals.proposed.v1 are no longer listed 2026-07-18:
# the channel subscriptions and handlers were removed entirely (not subscribed at all now,
# not just skipped) -- same shape as the drives-audit kill. Listing them here would be dead
# config since the kind can never reach this skip check anymore.
RDF_SKIP_KINDS=chat.history.message.v1
RDF_SKIP_REJECTED=true
RDF_DURABLE_ONLY=false

# --- RDF retention / pruning (SPARQL UPDATE against Fuseki) ---
# Writer runs a background pass every RDF_RETENTION_INTERVAL_HOURS when enabled.
# Operator cron (recommended in addition): cd services/orion-rdf-store && make prune
RDF_RETENTION_ENABLED=true
RDF_RETENTION_DRY_RUN=false
RDF_RETENTION_INTERVAL_HOURS=24
RDF_RETENTION_TIMEOUT_SEC=3600
# Optional SPARQL DELETE for specific graphs only — does NOT touch memory by default.
# TDB bloat is reclaimed with `make compact` in orion-rdf-store, not retention.
# RDF_RETENTION_POLICIES=[{"graph":"http://conjourney.net/graph/orion/cognition","max_age_days":30}]
#
# 2026-07-16: autonomy/{drives,identity,goals} accumulated 83M of 85M total triples in
# this store with zero retention (drives: write path removed 2026-07-15, orphaned;
# identity+goals: RDF_SKIP_KINDS currently gates their writes off entirely, see below —
# so this is not an active leak today, but is the reason it happened once already).
# Caps sized generously vs. current subject cardinality (identity: 5 distinct subjects,
# goals: 4) so a resumed write path can't starve a rarely-updated subject's latest row
# before the next daily pass catches up. One-off historical cleanup for the 2026-07-16
# incident was done directly via SPARQL, not through this policy list (batch_size=200
# default makes bulk catch-up of hundreds of thousands of stale artifacts impractically
# slow one-artifact-at-a-time) — see docs/superpowers/pr-reports/2026-07-16-fuseki-disk-cleanup-pr.md.
RDF_RETENTION_POLICIES=[{"graph":"http://conjourney.net/graph/autonomy/identity","max_artifacts":500,"batch_size":500},{"graph":"http://conjourney.net/graph/autonomy/goals","max_artifacts":2000,"batch_size":500},{"graph":"http://conjourney.net/graph/autonomy/drives","max_artifacts":1,"batch_size":500}]

# WORLD_PULSE_GRAPH_ENABLED / WORLD_PULSE_GRAPH_DRY_RUN /
# WORLD_PULSE_GRAPH_REQUIRE_POLICY_STAMP removed 2026-07-18: the
# world.pulse.graph.upsert.v1 handler and CHANNEL_WORLD_PULSE_GRAPH
# subscription were removed entirely (was already disabled live, dry_run
# by default even when enabled). Settings fields deleted -- nothing reads
# them anymore.
RETRY_LIMIT=3
RETRY_INTERVAL=2

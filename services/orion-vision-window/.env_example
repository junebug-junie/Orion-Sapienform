# -----------------------------
# Orion Vision Window
# -----------------------------
# Mesh bring-up (`mesh-utilities/common/up_all_services.sh`) runs:
#   docker compose --env-file <repo>/.env --env-file services/orion-vision-window/.env -f ...
#
# ORION_BUS_URL — required when running compose from this directory alone.
ORION_BUS_URL=redis://100.92.216.81:6379/0

# Optional (normally from root `.env` / compose defaults)
# LOG_LEVEL=INFO
# ORION_BUS_ENABLED=true

ORION_BUS_ENFORCE_CATALOG=true

# Host port -> container :8000 (compose default 8019; 8010 is used by orion-vector-writer)
# VISION_WINDOW_HTTP_PORT=8019

# Bus channels (defaults match `app/settings.py`)
CHANNEL_WINDOW_INTAKE=orion:vision:artifacts
CHANNEL_WINDOW_PUB=orion:vision:windows
CHANNEL_WINDOW_REQUEST=orion:exec:request:VisionWindowService

# Rolling window / flush
WINDOW_SIZE_SEC=30.0
FLUSH_INTERVAL_MS=5000
MAX_ARTIFACTS_PER_WINDOW=64
MAX_WINDOW_AGE_MS=60000
STALE_AFTER_MS=120000

# Scene belief habituation (observed → believed tier in summary.evidence)
WINDOW_BELIEF_ENABLED=true
WINDOW_BELIEF_VOTE_N=3
WINDOW_BELIEF_ENTER_VOTES=2
WINDOW_BELIEF_EXIT_VOTES=1

# HTTP (in-container listen; host mapping is VISION_WINDOW_HTTP_PORT above)
# HTTP_HOST=0.0.0.0
# HTTP_PORT=8000

# Bounded Redis recovery (empty VISION_WINDOW_RECOVERY_REDIS_URL → use ORION_BUS_URL)
VISION_WINDOW_RECOVERY_ENABLED=true
VISION_WINDOW_RECOVERY_REDIS_URL=
VISION_WINDOW_RECOVERY_TTL_SEC=3600
VISION_WINDOW_RECOVERY_MAX_N=50
VISION_WINDOW_HTTP_MAX_LIMIT=50
VISION_WINDOW_READY_REQUIRES_RECOVERY=false

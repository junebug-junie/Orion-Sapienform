{
  "permissions": {
    "allow": [
      "Bash(/mnt/scripts/Orion-Sapienform/orion_dev/bin/pytest *)",
      "Bash(node --check *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/athena/.local/bin/graphify hook-guard search"
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/hooks/destructive_git_guard.py\""
          }
        ]
      },
      {
        "matcher": "Read|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "/home/athena/.local/bin/graphify hook-guard read"
          }
        ]
      }
    ]
  }
}
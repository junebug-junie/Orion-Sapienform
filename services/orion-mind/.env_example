# Copy to `.env` in this directory (same folder as `docker-compose.yml`).
# Keys match `app/settings.py` (Pydantic) and `docker-compose.yml` (subset + compose-only).
#
# Local:  uvicorn is usually run from `services/orion-mind`; settings load this file via path.
# Docker: `docker compose` reads `.env` for substitution; the service also receives the
#         `environment:` block below (defaults apply if a key is unset in `.env`).

# --- Docker Compose (host / container naming) --------------------------------
PROJECT=orion
# Host port published to your machine (left side of ports: mapping)
HOST_PORT=6611

# --- App & process (consumed by Pydantic `Settings` and uvicorn) ------------
SERVICE_NAME=orion-mind
SERVICE_VERSION=0.1.0
NODE_NAME=local-dev
LOG_LEVEL=INFO
# Port the API listens on inside the container and for local uvicorn
PORT=6611

# --- Mind engine defaults ----------------------------------------------------
MIND_SNAPSHOT_MAX_BYTES=512000
MIND_WALL_MS_DEFAULT=120000
MIND_N_LOOPS_DEFAULT=1
# Leave empty to use packaged `app/config/router_profiles.yaml`
MIND_ROUTER_PROFILES_PATH=

# --- Evidence pack bounds -----------------------------------------------------
MIND_EVIDENCE_MAX_CHARS=12000
MIND_EVIDENCE_MAX_MESSAGES=8
MIND_EVIDENCE_MAX_RECALL_FRAGMENTS=8
MIND_EVIDENCE_MAX_PROJECTION_ITEMS=16

# --- LLM synthesis (Qwen routes via LLM gateway) -----------------------------
# semantic: quick lane (e.g. Qwen3 8B non-thinking) | appraisal: metacog (30B/32B thinking) | stance: chat
MIND_LLM_SYNTHESIS_ENABLED=false
MIND_SEMANTIC_MODEL_ROUTE=quick
MIND_APPRAISAL_MODEL_ROUTE=metacog
MIND_STANCE_MODEL_ROUTE=chat
MIND_LLM_TIMEOUT_SEC=90
MIND_LLM_MAX_TOKENS_SEMANTIC=2048
MIND_LLM_MAX_TOKENS_APPRAISAL=3072
MIND_LLM_MAX_TOKENS_STANCE=1536
MIND_LLM_THINKING_APPRAISAL=true
MIND_LLM_FAIL_OPEN_LEGACY=true

# --- Bus → LLM gateway -------------------------------------------------------
MIND_LLM_USE_BUS=true
ORION_BUS_ENABLED=true
MIND_LLM_INTAKE_CHANNEL=orion:exec:request:LLMGatewayService
MIND_LLM_REPLY_PREFIX=orion:mind:llm:reply

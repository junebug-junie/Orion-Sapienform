# orion-embodiment — mind-to-sprite bridge (docker compose)
# Athena operator contract: copy/sync this file to .env; do not maintain a parallel override block.
PROJECT=orion-athena
SERVICE_NAME=orion-embodiment
SERVICE_VERSION=0.1.0
NODE_NAME=athena
# Worker log level (DEBUG|INFO|WARNING|ERROR). Configured at boot so the loop's
# perception/speech/journal decisions surface in `docker logs`.
EMBODIMENT_LOG_LEVEL=INFO
# Orion bus (Redis) — pass through from root .env (Tailscale node); never hardcode bus-core here.
ORION_BUS_URL=${ORION_BUS_URL}
ORION_BUS_ENABLED=true
# Master switch — on for Athena AI Town embodiment.
ORION_EMBODIMENT_ENABLED=true
# AITOWN_* + secrets are loaded from ~/.fcc/.env (mounted ro), not this file.
EMBODIMENT_FCC_ENV_PATH=/root/.fcc/.env
# Override the Convex URL from ~/.fcc/.env when the container can't reach the host
# value (e.g. http://host.docker.internal:3210). Empty = use ~/.fcc/.env as-is.
EMBODIMENT_AITOWN_CONVEX_URL=
EMBODIMENT_DELIBERATE_HOLD_SEC=8
EMBODIMENT_WANDER_RADIUS=3
EMBODIMENT_LOCATIONS_JSON={}
EMBODIMENT_IDLE_HEARTBEAT_SEC=20
# Keep the AI Town engine awake so moveTo lands (also runs other town agents).
EMBODIMENT_WORLD_HEARTBEAT_ENABLED=true
EMBODIMENT_ORION_SPRITE=f1
EMBODIMENT_SELF_STATE_URL=http://orion-self-state-runtime:8118
# Orion's authored AI Town card (full identity blurb the bootstrap joins with).
# Source of truth: services/orion-ai-town/cards/town_cards.yaml, composed into
# cards/generated/orion_town_card.txt by scripts/generate_descriptions.py.
# Empty = use the built-in repo path (host runs). In-container the compose file
# mounts the card and sets /app/town_cards/orion_town_card.txt.
EMBODIMENT_TOWN_CARDS_PATH=
EMBODIMENT_PERCEPTION_INTERVAL_SEC=3
EMBODIMENT_SOCIAL_COOLDOWN_SEC=120
# Debounce competing move actuations across producers. 0 = off.
EMBODIMENT_MOVE_COOLDOWN_SEC=6
EMBODIMENT_SPEECH_ENABLED=true
EMBODIMENT_SPEECH_LANE=quick
# Cortex verb used to generate a town utterance (reuses the existing cortex chat rail).
EMBODIMENT_SPEECH_VERB=chat_quick
EMBODIMENT_SPEECH_TIMEOUT_SEC=45
# Town speech uses the chat exec lane — never the legacy intake (harness/chat_general starve it).
EMBODIMENT_CORTEX_REQUEST_CHANNEL=orion:cortex:exec:request:chat
EMBODIMENT_CORTEX_RESULT_PREFIX=orion:exec:result
# Optional grounded_small chat_general pass before chat_quick fallback (off for town latency).
EMBODIMENT_SPEECH_UNIFIED_ENABLED=false
EMBODIMENT_SPEECH_HUB_LLM_ROUTE=quick
# Grounded_small cortex RPC timeout (sec); then falls back to quick.
EMBODIMENT_UNIFIED_TIMEOUT_SEC=45
EMBODIMENT_MEMORY_ENABLED=true
# Conversation engagement: accept invites, walk to partner, reach participating.
EMBODIMENT_SOCIAL_ENABLED=true
# Tile distance under which Orion self-initiates with a nearby player. 0 = never.
EMBODIMENT_SOCIAL_INITIATE_DISTANCE=6
EMBODIMENT_CHANNEL_INTENT=orion:embodiment:intent
EMBODIMENT_CHANNEL_OUTCOME=orion:embodiment:outcome
EMBODIMENT_CHANNEL_PERCEPTION=orion:embodiment:perception
EMBODIMENT_PORT=8130

# services/orion-llamacpp-host/.env
#
# Single-worker defaults plus Atlas multi-worker examples.
# For Atlas bring-up, the shared vars below stay the same for every worker,
# and the ATLAS_* vars define the three isolated containers in
# docker-compose.atlas-workers.yml.

SERVICE_NAME=orion-llamacpp-host
SERVICE_VERSION=0.1.1
ORION_BUS_URL=redis://100.92.216.81:6379/0

# Which profile this single worker service should boot
LLM_PROFILES_CONFIG_PATH=/app/config/llm_profiles.yaml
LLM_PROFILE_NAME=
#llama3-8b-instruct-q4km-athena-p4
#qwen2.5-32b-instruct-abliterated-gguf
#deepseek-70b-gguf-atlas

# Container mount root for models volume (compose mounts host cache -> /models)
MODELS_MOUNT_ROOT=/models
LLM_CACHE_DIR=/mnt/telemetry/llm-cache

# Optional: HuggingFace token (only needed for gated/private)
HF_TOKEN=
hf_token=

# Optional: runtime overrides (ONLY if you want to override the profile YAML)
# (These are your “safe boot” levers if the model crashes at 8192/parallel/etc.)
LLAMACPP_HOST_OVERRIDE=
LLAMACPP_PORT_OVERRIDE=
LLAMACPP_MODEL_PATH_OVERRIDE=

LLAMACPP_CTX_SIZE_OVERRIDE=
LLAMACPP_N_GPU_LAYERS_OVERRIDE=
LLAMACPP_THREADS_OVERRIDE=
LLAMACPP_N_PARALLEL_OVERRIDE=
LLAMACPP_BATCH_SIZE_OVERRIDE=

# Optional: override GPU pinning (otherwise uses profile.gpu.device_ids)
# Supports early application before GPU init.
CUDA_VISIBLE_DEVICES_OVERRIDE=0,1,2,3

# Behavior
ENSURE_MODEL_DOWNLOAD=true
WAIT_FOR_MODEL_SECONDS=0

# Host port mapping (used by compose for published port)
LLAMACPP_HOST_PORT=7005
ORION_BUS_ENFORCE_CATALOG=true

# `MODELS_MOUNT_ROOT`, `ENSURE_MODEL_DOWNLOAD`, and `WAIT_FOR_MODEL_SECONDS`
# remain in this example for compose compatibility with sibling host services.
# Current orion-llamacpp-host runtime does not read them directly.

# Atlas multi-worker example values (used by docker-compose.atlas-workers.yml).
# Keep chat pointed at the current Atlas chat profile; set this explicitly to
# your existing Atlas chat profile name because the compose service has no
# fallback for this value.
# Every worker below must keep a unique SERVICE_NAME, HOST_PORT,
# CUDA_VISIBLE_DEVICES binding, and LLM_PROFILE_NAME.
ATLAS_CHAT_SERVICE_NAME=atlas-worker-1
ATLAS_CHAT_PROFILE_NAME=qwen2.5-32b-instruct-abliterated-gguf
#llama3-8b-instruct-q4km-athena-p4
ATLAS_CHAT_CUDA_VISIBLE_DEVICES=0,3
ATLAS_CHAT_HOST_PORT=8011

ATLAS_METACOG_SERVICE_NAME=atlas-worker-2
ATLAS_METACOG_PROFILE_NAME=llama3-8b-instruct-q4km-atlas-metacog
ATLAS_METACOG_CUDA_VISIBLE_DEVICES=2
ATLAS_METACOG_HOST_PORT=8012

ATLAS_AGENT_SERVICE_NAME=atlas-worker-agent-1
ATLAS_AGENT_PROFILE_NAME=qwen3-30b-a3b-q4km-atlas-agent
ATLAS_AGENT_CUDA_VISIBLE_DEVICES=1
ATLAS_AGENT_HOST_PORT=8014

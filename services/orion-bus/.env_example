# ────────────────────────────────────────────────
# 🌐 Orion Mesh Global Environment
# Automatically sourced by all services
# ────────────────────────────────────────────────


# Default Redis connection (may be overridden per node or managed)
REDIS_URL=redis://100.92.216.81:6379/0
REDIS_PORT=6379
REDIS_EXPORTER_PORT=9121
REDIS_DATA_VOL=${PROJECT}_redis_data

# Cold-standby bus-core (docker-compose.atlas-standby.yml only). Not read by
# the primary docker-compose.yml. Deployed on a separate mesh node (atlas by
# default -- see docs/notes/2026-07-16-bus-core-standby-cutover-runbook.md).
# Passive: no client points ORION_BUS_URL here automatically. Defaults to a
# different port than REDIS_PORT (6379) so it's safe to co-locate with the
# primary on one host for testing without a port collision; override back to
# 6379 on the real standby node if you want cutover to be a pure IP swap.
# NOT 6380: services/orion-falkordb/ (shared FalkorDB operator stack) binds
# host port 6380 -- co-locating the standby with FalkorDB on the same host
# would collide. See services/orion-falkordb/README.md.
# Confirmed free across every services/*/docker-compose*.yml as of 2026-07-16.
BUS_STANDBY_PORT=6381

# Substrate transport traces (bounded rollups; default off)
PUBLISH_ORION_BUS_GRAMMAR=true
GRAMMAR_EVENT_CHANNEL=orion:grammar:event
BUS_OBSERVER_ENABLED=true
BUS_OBSERVER_POLL_INTERVAL_SEC=10
# 2026-07-18 resolution: orion:evt:gateway/orion:bus:out were never real --
# they were placeholder names introduced in the original bus-observer commit
# (ee810551, 2026-05-25) and never once appeared in orion/bus/channels.yaml
# at any point in git history (git log -S on both strings against
# channels.yaml returns nothing). Verified live against bus-core Redis
# (TYPE + XLEN): both are TYPE=none (no key exists at all), consistent with
# 180 substrate_reduction_receipts spanning 15 days (2026-07-03 to
# 2026-07-18) showing transport_pressure/stream_depth_pressure/backpressure
# at a flat 0.0 with zero variance the entire time -- not "currently quiet",
# structurally incapable of ever producing a sample. orion:grammar:event is
# cataloged (schema_id=GrammarEventV1) but is also TYPE=none live: delivered
# purely via Redis PUBLISH (OrionBusAsync.publish(), never XADD'd anywhere in
# this repo), so XLEN/XREVRANGE can never see it regardless of real traffic.
#
# Root architecture fact, not a naming accident: orion-bus today routes
# almost everything through Redis pub/sub, which has no persistent backlog to
# observe (a subscriber either receives an in-flight message or misses it --
# there's no queue depth the way a Stream has one). Depth/backpressure is
# only a meaningful, measurable concept for the channels that are genuinely
# XADD'd via RedisStreamWorkQueue. orion/bus/channels.yaml catalogs exactly
# two such channels (kind: "stream"): orion:stream:world_pulse:run:result
# (cataloged, schema_id=WorldPulseRunResultV1, written via real XADD by
# orion-world-pulse -- WP_RUN_RESULT_STREAM_ENABLED=true by default, see
# services/orion-world-pulse/.env_example; verified live TYPE=stream, XLEN=82
# real entries) and its dead-letter sibling
# orion:stream:world_pulse:run:result:dlq (same schema_id; verified live
# TYPE=none/XLEN=0 right now, which is expected-healthy for a DLQ -- zero
# means no poison messages -- not evidence it's broken; a DLQ going nonzero
# is itself a real, meaningful backpressure/failure signal worth having
# wired). These are the only two real Streams in the current architecture,
# so they are now the entire default.
BUS_OBSERVER_STREAMS=orion:stream:world_pulse:run:result,orion:stream:world_pulse:run:result:dlq
BUS_STREAM_DEPTH_WARNING=25000
BUS_STREAM_DEPTH_CRITICAL=100000
BUS_OBSERVER_NODE_ID=athena
BUS_CHANNELS_CATALOG_PATH=orion/bus/channels.yaml
# Per-stream XREVRANGE sample size for the schema-mismatch check (contract_pressure).
# Only applied to configured streams that ARE in the channel catalog (uncataloged
# streams are already covered by catalog_drift_pressure). Keep small: cost scales as
# len(BUS_OBSERVER_STREAMS) * this value extra Redis reads per poll tick.
BUS_OBSERVER_SCHEMA_SAMPLE_COUNT=5

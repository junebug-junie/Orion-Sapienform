# =========================
# orion-cortex-orchestrator
# =========================

PROJECT=orion-athena
NET=app-net
NODE_NAME=athena

# Redis bus (required — orch is bus-driven; use host-reachable URL on your stack)
ORION_BUS_URL=redis://100.92.216.81:6379/0
ORION_BUS_ENABLED=true
ORION_BUS_ENFORCE_CATALOG=true

SERVICE_NAME=cortex-orch
SERVICE_VERSION=0.1.1
 
HEARTBEAT_INTERVAL_SEC=10

# Bus routing channels (for exec fan-out + result fan-in)
EXEC_REQUEST_PREFIX=orion:exec:request
EXEC_RESULT_PREFIX=orion:exec:result

# Optional: Orchestrator request/result channels (if you want to drive it over the bus)
ORCH_REQUEST_CHANNEL=orion:cortex:request
ORCH_RESULT_PREFIX=orion:cortex:result

# --- Exec lane isolation (Phase 2): set EXEC_LANE_ROUTING_ENABLED=true and run one cortex-exec per lane ---
# Orch sends chat via orion:verb:request, not CHANNEL_EXEC_REQUEST_CHAT, unless you add a direct-chat path.
EXEC_LANE_ROUTING_ENABLED=false
CHANNEL_EXEC_REQUEST=orion:cortex:exec:request
CHANNEL_EXEC_REQUEST_CHAT=orion:cortex:exec:request:chat
CHANNEL_EXEC_REQUEST_SPARK=orion:cortex:exec:request:spark
CHANNEL_EXEC_REQUEST_BACKGROUND=orion:cortex:exec:request:background

# Timeout for waiting on per-step results (ms)
ORION_CORTEX_STEP_TIMEOUT_MS=700000

# HTTP API config
API_HOST=0.0.0.0
API_PORT=8072
LOG_LEVEL=INFO


# --- Latest Orion State (Spark read-model) ---
ORION_STATE_ENABLED=true
STATE_REQUEST_CHANNEL=orion:state:request
STATE_RESULT_PREFIX=orion:state:reply
STATE_TIMEOUT_SEC=60.0
STATE_SCOPE=global
STATE_NODE=

# --- Metacognition routing ---
CHANNEL_METACOGNITION_TICK=orion:metacognition:tick
CHANNEL_METACOGNITION_ENRICHED=orion:metacognition:enriched
METACOGNITION_ENRICHED_KIND=metacognition.enriched.v1
CHANNEL_EQUILIBRIUM_METACOG_TRIGGER=orion:equilibrium:metacog:trigger

# --- Auto router ---
AUTO_ROUTER_LLM_ENABLED=false
AUTO_ROUTER_LLM_REQUEST_CHANNEL=orion:exec:request:LLMGatewayService
AUTO_ROUTER_LLM_REPLY_PREFIX=orion:llm:reply

# --- Spark ConceptProfile repository backend (Phase 3A shadow rollout) ---
CONCEPT_PROFILE_REPOSITORY_BACKEND=local
CONCEPT_PROFILE_BACKEND_CONCEPT_INDUCTION_PASS=graph
CONCEPT_PROFILE_GRAPH_CUTOVER_FALLBACK_POLICY=fail_open_local
CONCEPT_PROFILE_GRAPHDB_ENDPOINT=http://orion-athena-fuseki:3030/orion/query
CONCEPT_PROFILE_GRAPHDB_URL=
CONCEPT_PROFILE_GRAPHDB_REPO=collapse
CONCEPT_PROFILE_GRAPHDB_USER=admin
CONCEPT_PROFILE_GRAPHDB_PASS=orion
CONCEPT_PROFILE_GRAPH_TIMEOUT_SEC=6
CONCEPT_PROFILE_GRAPH_URI=http://conjourney.net/graph/spark/concept-profile
CONCEPT_PROFILE_PARITY_MIN_COMPARISONS=50
CONCEPT_PROFILE_PARITY_MAX_MISMATCH_RATE=0.05
CONCEPT_PROFILE_PARITY_MAX_UNAVAILABLE_RATE=0.02
CONCEPT_PROFILE_PARITY_CRITICAL_MISMATCH_CLASSES=profile_missing_on_graph,profile_missing_on_local,query_error

# --- Memory cards (always-inject + optional Stage 1 auto-extractor) ---
# Same logical DB as orion-recall RECALL_PG_DSN / Hub memory store (memory_cards + recall).
# Cortex-orch compose joins external app-net — use the Postgres service hostname on that network
# (matches orion-recall, orion-cortex-exec, orion-sql-writer on Athena stacks):
# Required for github_compactor_pass memory card supersede (repo_dev_snapshot slot).
RECALL_PG_DSN=postgresql://postgres:postgres@orion-athena-sql-db:5432/conjourney
# If orch runs on the host (not Docker) while Postgres is only published to the host port, use instead:
# RECALL_PG_DSN=postgresql://postgres:postgres@127.0.0.1:55432/conjourney
ORION_AUTO_EXTRACTOR_ENABLED=false
ORION_AUTO_EXTRACTOR_STAGE2_ENABLED=false
ORION_AUTO_EXTRACTOR_AUTO_PROMOTE_THRESHOLD=2

# --- Orion Mind (HTTP to services/orion-mind; Hub enables via context.metadata mind_enabled only through Orch) ---
# Hostname must match the Mind container on app-net: ${PROJECT:-orion}-mind (e.g. orion-mind or orion-athena-mind).
ORION_MIND_BASE_URL=http://orion-mind:6611
# Outer HTTP timeout for POST /v1/mind/run; must exceed Mind wall time (e.g. 210s > 180s).
ORION_MIND_TIMEOUT_SEC=210
MIND_N_LOOPS_DEFAULT=1
MIND_WALL_MS_DEFAULT=180000
ORION_MIND_MAX_RESPONSE_BYTES=2000000

# --- Mind projection preflight (Exec parity before Mind runs) ---
# Prefetch recall_bundle into plan ctx so the recall substrate producer can contribute at Orch time.
CHANNEL_RECALL_INTAKE=orion:exec:request:RecallService
# Reply prefix must be catalog-registered (orion:exec:result:RecallService:*). Orch is a consumer, not a separate channel.
CHANNEL_RECALL_REPLY_PREFIX=orion:exec:result:RecallService
MIND_RECALL_PREFETCH_ENABLED=true
# Bus RPC wait for RecallService during Mind preflight (not HTTP). Tune only after logs show healthy path.
MIND_RECALL_PREFETCH_TIMEOUT_SEC=30

# --- Substrate tier telemetry (optional HTTP pull before Mind) ---
# Leave ORION_SUBSTRATE_TELEMETRY_READ_TOKEN empty on trusted internal networks (no X-Telemetry-Token).
# Set only if orion-substrate-telemetry has SUBSTRATE_TELEMETRY_READ_API_TOKEN set.
ORION_SUBSTRATE_TELEMETRY_BASE_URL=
ORION_SUBSTRATE_TELEMETRY_TIMEOUT_SEC=2.0
ORION_SUBSTRATE_TELEMETRY_READ_TOKEN=

# --- Route arbitration grammar trace (default on) ---
# Publishes lane/mind/output_mode arbitration facts as a GrammarEventV1 trace
# (trace_id prefix "orch.route:") for the route_loop reducer. Fire-and-forget;
# never affects the chat response even when enabled. Requires
# manual_migration_route_substrate_loop.sql applied on substrate-runtime's DB
# before ENABLE_ROUTE_GRAMMAR_REDUCER is turned on there too, or the reducer
# will fail writing the projection.
PUBLISH_CORTEX_ORCH_GRAMMAR=true
GRAMMAR_EVENT_CHANNEL=orion:grammar:event

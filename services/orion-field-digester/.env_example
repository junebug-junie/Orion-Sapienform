PROJECT=orion-athena
SERVICE_NAME=orion-field-digester
SERVICE_VERSION=0.1.0
NODE_NAME=athena
FIELD_DIGESTER_PORT=8116

POSTGRES_URI=postgresql://postgres:postgres@orion-athena-sql-db:5432/conjourney
LATTICE_PATH=/app/config/field/orion_field_topology.v1.yaml
BIOMETRICS_FIELD_DECAY_RATE=0.92
BIOMETRICS_FIELD_DIFFUSION_RATE=1.0
RECEIPT_POLL_INTERVAL_SEC=2.0
ENABLE_TRANSPORT_FIELD_DIGESTION=true
# Default false: enabling before retention exists for substrate_field_state
# (and downstream substrate_attention_frame/substrate_self_state) risks
# unbounded row growth -- see README "Idle tick (pacemaker)" section.
# Enabled here so the field→attention→self_state heartbeat chain runs on Athena.
# Retention keys below bound substrate_field_state growth (~43k rows/day at 2s cadence).
FIELD_DIGESTER_IDLE_TICK_ENABLED=true
FIELD_STATE_RETENTION_HOURS=72.0
FIELD_STATE_PRUNE_INTERVAL_SEC=3600.0
LOG_LEVEL=INFO

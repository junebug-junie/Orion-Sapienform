PROJECT=orion-athena
SERVICE_NAME=orion-self-state-runtime
SERVICE_VERSION=0.1.0
POSTGRES_URI=postgresql://postgres:postgres@orion-athena-sql-db:5432/conjourney
SELF_STATE_POLICY_PATH=/app/config/self_state/self_state_policy.v1.yaml
SELF_STATE_POLL_INTERVAL_SEC=2.0
ENABLE_SELF_STATE_RUNTIME=true
# Transport M6: include transport_integrity dimension in self-state scoring (default off)
ENABLE_TRANSPORT_SELF_STATE_INFLUENCE=true
# Discard stale previous_self_state after policy change or long idle (seconds)
SELF_STATE_MAX_PREVIOUS_AGE_SEC=300.0
LOG_LEVEL=INFO
SELF_STATE_RUNTIME_PORT=8118

# Bus (publish SelfStateV1 after each save — Wire 1)
ORION_BUS_URL=${ORION_BUS_URL}
ORION_BUS_ENABLED=true
CHANNEL_SUBSTRATE_SELF_STATE=orion:substrate:self_state

# Bounded retention for substrate_self_state, self_state_predictions and
# identity_snapshots (per-tick / per-10-ticks writers). Newest row of each
# table is always kept. 0 disables.
SELF_STATE_RETENTION_HOURS=72.0
SELF_STATE_PRUNE_INTERVAL_SEC=3600.0

# ───────────────────────────────────────────────────────────────
# 🎧 Orion Hub — Voice + Web Gateway
# ───────────────────────────────────────────────────────────────
#
# Docker Compose: hub `docker-compose.yml` uses optional `env_file: .env` and passes
# variables through the `environment:` block. For `${VAR}` substitution in that block,
# either run `docker compose` from `services/orion-hub/`, or from the repo root use:
#   docker compose --env-file services/orion-hub/.env -f services/orion-hub/docker-compose.yml ...
#

# --- Service Identity ---
SERVICE_NAME=hub
SERVICE_VERSION=0.4.0
HUB_PORT=8080
HUB_API_BASE_OVERRIDE=
HUB_WS_BASE_OVERRIDE=

# --- Bus Configuration ---
ORION_BUS_ENABLED=true
ORION_BUS_ENFORCE_CATALOG=true
ORION_BUS_URL=redis://100.92.216.81:6379/0

# --- Landing Pad ---
LANDING_PAD_TIMEOUT_SEC=10

# --- Topic Foundry ---
TOPIC_FOUNDRY_BASE_URL=http://127.0.0.1:8615
WORLD_PULSE_BASE_URL=http://127.0.0.1:8628

# --- Social Memory ---
SOCIAL_MEMORY_BASE_URL=http://127.0.0.1:8765

# --- Biometrics Cache (Hub) ---
BIOMETRICS_ENABLED=true
BIOMETRICS_STALE_AFTER_SEC=60
BIOMETRICS_NO_SIGNAL_AFTER_SEC=600
BIOMETRICS_ROLE_WEIGHTS_JSON={"atlas":0.6,"athena":0.4}
BIOMETRICS_PUSH_INTERVAL_SEC=5

# --- In-app Notifications (Hub) ---
NOTIFY_IN_APP_ENABLED=true
NOTIFY_IN_APP_CHANNEL=orion:notify:in_app
NOTIFY_IN_APP_MAX=200
NOTIFY_TOAST_SECONDS=8
NOTIFY_BASE_URL=http://127.0.0.1:7140
NOTIFY_API_TOKEN=

# --- Cortex Gateway Integration (Titanium) ---
CORTEX_GATEWAY_REQUEST_CHANNEL=orion:cortex:gateway:request
CORTEX_GATEWAY_RESULT_PREFIX=orion:cortex:gateway:result

# --- TTS Integration (Titanium) ---
TTS_REQUEST_CHANNEL=orion:tts:intake
TTS_RESULT_PREFIX=orion:tts:result

# --- STT Integration (Titanium) ---
STT_REQUEST_CHANNEL=orion:stt:intake
STT_RESULT_PREFIX=orion:stt:result

# --- Legacy / Deprecated Channels (Preserved for compatibility) ---
WHISPER_MODEL_SIZE=distil-small.en
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float32
CHANNEL_VOICE_TRANSCRIPT=orion:voice:transcript
CHANNEL_VOICE_LLM=orion:voice:llm
CHANNEL_VOICE_TTS=orion:voice:tts
CHANNEL_TTS_INTAKE=orion:tts:intake
CHANNEL_COLLAPSE_INTAKE=orion:collapse:intake
CHANNEL_COLLAPSE_TRIAGE=orion:collapse:triage
LLM_GATEWAY_SERVICE_NAME=LLMGatewayService
EXEC_REQUEST_PREFIX=orion:exec:request
CHANNEL_LLM_INTAKE=orion:exec:request:LLMGatewayService
CHANNEL_LLM_REPLY_PREFIX=orion:llm:reply:
CORTEX_REQUEST_CHANNEL=orion:cortex:request
CORTEX_RESULT_PREFIX=orion:cortex:result
AGENT_CHAIN_REQUEST_CHANNEL=orion:exec:request:AgentChainService
AGENT_CHAIN_RESULT_PREFIX=orion:exec:result:AgentChainService
CHAT_HISTORY_LOG_CHANNEL=orion:chat:history:log
CHANNEL_CHAT_HISTORY_LOG=orion:chat:history:log
CHANNEL_COUNCIL_INTAKE=orion:agent-council:intake
CHANNEL_COUNCIL_REPLY_PREFIX=orion:agent-council:reply
CHANNEL_RECALL_REQUEST=orion:exec:request:RecallService
CHANNEL_RECALL_DEFAULT_REPLY_PREFIX=orion:exec:result:RecallService
RECALL_DEFAULT_MAX_ITEMS=16
RECALL_DEFAULT_TIME_WINDOW_DAYS=30
RECALL_DEFAULT_MODE=hybrid
HUB_RECALL_SERVICE_URL=
RECALL_SERVICE_URL=http://orion-recall:8090
HUB_RECALL_SHADOW_EVAL_TIMEOUT_SEC=20
HUB_RECALL_SHADOW_EVAL_MAX_ROWS_PER_RUN=128
HUB_RECALL_SHADOW_EVAL_DEFAULT_CORPUS_LIMIT=24

# --- Runtime / Mode ---
MODE=dev
TIMEOUT_SEC=300

# --- Hub Prompt Context (UI-side rolling history) ---
# Number of *turns* (user+assistant pairs) to include as inline context
HUB_CONTEXT_TURNS=12
# Hard cap to avoid runaway prompts when users paste long text
HUB_CONTEXT_MAX_CHARS=12000                                                     

# --- Recall Debugging ---
# When true, allows POST /api/substrate/mutation-runtime/recall-eval-suite/record (still requires SUBSTRATE_MUTATION_OPERATOR_TOKEN).
HUB_RECALL_EVAL_RECORDING_ENABLED=false
HUB_DEBUG_RECALL=false
HUB_DEBUG_COUNCIL=false
HUB_SOCIAL_SKILLS_ENABLED=true
HUB_SOCIAL_SKILLS_ALLOWLIST=social_artifact_dialogue,social_summarize_thread,social_safe_recall,social_self_ground,social_followup_question,social_room_reflection,social_exit_or_pause
HUB_SOCIAL_STYLE_ADAPTATION_ENABLED=true
HUB_SOCIAL_ROOM_RITUALS_ENABLED=true
HUB_SOCIAL_STYLE_CONFIDENCE_FLOOR=0.35
ORION_PRESENCE_SESSION_TTL_SECONDS=14400
ORION_PRESENCE_DEFAULT_REQUESTOR=Juniper
ORION_PRESENCE_PERSIST_ALLOWED=false

# --- No-Write Debug Mode ---
HUB_DEFAULT_NO_WRITE=false
HUB_AUTO_DEFAULT_ENABLED=false

# --- Hub Docker networking posture ---
# Hub docker-compose uses network_mode: "host" by default.
# In host mode, Docker service DNS names (for example "orion-athena-sql-db") do NOT resolve.
# Use a host-reachable Postgres host instead: 127.0.0.1, LAN IP, Tailscale IP, etc.
HUB_DOCKER_NETWORK_MODE=host

# --- Substrate control-plane SQL source (Phase 20c parity) ---
# Precedence for Hub control-plane reads:
# 1) SUBSTRATE_CONTROL_PLANE_POSTGRES_URL
# 2) SUBSTRATE_POLICY_POSTGRES_URL
# 3) DATABASE_URL
# Prefer shared operational Postgres over local sqlite seams.
# for a host-networked Hub, the right DB URL is:
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55432/conjourney
SUBSTRATE_CONTROL_PLANE_POSTGRES_URL=
SUBSTRATE_POLICY_POSTGRES_URL=
SUBSTRATE_REVIEW_QUEUE_SQL_DB_PATH=
# Optional sqlite file for review telemetry when Postgres is not used (parity with queue seam).
SUBSTRATE_REVIEW_TELEMETRY_SQL_DB_PATH=
SUBSTRATE_AUTONOMY_ENABLED=false
SUBSTRATE_AUTONOMY_PROPOSALS_ENABLED=true
SUBSTRATE_AUTONOMY_APPLY_ENABLED=false
SUBSTRATE_AUTONOMY_MONITOR_ENABLED=true
SUBSTRATE_AUTONOMY_ROUTING_PROPOSALS_ENABLED=true
SUBSTRATE_AUTONOMY_COGNITIVE_PROPOSALS_ENABLED=false
SUBSTRATE_AUTONOMY_ROUTING_APPLY_ENABLED=false
SUBSTRATE_AUTONOMY_ROUTING_ROLLBACK_DELTA_THRESHOLD=-0.05
SUBSTRATE_AUTONOMY_INTERVAL_SEC=30
SUBSTRATE_MUTATION_RETENTION_MAX_BLOCKED_APPLIES=500
SUBSTRATE_MUTATION_RETENTION_MAX_ROLLBACKS=500
SUBSTRATE_MUTATION_CONTROL_SQL_DB_PATH=

# --- Substrate semantic graph (GraphDB) ---
# Code default is in_memory unless backend is graphdb (aliases: graph_db, rdf).
# With HUB_DOCKER_NETWORK_MODE=host, GraphDB must be a host-reachable URL (e.g. 127.0.0.1:7200),
# not a Docker Compose service hostname.
SUBSTRATE_STORE_BACKEND=graphdb
# Full SPARQL endpoint; preferred when set. Example matches published GraphDB + collapse repo:
SUBSTRATE_GRAPHDB_ENDPOINT=http://127.0.0.1:7200/repositories/collapse
# If SUBSTRATE_GRAPHDB_ENDPOINT is empty, build_substrate_store_from_env() can build from:
# GRAPHDB_URL=http://127.0.0.1:7200
# GRAPHDB_REPO=collapse
SUBSTRATE_GRAPHDB_GRAPH_URI=http://conjourney.net/graph/orion/substrate
SUBSTRATE_GRAPHDB_TIMEOUT_SEC=5.0
SUBSTRATE_GRAPHDB_USER=
SUBSTRATE_GRAPHDB_PASS=

# --- Substrate operator seed (optional) ---
# One-shot demo nodes/edges into GraphDB (same contracts as production materialization).
# In a running hub container with the repo mounted at /repo, use a neutral cwd so Python
# loads orion from the mount (WORKDIR /app shadows orion on PYTHONPATH=/repo:/app):
#   docker exec <hub> sh -c 'cd /tmp && env PYTHONPATH=/repo python3 /repo/services/orion-hub/scripts/seed_substrate_graphdb.py'
# After a new image build, the script also lives under /app/scripts/ when not using /repo.

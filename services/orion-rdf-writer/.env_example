# ───────────────────────────────────────────────────────────────
# ✍️  Orion RDF Writer — bus → triples → RDF store (GraphDB, Fuseki, …)
# ───────────────────────────────────────────────────────────────

# --- Stack / compose placeholders (match other Orion services) ---
PROJECT=orion-athena
NET=app-net
NODE_NAME=athena
BATCH_SIZE=100
# Redis on app-net: use the bus compose alias (see services/orion-bus/docker-compose.yml), not container_name.
ORION_BUS_URL=redis://bus-core:6379/0

# --- Service Identity ---
SERVICE_NAME=orion-rdf-writer
SERVICE_VERSION=1.0.0
PORT=8020

# --- Orion Bus Integration ---
ORION_BUS_ENABLED=true
ORION_BUS_ENFORCE_CATALOG=true

# --- Bus Listener Channels ---
# Defines all channels this service will subscribe to.
CHANNEL_RDF_ENQUEUE=orion:rdf:enqueue
CHANNEL_EVENTS_COLLAPSE=orion:collapse:intake
CHANNEL_EVENTS_TAGGED=orion:tags:enriched
CHANNEL_EVENTS_TAGGED_CHAT=orion:tags:chat:enriched
CHANNEL_CORE_EVENTS=orion:core:events
CHANNEL_WORKER_RDF=orion:rdf:worker
CORTEX_LOG_CHANNEL=orion:cortex:telemetry
CHANNEL_COGNITION_TRACE_PUB=orion:cognition:trace
CHANNEL_CHAT_HISTORY_TURN=orion:chat:history:turn
CHANNEL_CHAT_HISTORY_LOG=orion:chat:history:log
CHANNEL_MEMORY_IDENTITY_SNAPSHOT=orion:memory:identity:snapshot
CHANNEL_MEMORY_DRIVES_AUDIT=orion:memory:drives:audit
CHANNEL_MEMORY_GOALS_PROPOSED=orion:memory:goals:proposed
CHANNEL_WORLD_PULSE_GRAPH=orion:world_pulse:graph:upsert

# --- Bus Publish Channels ---
CHANNEL_RDF_CONFIRM=orion:rdf:confirm
CHANNEL_RDF_ERROR=orion:rdf:error

# === RDF Store V1 Cutover ===
# Canonical general RDF write sink: ``orion-rdf-writer`` (this service). Backend-neutral envs:
# RDF_STORE_BACKEND=fuseki
# RDF_STORE_BASE_URL=http://orion-athena-fuseki:3030
# RDF_STORE_DATASET=orion
# RDF_STORE_GRAPH_STORE_URL=http://orion-athena-fuseki:3030/orion/data
# RDF_STORE_QUERY_URL=http://orion-athena-fuseki:3030/orion/query
# RDF_STORE_UPDATE_URL=http://orion-athena-fuseki:3030/orion/update
# RDF_STORE_TIMEOUT_SEC=10.0
# Optional: reduce duplicate chat graph volume during V1 cutover
# RDF_SKIP_KINDS=chat.history.message.v1
# Legacy GraphDB for this service only when RDF_STORE_BACKEND=graphdb (see below).

# --- Global graph mode (active stack: Fuseki / SPARQL) ---
GRAPH_BACKEND=fuseki
GDB_CLIENT_ENABLED=false

# --- GraphDB (legacy explicit only: RDF_STORE_BACKEND=graphdb) ---
# GRAPHDB_URL=http://${PROJECT}-graphdb:7200
GRAPHDB_URL=
GRAPHDB_REPO=collapse
GRAPHDB_USER=
GRAPHDB_PASS=

# --- RDF store (backend-neutral) ---
# graphdb: set RDF_STORE_BACKEND=graphdb and set GRAPHDB_URL + GRAPHDB_REPO above.
# fuseki (Athena default): orion-athena-fuseki on app-net.
# generic/rdf4j: set explicit RDF_STORE_GRAPH_STORE_URL and/or RDF_STORE_UPDATE_URL.
RDF_STORE_BACKEND=fuseki
RDF_STORE_BASE_URL=http://orion-athena-fuseki:3030
RDF_STORE_DATASET=orion
RDF_STORE_QUERY_URL=http://orion-athena-fuseki:3030/orion/query
RDF_STORE_UPDATE_URL=http://orion-athena-fuseki:3030/orion/update
RDF_STORE_GRAPH_STORE_URL=http://orion-athena-fuseki:3030/orion/data
# Local Fuseki dev auth:
# services/orion-rdf-store/.env sets FUSEKI_ADMIN_PASSWORD=orion.
# Therefore local update credentials are admin/orion, not admin/admin.
# Production should override these with real secrets.
RDF_STORE_USER=admin
RDF_STORE_PASS=orion
RDF_STORE_TIMEOUT_SEC=10.0
# When true, GraphDB ?context= uses normalize_graph_name(); default false preserves legacy compact URIs.
RDF_STORE_NORMALIZE_GRAPHDB_CONTEXT=false

# Async writer (decouples bus handlers from store HTTP latency)
RDF_WRITE_ASYNC_ENABLED=true
RDF_WRITE_QUEUE_MAXSIZE=5000
RDF_WRITE_WORKERS=8
RDF_WRITE_MAX_IN_FLIGHT=32
RDF_WRITE_HTTP_MAX_CONNECTIONS=64
RDF_WRITE_HTTP_MAX_KEEPALIVE=32
RDF_WRITE_RETRY_ATTEMPTS=3
RDF_WRITE_RETRY_BASE_DELAY_SEC=0.25
RDF_WRITE_RETRY_MAX_DELAY_SEC=5.0
RDF_WRITE_DEAD_LETTER_ENABLED=true
RDF_WRITE_DEAD_LETTER_PATH=/app/logs/orion-rdf-writer-deadletter.ndjson

# --- RDF store disk layout (Fuseki host paths; operator stack: services/orion-rdf-store) ---
RDF_STORE_DATA_ROOT=/mnt/storage-lukewarm/rdf-store
FUSEKI_DATA_DIR=${RDF_STORE_DATA_ROOT}/fuseki
FUSEKI_BACKUP_DIR=${RDF_STORE_DATA_ROOT}/fuseki-backups
FUSEKI_ADMIN_PASSWORD=orion
FUSEKI_PORT=3030
FUSEKI_JVM_XMS=4g
FUSEKI_JVM_XMX=32g
FUSEKI_JVM_GC_OPTS=-XX:+UseG1GC -XX:MaxGCPauseMillis=200
FUSEKI_EXTRA_JAVA_OPTS=
FUSEKI_JVM_ARGS=-Xms${FUSEKI_JVM_XMS} -Xmx${FUSEKI_JVM_XMX} ${FUSEKI_JVM_GC_OPTS} ${FUSEKI_EXTRA_JAVA_OPTS}

# --- Runtime ---
LOG_LEVEL=INFO
RDF_SKIP_KINDS=chat.history.message.v1
RDF_SKIP_REJECTED=true
RDF_DURABLE_ONLY=false
WORLD_PULSE_GRAPH_ENABLED=false
WORLD_PULSE_GRAPH_DRY_RUN=true
WORLD_PULSE_GRAPH_REQUIRE_POLICY_STAMP=true
RETRY_LIMIT=3
RETRY_INTERVAL=2

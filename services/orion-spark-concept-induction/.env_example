# ──────────────────────────────────────────────────────────────
# ✨ Orion Spark Concept Induction
# ──────────────────────────────────────────────────────────────

SERVICE_NAME=spark-concept-induction
SERVICE_VERSION=0.1.0
NODE_NAME=athena

# Bus
ORION_BUS_URL=${ORION_BUS_URL}
ORION_BUS_ENFORCE_CATALOG=true
ORION_BUS_ENABLED=true
HEARTBEAT_INTERVAL_SEC=10

# Logging (stdlib->loguru bridge level for worker traces e.g. substrate_policy_act)
LOG_LEVEL=INFO

# Channels
BUS_INTAKE_CHANNELS=["orion:chat:history:log","orion:chat:history:turn","orion:chat:social:turn","orion:chat:social:stored","orion:chat:gpt:turn","orion:chat:gpt:message:log","orion:collapse:sql-write","orion:spark:telemetry","orion:metacognition:tick","orion:cognition:trace","orion:substrate:self_state","orion:feedback:frame","orion:world_pulse:run:result"]
BUS_PROFILE_OUT=orion:spark:concepts:profile
BUS_DELTA_OUT=orion:spark:concepts:delta
BUS_VECTOR_OUT=orion:vector:write
BUS_RDF_OUT=orion:rdf:enqueue
BUS_SQL_OUT=orion:collapse:sql-write
BUS_DRIVE_STATE_OUT=orion:memory:drives:state
BUS_TENSION_EVENT_OUT=orion:memory:tension:event
BUS_DRIVE_AUDIT_OUT=orion:memory:drives:audit
BUS_IDENTITY_SNAPSHOT_OUT=orion:memory:identity:snapshot
BUS_GOAL_PROPOSAL_OUT=orion:memory:goals:proposed
BUS_TURN_DOSSIER_OUT=orion:debug:turn:dossier
BUS_ACTION_OUTCOME_OUT=orion:autonomy:action:outcome

# Concept window
CONCEPT_WINDOW_MAX_EVENTS=200
CONCEPT_WINDOW_MAX_MINUTES=360
CONCEPT_TRIGGER_COOLDOWN_SEC=300
CONCEPT_TRIGGER_DEDUPE_SEC=45
CONCEPT_TRIGGER_RECENT_DECISIONS=200
CONCEPT_AUTONOMOUS_TRIGGER_ENABLED=false
CONCEPT_SUBJECTS=orion,juniper,relationship
CONCEPT_PROFILE_PARITY_SUMMARY_INTERVAL=30

# Extraction / Embeddings
SPACY_MODEL=en_core_web_sm
CONCEPT_MAX_CANDIDATES=50
EMBEDDINGS_BASE_URL=http://orion-athena-vector-host:8320
EMBEDDINGS_TIMEOUT_SEC=5
CONCEPT_CLUSTER_THRESHOLD=0.8

# Cortex-Orch override
USE_CORTEX_ORCH=false
CORTEX_ORCH_VERB=concept_induction
CORTEX_ORCH_REQUEST_CHANNEL=orion:cortex:request
CORTEX_ORCH_RESULT_PREFIX=orion:cortex:result
CORTEX_TIMEOUT_SEC=12

# Persistence
CONCEPT_STORE_PATH=/data/concept-induction-state.json
DRIVE_DECAY_TAU_SEC=1800
DRIVE_SATURATION_GAIN=1.8
DRIVE_ACTIVATION_ON=0.62
DRIVE_ACTIVATION_OFF=0.42
# Homeostatic drives (spec 2026-07-07). Leaky math replaces the soft-saturate
# ~0.731 fixed-point pin; deviation-gated tensions come from the signal/failure/
# health bus. Both default true (Juniper-authorized). Roll back either
# independently: LEAKY_MATH=false keeps legacy pressure math; HOMEOSTATIC=false
# stops minting signal tensions.
ORION_HOMEOSTATIC_DRIVES_ENABLED=true
ORION_DRIVE_LEAKY_MATH_ENABLED=true
DEVIATION_EWMA_ALPHA=0.1
DEVIATION_Z_THRESHOLD=1.5
DEVIATION_SIGMA_FLOOR=0.02
SIGNAL_TENSION_IMPULSE_K=0.25
SIGNAL_TENSION_CAP_PER_WINDOW=3
SIGNAL_TENSION_WINDOW_SEC=60
# Homeostatic consumer subscription: SPECIFIC organ/failure channels only (never
# the orion:signals:* wildcard, so the scene_state flood is excluded). These route
# to a drive-only tick (no concept induction). Override with JSON arrays if needed;
# defaults apply when unset:
#   HOMEOSTATIC_SIGNAL_CHANNELS=["orion:signals:biometrics","orion:signals:spark","orion:signals:equilibrium"]
#   HOMEOSTATIC_FAILURE_CHANNELS=["orion:system:error","orion:rdf:error","orion:vision:edge:error"]
HOMEOSTATIC_FAILURE_SEVERITY=0.8
# Endogenous drive origination (spec 2026-07-07 Step 1) — DEFAULT-OFF proposal
# mode. Changes what causes Orion to *want* things; enable only after measurement
# 0(a) passes + review. Cooldown is coupled to the activate threshold via tau:
# keep well under ~22 min or endogenous drives never activate (see spec).
ORION_ENDOGENOUS_ORIGINATION_ENABLED=false
ORIGINATION_WINDOW=8
ORIGINATION_THRESHOLD=0.55
ORIGINATION_COOLDOWN_SEC=900
ENDOGENOUS_MAG_CAP=0.5
ORIGINATION_W_DRIFT=0.4
ORIGINATION_W_DWELL=0.35
ORIGINATION_W_AGENCY=0.25
ORIGINATION_EXOGENOUS_FLOOR=0
GOAL_PROPOSAL_COOLDOWN_MINUTES=180
GOAL_GENERATION_MODE=evidence_rules
# tick_attribution | pressures (legacy) | audit_dominant (deprecated alias)
GOAL_DRIVE_ORIGIN_SOURCE=tick_attribution

# Concept profile repository backend (Phase 2)
CONCEPT_PROFILE_REPOSITORY_BACKEND=local
CONCEPT_PROFILE_BACKEND_CONCEPT_INDUCTION_PASS=
CONCEPT_PROFILE_GRAPH_CUTOVER_FALLBACK_POLICY=fail_open_local
CONCEPT_PROFILE_GRAPHDB_ENDPOINT=
CONCEPT_PROFILE_GRAPHDB_URL=
CONCEPT_PROFILE_GRAPHDB_REPO=collapse
CONCEPT_PROFILE_GRAPHDB_USER=
CONCEPT_PROFILE_GRAPHDB_PASS=
CONCEPT_PROFILE_GRAPH_TIMEOUT_SEC=6
CONCEPT_PROFILE_GRAPH_URI=http://conjourney.net/graph/spark/concept-profile
CONCEPT_PROFILE_PARITY_MIN_COMPARISONS=50
CONCEPT_PROFILE_PARITY_MAX_MISMATCH_RATE=0.05
CONCEPT_PROFILE_PARITY_MAX_UNAVAILABLE_RATE=0.02
CONCEPT_PROFILE_PARITY_CRITICAL_MISMATCH_CLASSES=profile_missing_on_graph,profile_missing_on_local,query_error
CONCEPT_PROFILE_PARITY_SUMMARY_INTERVAL=25

# Substrate-fed motivation (v1 — enabled for golden-path activation)
ORION_SUBSTRATE_AUTONOMY_METABOLISM_ENABLED=true
ORION_METABOLISM_MIN_PREDICTIVE_PRESSURE=0.55
ORION_METABOLISM_MIN_CURIOSITY_STRENGTH=0.5
ORION_CAPABILITY_POLICY_AUTO_READONLY_ENABLED=true
ORION_EPISODE_FETCH_BACKEND=auto
# Host path for local pytest/smoke; docker-compose overrides to /root/.fcc/.env with ~/.fcc mount
ORION_FCC_ENV_PATH=~/.fcc/.env
# Optional direct key; otherwise resolved from ORION_FCC_ENV_PATH
FIRECRAWL_API_KEY=
# Retired: the standalone autonomy-episode journal produced a SECOND daily email
# (Source: autonomy_episode) that duplicated the world-pulse "daily news pulse".
# The gap-fill / "Orion went looking" narrative is now folded into the single
# world-pulse journal seed (orion/journaler/worker.py:build_world_pulse_prompt_seed),
# so one world-pulse run = one grounded journal = one email. The substrate ACT
# (Firecrawl gap-fill fetch) still runs; only the duplicate journal compose is off.
# Flip back to true to re-enable the separate episode journal + its email.
ORION_AUTONOMY_EPISODE_JOURNAL_ENABLED=false
# Journal compose LLM RPC budget (~16s observed); keep well above CORTEX_TIMEOUT_SEC.
ORION_AUTONOMY_EPISODE_JOURNAL_TIMEOUT_SEC=120
# Durable world-pulse run-result consumption (Redis Stream + consumer group). When
# enabled, orion:world_pulse:run:result is consumed from the durable stream instead of
# pub/sub so a busy/restarting worker never loses the rare episode trigger. Requires
# WP_RUN_RESULT_STREAM_ENABLED=true on orion-world-pulse too (producer dual-write).
# ROLLOUT ORDER: enable THIS consumer first (creates the consumer group at start_id="$"),
# then enable the producer flag on orion-world-pulse. Runs published before the group
# exists are not replayed to the group.
WP_RUN_RESULT_STREAM_ENABLED=true
WP_RUN_RESULT_STREAM_KEY=orion:stream:world_pulse:run:result
WP_RUN_RESULT_STREAM_GROUP=cg:concept-induction
WP_RUN_RESULT_DLQ_KEY=orion:stream:world_pulse:run:result:dlq
WP_RUN_RESULT_BLOCK_MS=5000
WP_RUN_RESULT_MAX_ATTEMPTS=5
WP_RUN_RESULT_AUTOCLAIM_IDLE_MS=120000
JOURNAL_WRITE_CHANNEL=orion:journal:write
JOURNAL_SESSION_ID=orion
JOURNAL_USER_ID=juniper
JOURNAL_AUTHOR=orion

# Autonomy goal graph hygiene (orion.autonomy.goal_archive; nightly via orion-actions when enabled there)
# false while autonomy graph reads disabled (post-publish trim hits Fuseki).
AUTONOMY_GOAL_ARCHIVE_ENABLED=false
AUTONOMY_GOAL_ARCHIVE_MAX_UPDATES_PER_TICK=25
AUTONOMY_GOAL_ARCHIVE_SUBJECTS=orion,relationship
AUTONOMY_GOAL_RETENTION_DAYS=30
AUTONOMY_GOAL_MAX_ACTIVE_PER_SUBJECT=3
# Required if AUTONOMY_GOAL_ARCHIVE_ENABLED=true (post-publish trim)
AUTONOMY_GRAPH_QUERY_URL=http://orion-athena-fuseki:3030/orion/query
AUTONOMY_GRAPH_UPDATE_URL=http://orion-athena-fuseki:3030/orion/update
AUTONOMY_GRAPH_TIMEOUT_SEC=30
RDF_STORE_USER=admin
RDF_STORE_PASS=orion

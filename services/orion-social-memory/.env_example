APP_NAME=orion-social-memory
SERVICE_NAME=orion-social-memory
SERVICE_VERSION=0.1.0
NODE_NAME=athena
PORT=8765
LOG_LEVEL=INFO

ORION_BUS_URL=redis://orion-redis:6379/0
ORION_BUS_ENABLED=true
ORION_BUS_ENFORCE_CATALOG=false

DATABASE_URL=postgresql://postgres:postgres@orion-athena-sql-db:5432/conjourney

SOCIAL_MEMORY_INPUT_CHANNEL=orion:chat:social:stored
SOCIAL_MEMORY_PARTICIPANT_CHANNEL=orion:social:participant:continuity
SOCIAL_MEMORY_ROOM_CHANNEL=orion:social:room:continuity
SOCIAL_MEMORY_STANCE_CHANNEL=orion:social:stance:snapshot
SOCIAL_MEMORY_UPDATE_CHANNEL=orion:social:relational:update
SOCIAL_MEMORY_OPEN_THREAD_CHANNEL=orion:social:open-thread
SOCIAL_MEMORY_PEER_STYLE_CHANNEL=orion:social:peer-style
SOCIAL_MEMORY_ROOM_RITUAL_CHANNEL=orion:social:room-ritual
SOCIAL_MEMORY_COMMITMENT_CHANNEL=orion:social:commitment
SOCIAL_MEMORY_COMMITMENT_RESOLUTION_CHANNEL=orion:social:commitment:resolution
SOCIAL_MEMORY_CLAIM_CHANNEL=orion:social:claim
SOCIAL_MEMORY_CLAIM_REVISION_CHANNEL=orion:social:claim:revision
SOCIAL_MEMORY_CLAIM_STANCE_CHANNEL=orion:social:claim:stance
SOCIAL_MEMORY_CLAIM_ATTRIBUTION_CHANNEL=orion:social:claim:attribution
SOCIAL_MEMORY_CLAIM_CONSENSUS_CHANNEL=orion:social:claim:consensus
SOCIAL_MEMORY_CLAIM_DIVERGENCE_CHANNEL=orion:social:claim:divergence
SOCIAL_MEMORY_BRIDGE_SUMMARY_CHANNEL=orion:social:bridge-summary
SOCIAL_MEMORY_CLARIFYING_QUESTION_CHANNEL=orion:social:clarifying-question
SOCIAL_MEMORY_DELIBERATION_DECISION_CHANNEL=orion:social:deliberation:decision
SOCIAL_MEMORY_TURN_HANDOFF_CHANNEL=orion:social:turn-handoff
SOCIAL_MEMORY_CLOSURE_SIGNAL_CHANNEL=orion:social:closure-signal
SOCIAL_MEMORY_FLOOR_DECISION_CHANNEL=orion:social:floor:decision
SOCIAL_MEMORY_EVIDENCE_MAX=5
SOCIAL_MEMORY_TOPIC_MAX=6
SOCIAL_MEMORY_ROOM_PARTICIPANT_MAX=8
SOCIAL_MEMORY_OPEN_THREAD_TTL_HOURS=6
SOCIAL_MEMORY_COMMITMENT_TTL_MINUTES=90
SOCIAL_MEMORY_COMMITMENT_MAX_OPEN=3
SOCIAL_MEMORY_STYLE_ADAPTATION_ENABLED=true
SOCIAL_MEMORY_STYLE_CONFIDENCE_FLOOR=0.35

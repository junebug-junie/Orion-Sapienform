# ───────────────────────────────────────────────
# 🧠 Orion Whisper, TTS
# ───────────────────────────────────────────────

SERVICE_NAME=whisper-tts
SERVICE_VERSION=0.1.0

# Bus (usually already defined at project root, but safe to override here)
ORION_BUS_ENABLED=true
ORION_BUS_ENFORCE_CATALOG=true
ORION_BUS_URL=redis://100.92.216.81:6379/0

# TTS intake (Hub → TTS)
CHANNEL_TTS_INTAKE=orion:tts:intake

# TTS backend (coqui today; fish_speech_http / f5_tts_http later)
TTS_BACKEND=coqui
TTS_MODEL_NAME=tts_models/multilingual/multi-dataset/xtts_v2
TTS_USE_GPU=true
TTS_DEFAULT_LANGUAGE=en
# Mode 1 — built-in XTTS speaker (e.g. Ana Florence; list inside container — see README)
TTS_DEFAULT_SPEAKER=
# Mode 2 — reference voice cloning (.wav under TTS_VOICE_PROFILE_DIR; file must exist)
# TTS_DEFAULT_SPEAKER_WAV=/models/voices/orion_reference.wav
TTS_DEFAULT_SPEAKER_WAV=
TTS_SPLIT_SENTENCES=true
TTS_VOICE_PROFILE_DIR=/models/voices
# Host path mounted read-only to TTS_VOICE_PROFILE_DIR in the container
TTS_VOICE_PROFILE_HOST_DIR=/mnt/telemetry/models/coqui/voices

# Required for XTTS unless every request supplies voice_id / options.speaker_wav
TTS_DEFAULT_SPEAKER=Ana Florence

# GPU avail from nvidia-smi
GPU_INDEX=2

# Timeouts (seconds)
CONNECT_TIMEOUT_SEC=10
READ_TIMEOUT_SEC=60
WHISPER_TTS_STT_TIMEOUT_SEC=90
WHISPER_TTS_SYNTH_TIMEOUT_SEC=120

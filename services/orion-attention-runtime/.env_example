PROJECT=orion-athena
SERVICE_NAME=orion-attention-runtime
SERVICE_VERSION=0.1.0
POSTGRES_URI=postgresql://postgres:postgres@orion-athena-sql-db:5432/conjourney
ATTENTION_POLICY_PATH=/app/config/attention/field_attention_policy.v1.yaml
ATTENTION_POLL_INTERVAL_SEC=2.0
ENABLE_ATTENTION_RUNTIME=true
# Transport M5: expose capability:transport in attention frames (default off)
ENABLE_TRANSPORT_ATTENTION_VISIBILITY=true
ATTENTION_RUNTIME_PORT=8117
LOG_LEVEL=INFO
# Bounded retention for substrate_attention_frames (~43k rows/day once the
# field-digester idle tick is on). Newest row is always kept. 0 disables.
ATTENTION_FRAME_RETENTION_HOURS=72.0
ATTENTION_FRAME_PRUNE_INTERVAL_SEC=3600.0

# Health monitor: an edge-triggered check (attention_frame prune stall) that
# raises an orion-notify attention request only on a healthy->unhealthy
# transition -- never spams once per health-check tick.
ATTENTION_RUNTIME_HEALTH_CHECK_INTERVAL_SEC=900.0
ATTENTION_FRAME_STALL_MULTIPLIER=1.5
NOTIFY_BASE_URL=http://orion-athena-notify:7140
NOTIFY_API_TOKEN=

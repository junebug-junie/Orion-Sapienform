SERVICE_NAME=orion-heartbeat
SERVICE_VERSION=0.1.0
NODE_NAME=
INSTANCE_ID=

ORION_BUS_URL=redis://100.92.216.81:6379/0
ORION_BUS_ENABLED=true
ORION_HEALTH_CHANNEL=orion:system:health
HEARTBEAT_INTERVAL_SEC=10.0

# Existing, already-registered channel (orion/bus/channels.yaml) -- v0 is a
# second, additive, read-only consumer. No new channel is registered by this
# service.
CHANNEL_GRAMMAR_EVENT=orion:grammar:event

# How often the H1 (boundary/bulk entanglement) result is recomputed from the
# live substrate. Computation itself is cheap (~6ms); this just controls how
# fresh the debug HTTP surface's /h1 response is.
HEARTBEAT_H1_INTERVAL_SEC=30.0

# Fixed seed for the substrate's initial random MPS state. v0 has no
# crash-safe snapshot/restore (see docs/superpowers/specs/2026-07-24-spark-
# field-holographic-lattice-design.md's "Explicit deferrals") -- a restart
# reinitializes from this same seed rather than resuming prior state.
HEARTBEAT_SUBSTRATE_SEED=42

HEARTBEAT_HTTP_PORT=7251

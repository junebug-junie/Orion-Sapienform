PROJECT=orion-athena
SERVICE_NAME=orion-substrate-runtime
SERVICE_VERSION=0.1.0
NODE_NAME=athena

# Athena stack: conjourney DB on orion-athena-sql-db (not the legacy orion@postgres DSN).
POSTGRES_URI=postgresql://postgres:postgres@orion-athena-sql-db:5432/conjourney
ORION_BUS_URL=redis://100.92.216.81:6379/0
ORION_BUS_ENABLED=true

ENABLE_BIOMETRICS_NODE_REDUCER=true
ENABLE_BIOMETRICS_PRESSURE_ORGAN=true
ENABLE_NODE_PRESSURE_REDUCER=true
BIOMETRICS_NODE_STALE_AFTER_SEC=180
BIOMETRICS_PRESSURE_MIN_CONFIDENCE=0.60
NODE_CATALOG_PATH=/app/config/biometrics/node_catalog.yaml
GRAMMAR_POLL_INTERVAL_SEC=1.0
# Per-reducer batch limits. Biometrics matches transport for catch-up on high-RAM hosts.
BIOMETRICS_GRAMMAR_BATCH_LIMIT=500
EXECUTION_GRAMMAR_BATCH_LIMIT=500
TRANSPORT_GRAMMAR_BATCH_LIMIT=1000
REDUCER_HEARTBEAT_STALE_SEC=120
REDUCER_POISON_MAX_RETRIES=3
GRAMMAR_EVENT_CHANNEL=orion:grammar:event
# Unified turn 5a: substrate finalize appraisal RPC (HarnessDraftMoleculeV1 -> SubstrateFinalizeAppraisalV1)
CHANNEL_FINALIZE_APPRAISAL_REQUEST=orion:substrate:finalize_appraisal:request
CHANNEL_FINALIZE_APPRAISAL_RESULT_PREFIX=orion:substrate:finalize_appraisal:result:
# Unified turn step 7: harness post-turn closure consumer (HarnessPostTurnClosureV1)
CHANNEL_POST_TURN_CLOSURE=orion:substrate:post_turn_closure
ENABLE_POST_TURN_CLOSURE_LISTENER=true
# Voluntary attention (ORION_ATTENTION_TOPDOWN_ENABLED) goal-context feed: always-on
# consumer that populates the in-memory active-goal store from GoalProposalV1 events.
CHANNEL_GOAL_PROPOSAL=orion:memory:goals:proposed
# Accepted pressure candidates publish to a separate channel (not orion:grammar:event).
PUBLISH_ACCEPTED_PRESSURE_GRAMMAR=true
ACCEPTED_PRESSURE_GRAMMAR_CHANNEL=orion:grammar:accepted-pressure
# Default false: do not silently skip history after long outage. Cold-start tail-seed still logs substrate_data_gap.
SUBSTRATE_CURSOR_TAIL_SEED_ON_LAG=false
SUBSTRATE_CURSOR_LAG_RESYNC_HOURS=6
# Required for POST /grammar/cursor/reset and POST /grammar/quarantine/ack (internal operator endpoints; not exposed via hub/Caddy).
SUBSTRATE_CURSOR_RESET_OPERATOR_TOKEN=
ENABLE_EXECUTION_TRAJECTORY_REDUCER=true
# active_execution_trajectory.runs caps (LRU by last_updated_at). Only the freshest
# ~120s of runs are ever consumed downstream (orion-spark-introspector).
EXECUTION_TRAJECTORY_MAX_RUNS=2000
EXECUTION_TRAJECTORY_MAX_AGE_SEC=86400
# Transport M3: set true to enable bus reducer and projection (default off)
ENABLE_TRANSPORT_BUS_REDUCER=true
BUS_STREAM_DEPTH_CRITICAL=100000
# trace_only | m3 | m4 | m5 | full
TRANSPORT_SUBSTRATE_MATURITY=full_observe
# --- Rung 1 bridge: write execution/transport prediction_error onto a durable ---
# substrate node so the dynamics engine can seed pressure from it. Default-off in
# code, fail-open. For cross-process effect the write must target the shared
# semantic store (SUBSTRATE_STORE_BACKEND=sparql + Fuseki URLs below); with the
# in-memory default the node is process-local. The periodic dynamics-engine tick
# that consumes these nodes is SUBSTRATE_DYNAMICS_TICK_ENABLED below.
# Default-off in code; enabled here so rung-1 write + dynamics tick can run on Athena.
SUBSTRATE_WRITE_PREDICTION_ERROR_NODES=true
# Rung-1 consumer (closes PR #766 gap): periodic SubstrateDynamicsEngine.tick()
# against the shared substrate graph store, seeding pressure from
# metadata['prediction_error'] written by SUBSTRATE_WRITE_PREDICTION_ERROR_NODES.
# Default off in code; enabled here to close the rung-1 consumer gap on Athena.
SUBSTRATE_DYNAMICS_TICK_ENABLED=true
SUBSTRATE_DYNAMICS_TICK_INTERVAL_SEC=30.0
# Rung 4: roll each completed clock-aligned receipt window into one
# proposal-marked EpisodeSummaryV1 (substrate_episode_summaries table; apply
# manual_migration_substrate_episodes_v1.sql first). Window + tick interval
# must stay under receipt retention or completed windows are pruned unseen.
SUBSTRATE_EPISODIC_TICK_ENABLED=true
SUBSTRATE_EPISODIC_TICK_INTERVAL_SEC=300.0
SUBSTRATE_EPISODIC_WINDOW_SECONDS=900
SUBSTRATE_EPISODIC_MAX_RECEIPTS=64
SUBSTRATE_EPISODIC_RETENTION_DAYS=14.0
# Rung 3: continuous workspace competition over the substrate graph; winning
# coalition persisted to substrate_attention_broadcast_projection (apply
# manual_migration_attention_broadcast_v1.sql first). Needs the shared sparql
# store (same requirement as the dynamics tick). Never generates questions or
# actions — read-only broadcast.
ORION_ATTENTION_BROADCAST_ENABLED=true
ORION_ATTENTION_BROADCAST_INTERVAL_SEC=30.0
ORION_ATTENTION_BROADCAST_MIN_SALIENCE=0.2
# Operator sign-off granted: lets intrinsic signals seed curiosity candidates.
ORION_ENDOGENOUS_CURIOSITY_ENABLED=true
ORION_ENDOGENOUS_CURIOSITY_KILL_SWITCH=false
ORION_ENDOGENOUS_CURIOSITY_BUDGET=3
# Default 0.6 in code if unset. Athena: 0.25 seeds from moderate chat repair pressure (~0.28 in projection).
ORION_ENDOGENOUS_CURIOSITY_MIN_REPAIR_LEVEL=0.25
ORION_ENDOGENOUS_CURIOSITY_TICK_INTERVAL_SEC=60.0
SUBSTRATE_STORE_BACKEND=sparql
SUBSTRATE_GRAPH_QUERY_URL=http://orion-athena-fuseki:3030/orion/query
SUBSTRATE_GRAPH_UPDATE_URL=http://orion-athena-fuseki:3030/orion/update
SUBSTRATE_GRAPH_URI=http://conjourney.net/graph/substrate
SUBSTRATE_GRAPH_USER=admin
SUBSTRATE_GRAPH_PASS=orion
# Chat grammar reducer (set true after PUBLISH_HUB_CHAT_GRAMMAR=true is set on hub)
ENABLE_CHAT_GRAMMAR_REDUCER=true
CHAT_GRAMMAR_BATCH_LIMIT=100
LOG_LEVEL=INFO

# Substrate receipt retention + prune (30-minute success TTL; 5-minute prune loop)
ORION_RECEIPT_RETENTION_SUCCESS_MINUTES=30
ORION_RECEIPT_RETENTION_ERROR_HOURS=6
ORION_RECEIPT_FULL_PAYLOAD_SUCCESS=false
ORION_RECEIPT_FULL_PAYLOAD_SAMPLE_RATE=0
ORION_RECEIPT_MAX_TABLE_GB=25
ORION_RECEIPT_WARN_TABLE_GB=15
ORION_RECEIPT_CRITICAL_TABLE_GB=20
ORION_RECEIPT_EMERGENCY_METADATA_ONLY=true
ORION_RECEIPT_PRUNE_INTERVAL_SEC=300
ORION_RECEIPT_PRUNE_BATCH_SIZE=10000
ORION_RECEIPT_POSTGRES_DATA_PATH=/mnt/postgres
ORION_RECEIPT_DISK_CRITICAL_PCT=85

# Orion embodiment (mind-to-sprite) hooks — default off / empty-safe.
# EMBODIMENT_C_TICK_ENABLED: cache DriveStateV1 and publish one involuntary
# embodiment intent per dynamics tick. EMBODIMENT_PERCEPTION_SUBSTRATE_ENABLED:
# fold town perception into the substrate graph.
EMBODIMENT_C_TICK_ENABLED=false
EMBODIMENT_PERCEPTION_SUBSTRATE_ENABLED=false
EMBODIMENT_CHANNEL_INTENT=orion:embodiment:intent
EMBODIMENT_CHANNEL_PERCEPTION=orion:embodiment:perception
EMBODIMENT_DRIVES_STATE_CHANNEL=orion:memory:drives:state
# --- Computed salience v2 (shadow-first, default-off) ---
ORION_ATTENTION_SALIENCE_V2_ENABLED=true
ORION_ATTENTION_HABITUATION_ENABLED=true
# Optional JSON override for combiner weights; empty = hand-seeded seed-v1.
ORION_ATTENTION_SALIENCE_WEIGHTS=
# Voluntary attention override (spec 2026-07-07 Step 2) — DEFAULT-OFF proposal
# mode. Lets an active goal bias attention against bottom-up salience under a
# bounded effort budget (biased competition). Enable only after review; off =
# pure bottom-up, byte-identical to today.
ORION_ATTENTION_TOPDOWN_ENABLED=false
ATTENTION_TOPDOWN_GAIN=0.6
ATTENTION_EFFORT_MAX=1.0
ATTENTION_EFFORT_SCALE_BY_AGENCY=true
ATTENTION_TOPDOWN_WEIGHTS_VERSION=seed-v1

# --- Self-tab brain-EKG frame producer ---
SUBSTRATE_BRAIN_FRAME_ENABLED=true
BRAIN_FRAME_INTERVAL_SEC=5.0
BRAIN_FRAME_RETENTION_HOURS=24
BRAIN_FRAME_SAMPLE_NODES=40
BRAIN_FRAME_SAMPLE_EDGES=60
BRAIN_FRAME_FIRING_THRESHOLD=0.5
BRAIN_FRAME_STARVING_THRESHOLD=0.1
BRAIN_FRAME_SELF_STATE_CADENCE_SEC=30.0
BRAIN_FRAME_SPOTLIGHT_CADENCE_SEC=30.0
# Dependent signal producers the brain frame reads are enabled above so regions
# show real motion: SUBSTRATE_DYNAMICS_TICK_ENABLED, ORION_ATTENTION_BROADCAST_ENABLED,
# ENABLE_EXECUTION_TRAJECTORY_REDUCER, ENABLE_TRANSPORT_BUS_REDUCER, ENABLE_CHAT_GRAMMAR_REDUCER.

diff --git a/src/lib/hubEmbed.ts b/src/lib/hubEmbed.ts
new file mode 100644
index 0000000..8ee34b2
--- /dev/null
+++ b/src/lib/hubEmbed.ts
@@ -0,0 +1,6 @@
+/** True when AI Town runs inside Orion Hub (or ?hub_embed=1). */
+export function isHubEmbed(): boolean {
+  if (typeof window === 'undefined') return false;
+  if (window.self !== window.top) return true;
+  return new URLSearchParams(window.location.search).has('hub_embed');
+}

# ───────────────────────────────────────────────────────────────
# Orion FalkorDB — shared property-graph operator stack
# ───────────────────────────────────────────────────────────────

NODE_NAME=athena
NET=app-net

# === FalkorDB service ===
FALKORDB_IMAGE=falkordb/falkordb:latest
FALKORDB_PORT=6380
FALKORDB_DATA_DIR=/mnt/graphdb/falkordb

# === Client URI (container DNS on app-net) ===
# Stable hostname: orion-${NODE_NAME}-falkordb (Redis protocol, port 6379 inside the mesh).
FALKORDB_URI=redis://orion-athena-falkordb:6379

# === Graph names (logical partitions inside one FalkorDB instance) ===
# One container, separate graph names — do not share labels/properties across rails.
#
# orion_graphiti — temporal crystallization projection (graphiti-adapter / graphiti_core).
#   Today graphiti-adapter defaults FALKORDB_GRAPH=graphiti_temporal; planned canonical name
#   is orion_graphiti (see docs/superpowers/specs/2026-07-16-falkordb-property-graph-routing-design.md).
#
# orion_substrate — substrate property-graph rail (FalkorSubstrateStore / routed store).
#   Set FALKORDB_SUBSTRATE_GRAPH=orion_substrate on orion-substrate-runtime when enabled.
#
# FALKORDB_GRAPHITI_GRAPH=orion_graphiti
# FALKORDB_SUBSTRATE_GRAPH=orion_substrate

# ────────────────────────────────────────────────
# 🌐 Orion Mesh Global Environment
# Automatically sourced by all services
# ────────────────────────────────────────────────


# Default Redis connection (may be overridden per node or managed)
REDIS_URL=redis://100.92.216.81:6379/0
REDIS_PORT=6379
REDIS_EXPORTER_PORT=9121
REDIS_DATA_VOL=${PROJECT}_redis_data

# Cold-standby bus-core (docker-compose.atlas-standby.yml only). Not read by
# the primary docker-compose.yml. Deployed on a separate mesh node (atlas by
# default -- see docs/notes/2026-07-16-bus-core-standby-cutover-runbook.md).
# Passive: no client points ORION_BUS_URL here automatically. Defaults to a
# different port than REDIS_PORT (6379) so it's safe to co-locate with the
# primary on one host for testing without a port collision; override back to
# 6379 on the real standby node if you want cutover to be a pure IP swap.
# NOT 6380: services/orion-graphiti-adapter/docker-compose.yml already
# hardcodes host port 6380 for its own falkordb container -- co-locating the
# standby with anything running that service on the same host would collide.
# Confirmed free across every services/*/docker-compose*.yml as of 2026-07-16.
BUS_STANDBY_PORT=6381

# Substrate transport traces (bounded rollups; default off)
PUBLISH_ORION_BUS_GRAMMAR=true
GRAMMAR_EVENT_CHANNEL=orion:grammar:event
BUS_OBSERVER_ENABLED=true
BUS_OBSERVER_POLL_INTERVAL_SEC=10
# orion:evt:gateway/orion:bus:out are depth/backpressure-monitoring targets
# only. Verified live against bus-core Redis (TYPE + XLEN): both are TYPE=none
# (no key at all) and are not cataloged in channels.yaml either, so
# schema-mismatch sampling never fires for them.
# orion:grammar:event IS cataloged (schema_id=GrammarEventV1) but does NOT
# fix schema-mismatch sampling being dead: verified live it is TYPE=none too
# -- delivered purely via Redis PUBLISH (never XADD'd anywhere in this repo),
# so XLEN/XREVRANGE can never see it no matter how much real traffic it
# carries. Kept in the default anyway (harmless, correctly cataloged) but it
# is not what makes the feature live.
# orion:stream:world_pulse:run:result is what actually does: cataloged
# (schema_id=WorldPulseRunResultV1, kind=stream), written via real XADD by
# orion-world-pulse (WP_RUN_RESULT_STREAM_ENABLED=true by default -- see
# services/orion-world-pulse/.env_example). Verified live: TYPE=stream,
# XLEN=82 real entries at verification time. Low/bursty volume ("once per
# run") -- a sampled_count of 0 between runs is expected, not a bug.
BUS_OBSERVER_STREAMS=orion:evt:gateway,orion:bus:out,orion:grammar:event,orion:stream:world_pulse:run:result
BUS_STREAM_DEPTH_WARNING=25000
BUS_STREAM_DEPTH_CRITICAL=100000
BUS_OBSERVER_NODE_ID=athena
BUS_CHANNELS_CATALOG_PATH=orion/bus/channels.yaml
# Per-stream XREVRANGE sample size for the schema-mismatch check (contract_pressure).
# Only applied to configured streams that ARE in the channel catalog (uncataloged
# streams are already covered by catalog_drift_pressure). Keep small: cost scales as
# len(BUS_OBSERVER_STREAMS) * this value extra Redis reads per poll tick.
BUS_OBSERVER_SCHEMA_SAMPLE_COUNT=5

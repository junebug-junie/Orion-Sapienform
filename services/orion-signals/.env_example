# Orion Signals mesh launcher — operator contract (sync to local .env; never commit .env)

# MUST be redis://<tailscale-node-ip>:6379/0 for mesh bus (not bus-core hostname on host)
ORION_BUS_URL=

PROJECT=orion-athena
NODE_NAME=athena

# Default launch tier: core | tier1 | tier2 | routing | full
SIGNALS_TIER=core

SIGNAL_GATEWAY_HTTP_PORT=8879

# When false (default), up.sh starts signal-gateway without bundled orion-redis — use orion-bus bus-core.
# Set true only when running signal-gateway standalone without bus-core.
SIGNALS_USE_BUNDLED_REDIS=false

# Hub (orion-hub) is external — host network, not started by this stack.
# Start Hub separately for Organ Signals UI and operator surfaces.

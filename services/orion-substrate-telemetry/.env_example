# ──────────────────────────────────────────────────────────────
# Orion Substrate Telemetry
# ──────────────────────────────────────────────────────────────

# Compose naming / network
PROJECT=orion-athena
NET=app-net

# Service identity
SERVICE_NAME=substrate-telemetry
SERVICE_VERSION=0.1.0
NODE_NAME=athena

# Port mapping (compose maps SUBSTRATE_TELEMETRY_PORT -> PORT)
SUBSTRATE_TELEMETRY_PORT=8395

# Orion bus
ORION_BUS_ENABLED=true
ORION_BUS_ENFORCE_CATALOG=false
ORION_BUS_URL=redis://100.92.216.81:6379/0

# Tier outcomes channel
CHANNEL_SUBSTRATE_TIER_OUTCOMES=orion:substrate:tier_outcomes

# Postgres
POSTGRES_URI=postgresql://postgres:postgres@orion-athena-sql-db:5432/conjourney

# Telemetry table (fixed in v1 DDL; reserved for future overrides)
SUBSTRATE_TELEMETRY_TABLE=substrate_tier_outcomes_events

# Retention: per-correlation row cap after each insert; global age purge interval and day cap
SUBSTRATE_TELEMETRY_PER_CORR_CAP=100
SUBSTRATE_TELEMETRY_RETENTION_DAYS=7
SUBSTRATE_TELEMETRY_RETENTION_SCAN_SEC=3600

# Optional bearer for HTTP read API (sent as X-Telemetry-Token)
SUBSTRATE_TELEMETRY_READ_API_TOKEN=

# Chassis / runtime
HEARTBEAT_INTERVAL_SEC=10

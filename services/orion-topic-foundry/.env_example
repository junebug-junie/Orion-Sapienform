SERVICE_NAME=orion-topic-foundry
SERVICE_VERSION=0.1.0
NODE_NAME=athena
LOG_LEVEL=INFO
PORT=8615

TOPIC_FOUNDRY_PG_DSN=postgresql://postgres:postgres@orion-athena-sql-db:5432/conjourney
TOPIC_FOUNDRY_EMBEDDING_URL=http://orion-athena-vector-host:8320/embedding
TOPIC_FOUNDRY_TOPIC_ENGINE=bertopic
TOPIC_FOUNDRY_EMBEDDING_BACKEND=vector_host
TOPIC_FOUNDRY_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
TOPIC_FOUNDRY_VECTOR_HOST_URL=http://orion-athena-vector-host:8320/embedding
TOPIC_FOUNDRY_EMBEDDING_BATCH_SIZE=32
TOPIC_FOUNDRY_EMBEDDING_MAX_RETRIES=2
TOPIC_FOUNDRY_EMBEDDING_RETRY_DELAY_SECS=0.75
TOPIC_FOUNDRY_REDUCER=umap
TOPIC_FOUNDRY_CLUSTERER=hdbscan
TOPIC_FOUNDRY_REPRESENTATION=ctfidf
TOPIC_FOUNDRY_RANDOM_STATE=42
TOPIC_FOUNDRY_UMAP_N_NEIGHBORS=15
TOPIC_FOUNDRY_UMAP_N_COMPONENTS=5
TOPIC_FOUNDRY_UMAP_MIN_DIST=0.0
TOPIC_FOUNDRY_UMAP_METRIC=cosine
# Live 2026-07-21: 15/eom (both HDBSCAN's own library defaults) produced 2
# clusters on a real 676-doc corpus, one holding 77% of all documents.
# 8/leaf produced 29 genuinely distinct clusters on the same data -- now
# wired as real fallbacks in training.py::_build_clusterer (previously
# only consumed by dead code in topic_engine.py).
TOPIC_FOUNDRY_HDBSCAN_MIN_CLUSTER_SIZE=8
TOPIC_FOUNDRY_HDBSCAN_MIN_SAMPLES=3
TOPIC_FOUNDRY_HDBSCAN_METRIC=euclidean
TOPIC_FOUNDRY_HDBSCAN_CLUSTER_SELECTION_METHOD=leaf
TOPIC_FOUNDRY_VECTORIZER_NGRAM_MIN=1
TOPIC_FOUNDRY_VECTORIZER_NGRAM_MAX=1
TOPIC_FOUNDRY_VECTORIZER_MIN_DF=1
TOPIC_FOUNDRY_VECTORIZER_MAX_DF=0.95
TOPIC_FOUNDRY_VECTORIZER_MAX_FEATURES=5000
TOPIC_FOUNDRY_VECTORIZER_STOP_WORDS=english
TOPIC_FOUNDRY_STOP_WORDS_EXTRA=
TOPIC_FOUNDRY_TOP_N_WORDS=12
TOPIC_FOUNDRY_ENABLE_CLASS_BASED=true
TOPIC_FOUNDRY_ENABLE_LONG_DOCUMENT=true
TOPIC_FOUNDRY_ENABLE_HIERARCHICAL=true
TOPIC_FOUNDRY_ENABLE_DYNAMIC=true
TOPIC_FOUNDRY_ENABLE_GUIDED=true
TOPIC_FOUNDRY_ENABLE_ZEROSHOT=true
TOPIC_FOUNDRY_CHAT_CORPUS_OUTPUT_DIR=/data/topic-foundry/chat-corpus
TOPIC_FOUNDRY_CHAT_CORPUS_MARKDOWN_PATH=/data/pageindex/chat_episodes/chat_episode_corpus.md
TOPIC_FOUNDRY_CHAT_CORPUS_MAX_ROWS=10000
TOPIC_FOUNDRY_CHAT_CORPUS_LOOP_ENABLED=false
TOPIC_FOUNDRY_CHAT_CORPUS_INTERVAL_SECONDS=86400
TOPIC_FOUNDRY_COSINE_IMPL=normalize_euclidean
TOPIC_FOUNDRY_MODEL_DIR=/mnt/telemetry/models/topic-foundry
TOPIC_FOUNDRY_LLM_BUS_ROUTE=
TOPIC_FOUNDRY_LLM_TIMEOUT_SECS=60
TOPIC_FOUNDRY_LLM_MAX_CONCURRENCY=4
TOPIC_FOUNDRY_LLM_USE_BUS=true
TOPIC_FOUNDRY_LLM_INTAKE_CHANNEL=orion:exec:request:LLMGatewayService
TOPIC_FOUNDRY_LLM_REPLY_PREFIX=orion:llm:reply
# Live 2026-07-21: flipped on so topic labeling (training.py::_llm_label_topics,
# reuses the existing per-segment enrichment LLM client) and per-segment LLM
# enrichment both actually run instead of degrading to heuristics/null labels.
TOPIC_FOUNDRY_LLM_ENABLE=true

ORION_BUS_ENABLED=true
ORION_BUS_URL=redis://100.92.216.81:6379/0

TOPIC_FOUNDRY_DRIFT_DAEMON=false
TOPIC_FOUNDRY_DRIFT_POLL_SECONDS=900
TOPIC_FOUNDRY_DRIFT_WINDOW_HOURS=24
TOPIC_FOUNDRY_INTROSPECT_SCHEMAS=public
TOPIC_FOUNDRY_INTROSPECT_CACHE_SECS=30
TOPIC_FOUNDRY_INTROSPECT_MAX_TABLES=5000
TOPIC_FOUNDRY_INTROSPECT_MAX_COLUMNS=5000

# Host port → container :8000. Default 8879 avoids typical 809x collisions on the host.
SIGNAL_GATEWAY_HTTP_PORT=8879

SERVICE_NAME=orion-signal-gateway
SERVICE_VERSION=0.1.0
NODE_NAME=athena
# Default matches compose service orion-redis. Override if using mesh Redis from another stack.
# ORION_BUS_URL=redis://orion-redis:6379/0
ORION_BUS_ENABLED=true
LOG_LEVEL=INFO
SIGNAL_WINDOW_SEC=30.0
SIGNALS_OUTPUT_CHANNEL=orion:signals

# Optional: skip adapter emit when a passthrough for the same (organ_id, source_event_id) was recent.
SUPPRESS_ADAPTED_WHEN_PASSTHROUGH=false
PASSTHROUGH_DEDUPE_WINDOW_SEC=30.0

# Optional: OTLP gRPC endpoint for trace export (e.g. sidecar otel-collector:4317)
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_CONSOLE_EXPORT=true
# JSON list of dimension keys allowed as OTEL span attributes dim.* (see README; defaults in settings.py)
OTEL_DIMENSION_ALLOWLIST=["level","trend","volatility","confidence"]

# Compose observability stack host ports (docker-compose.yml — override if busy)
TEMPO_HTTP_PORT=3200
TEMPO_OTLP_GRPC_PORT=14317
TEMPO_OTLP_HTTP_PORT=14318
GRAFANA_HTTP_PORT=3001

# Local dev: anonymous Grafana login (compose default). Set false on shared networks and configure admin login.
GRAFANA_ANONYMOUS_ENABLED=true

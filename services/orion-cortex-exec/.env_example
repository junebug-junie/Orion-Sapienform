# Container name prefix (required — without this, compose creates invalid names like /-cortex-exec)
PROJECT=orion-athena

# Redis bus
ORION_BUS_URL=redis://100.92.216.81:6379/0
ORION_BUS_ENABLED=true
ORION_BUS_ENFORCE_CATALOG=true

SERVICE_NAME=cortex-exec
SERVICE_VERSION=0.1.1

HEARTBEAT_INTERVAL_SEC=10

# Background HTTP server for /health and /ready probes (mesh guardian)
HEALTH_HTTP_PORT=8070

# Bus routing channels (semantic)
EXEC_REQUEST_PREFIX=orion:exec:request
EXEC_RESULT_PREFIX=orion:exec:result
CORTEX_LOG_CHANNEL=orion:cortex:telemetry
CHANNEL_LLM_INTAKE=orion:exec:request:LLMGatewayService
# Downstream service channels
CHANNEL_RECALL_INTAKE=orion:exec:request:RecallService
CHANNEL_RECALL_REPLY_PREFIX=orion:exec:result:RecallService
# Bus RPC wait for RecallService (collapse mirror action recall step; separate from STEP_TIMEOUT_MS).
RECALL_RPC_TIMEOUT_SEC=90
# Hub chat_quick only — max seconds to wait on RecallService (Quick lane); honors recall toggle.
CHAT_QUICK_RECALL_TIMEOUT_SEC=30
# Default recall profile for chat_quick when profile is not client-explicit (vector-light; see orion/recall/profiles).
CHAT_QUICK_RECALL_PROFILE=assist.light.v1
# Default recall profile for chat_kids_story when profile is not client-explicit (vector-off; see orion/recall/profiles).
# CHAT_KIDS_STORY_RECALL_PROFILE=chat.story.kids.v1
# Purpose-conditioned recall (PCR) — chat_general read path
CHAT_PCR_ENABLED=true
CHAT_PCR_POST_STANCE_RECALL=true
CHAT_PCR_SKIP_ON_LOW_INFO=true
CHAT_PCR_QUICK_PHASE3=false
CHAT_PCR_SKIP_MAX_NOVELTY=0.25
CHAT_PCR_SKIP_SHIFT_NOVELTY_FLOOR=0.35
MEMORY_COGNITION_BRAIN_BELIEF_DEFAULT=true

# Unified-turn self-grounding: assemble the identity+relationship+PCR grounding
# capsule in the stance step and ride it on ThoughtEventV1. false => byte-identical
# to pre-grounding unified-turn behavior.
ORION_UNIFIED_GROUNDING_ENABLED=true
CHANNEL_CONTEXT_EXEC_INTAKE=orion:exec:request:ContextExecService
CHANNEL_CONTEXT_EXEC_REPLY_PREFIX=orion:exec:result:ContextExecService
CONTEXT_EXEC_ENABLED=true
CONTEXT_EXEC_TIMEOUT_SEC=60
CONTEXT_EXEC_DEPTH2_DEFAULT=false
CHANNEL_COUNCIL_INTAKE=orion:agent-council:intake
CHANNEL_COUNCIL_REPLY_PREFIX=orion:council:reply
CHANNEL_METACOG_TRACE_PUB=orion:metacog:trace
# Intake channel (orch -> exec)
CHANNEL_EXEC_REQUEST=orion:cortex:exec:request
# Lane label for this process: chat | spark | background | legacy (verb intake + legacy exec channel)
EXEC_LANE=legacy
# Parallel plan intake — harness finalize must not queue behind long chat_general turns.
EXEC_CONCURRENT_HANDLERS=true
# Metacog output channels
CHANNEL_COLLAPSE_SQL_WRITE=orion:collapse:sql-write
CHANNEL_COLLAPSE_INTAKE=orion:collapse:intake
# Context RPC channels
CHANNEL_PAD_RPC_REQUEST=orion:pad:rpc:request
CHANNEL_STATE_REQUEST=orion:state:request
CHANNEL_PAD_RPC_REPLY_PREFIX=orion:pad:rpc:reply
CHANNEL_STATE_REPLY_PREFIX=orion:state:reply
CHANNEL_CORE_EVENTS=orion:core:events
# Timeout for waiting on result
STEP_TIMEOUT_MS=600000
LLM_CHAT_QUICK_MAX_TOKENS=8000
LLM_CHAT_GENERAL_MAX_TOKENS=8000
LLM_CHAT_FALLBACK_MAX_TOKENS=8000
# memory_graph_suggest JSON draft completion budget (llm_memory_graph_suggest step)
LLM_MEMORY_GRAPH_SUGGEST_MAX_TOKENS=4096
# Completion budget for canonical dream_cycle step dream_synthesis only (not chat lanes)
LLM_DREAM_MAX_TOKENS=32768
# Explicit profile hint for metacog lane (route=metacog), including Juniper collapse mirror replies.
ATLAS_METACOG_PROFILE_NAME=qwen3-8b-q5km-v100-16gb-atlas-metacog-16k
# Metacog draft: pass 1 = chat JSON (always). Pass 2 = native uncertainty probe when true.
CORTEX_METACOG_RETURN_LOGPROBS=true
CORTEX_METACOG_LOGPROB_PROBE_MODE=native_completion
# Kill-switch for pass 2 only (pass 1 unaffected):
CORTEX_METACOG_UNCERTAINTY_PROBE_ENABLED=true
# Draft: trim metacog_biometrics_cue then spark_state_json when prompt exceeds worker ctx char budget.
CORTEX_METACOG_DRAFT_WORKER_CTX_CHAR_BUDGET=8000
# Enrich: trim metacog_biometrics_cue then spark_state_json when prompt exceeds worker ctx char budget.
CORTEX_METACOG_ENRICH_WORKER_CTX_CHAR_BUDGET=12000
# Fail daily_metacog_v1 before LLM when rendered prompt exceeds this char budget (no blind truncation).
CORTEX_DAILY_METACOG_PROMPT_MAX_CHARS=8192
# Lane A collapse mirror publish (log_orion_metacognition): skip draft/enrich LLM when prompt exceeds budget.
CORTEX_METACOG_DRAFT_PROMPT_MAX_CHARS=16384
CORTEX_METACOG_ENRICH_PROMPT_MAX_CHARS=20480

# Notify
NOTIFY_URL=http://orion-athena-notify:7140
NOTIFY_API_TOKEN=

# Skills Pack V1
ORION_TZ=America/Denver
ORION_SITUATION_ENABLED=true
ORION_SITUATION_TTL_SECONDS=300
ORION_SITUATION_PROMPT_MAX_CHARS=1200
ORION_SITUATION_TIMEZONE=America/Denver
ORION_SITUATION_LOCATION_LABEL=Utah
ORION_SITUATION_LOCALITY=Vernal
ORION_SITUATION_REGION=Utah
ORION_SITUATION_COUNTRY=US
ORION_SITUATION_LOCATION_PRECISION=city
ORION_SITUATION_WEATHER_ENABLED=true
ORION_SITUATION_WEATHER_PROVIDER=stub
# Blank LAT/LON means unset (stub / provider default); do not use a placeholder number here.
ORION_SITUATION_WEATHER_LAT=
ORION_SITUATION_WEATHER_LON=
ORION_SITUATION_WEATHER_TTL_SECONDS=600
ORION_SITUATION_UMBRELLA_PRECIP_PROB_THRESHOLD=40
ORION_SITUATION_JACKET_TEMP_F_THRESHOLD=55
ORION_SITUATION_HIGH_WIND_MPH_THRESHOLD=25
ORION_SITUATION_HOT_CAR_TEMP_F_THRESHOLD=80
ORION_SITUATION_AGENDA_ENABLED=true
ORION_SITUATION_LAB_CONTEXT_ENABLED=true
ORION_SITUATION_LAB_PROVIDER=stub
ORION_PRESENCE_SESSION_TTL_SECONDS=14400
ORION_PRESENCE_DEFAULT_REQUESTOR=Juniper
ORION_PRESENCE_PERSIST_ALLOWED=false
SKILLS_COMMAND_TIMEOUT_SEC=8
SKILLS_MESH_OPS_TIMEOUT_SEC=12
DOCKER_SOCK_PATH=/var/run/docker.sock
# Host docker CLI bind-mount (default /usr/bin/docker). Socket is mounted at DOCKER_SOCK_PATH.
# ORION_HOST_DOCKER_CLI=/usr/bin/docker
# --- NVIDIA / GPU snapshot (docker-compose bind-mount + gpus: all) ---
# Host path to nvidia-smi (must exist on the Docker host). Slim exec image does not ship the driver stack.
# ORION_HOST_NVIDIA_SMI=/usr/bin/nvidia-smi
# ORION_ACTIONS_NVIDIA_SMI_PATH=/usr/bin/nvidia-smi
# --- Tailscale / mesh ---
# docker-compose.yml bind-mounts host tailscale + /var/run/tailscale into the container.
# Use the in-container path (must match the volume mount target, default /usr/bin/tailscale).
# Override ORION_HOST_TAILSCALE_BIN if your CLI is only under /usr/sbin/tailscale.
ORION_ACTIONS_TAILSCALE_PATH=/usr/bin/tailscale
ORION_ACTIONS_SMARTCTL_PATH=/usr/sbin/smartctl
ORION_ACTIONS_NVME_PATH=/usr/sbin/nvme
ORION_ACTIONS_GITHUB_API_URL=https://api.github.com
# github_compactor_pass + skills.repo.github_recent_prs.v1 (set token; owner/repo default to this repo)
GITHUB_TOKEN=
ORION_ACTIONS_GITHUB_OWNER=junebug-junie
ORION_ACTIONS_GITHUB_REPO=Orion-Sapienform
ORION_ACTIONS_MESH_DEFAULT_LOOKBACK_DAYS=7
ORION_ACTIONS_DOCKER_PRUNE_DEFAULT_UNTIL=72h
ORION_ACTIONS_DOCKER_PROTECTED_LABELS=orion.keep=true,keep=true,protected=true
SKILLS_ALLOW_MUTATING_RUNTIME_HOUSEKEEPING=true
SKILLS_ALLOW_MESH_SERVICE_SCRIPTS=false
SKILLS_MESH_SERVICE_SCRIPT_TIMEOUT_SEC=900
BIOMETRICS_SERVICE_URL=http://orion-athena-biometrics:8100
BIOMETRICS_HTTP_TIMEOUT_SEC=5
# Consumes enriched journal metadata through pageindex query provenance.
JOURNAL_PAGEINDEX_SERVICE_URL=http://orion-pageindex:8360
ORION_REPO_ROOT=
ENDOGENOUS_RUNTIME_ENABLED=true
ENDOGENOUS_RUNTIME_SURFACE_CHAT_REFLECTIVE_ENABLED=true
ENDOGENOUS_RUNTIME_SURFACE_OPERATOR_ENABLED=true
ENDOGENOUS_RUNTIME_ALLOWED_WORKFLOW_TYPES=contradiction_review,concept_refinement,reflective_journal
ENDOGENOUS_RUNTIME_ALLOW_MENTOR_BRANCH=false
ENDOGENOUS_RUNTIME_SAMPLE_RATE=1.0
ENDOGENOUS_RUNTIME_MAX_ACTIONS=5
ENDOGENOUS_RUNTIME_STORE_BACKEND=memory
ENDOGENOUS_RUNTIME_STORE_PATH=/tmp/orion_endogenous_runtime_records.jsonl
ENDOGENOUS_RUNTIME_STORE_MAX_RECORDS=2000
ENDOGENOUS_RUNTIME_SQL_READ_ENABLED=true
ENDOGENOUS_RUNTIME_SQL_DATABASE_URL=postgresql://postgres:postgres@orion-athena-sql-db:5432/conjourney

# --- Global graph mode (active stack: Fuseki / SPARQL) ---
GRAPH_BACKEND=fuseki
RDF_STORE_BACKEND=fuseki
GDB_CLIENT_ENABLED=false

# Autonomy graph reads (Fuseki / SPARQL): default auto resolves from AUTONOMY_GRAPH_QUERY_URL, RDF_STORE_QUERY_URL, or RDF_STORE_BACKEND=fuseki + RDF_STORE_BASE_URL.
# Legacy GraphDB: AUTONOMY_GRAPH_BACKEND=graphdb + GRAPHDB_URL / CONCEPT_PROFILE_GRAPHDB_*.
# disabled = chat stance skips SPARQL (LocalAutonomyRepository + identity YAML); no Fuseki fan-out on brain lanes.
AUTONOMY_GRAPH_BACKEND=disabled
AUTONOMY_GRAPH_QUERY_URL=
AUTONOMY_GRAPH_UPDATE_URL=
RDF_STORE_QUERY_URL=http://orion-athena-fuseki:3030/orion/query
RDF_STORE_UPDATE_URL=http://orion-athena-fuseki:3030/orion/update
RDF_STORE_GRAPH_STORE_URL=http://orion-athena-fuseki:3030/orion/data
RDF_STORE_BASE_URL=http://orion-athena-fuseki:3030
RDF_STORE_DATASET=orion
# Local Fuseki dev auth:
# services/orion-rdf-store/.env sets FUSEKI_ADMIN_PASSWORD=orion.
# Therefore local update credentials are admin/orion, not admin/admin.
# Production should override these with real secrets.
RDF_STORE_USER=admin
RDF_STORE_PASS=orion

# --- Substrate durable semantic graph (materializer / exec substrate reads) ---
# in_memory = unified-beliefs cold fan-out stays local (no self_study/orionmem SPARQL on chat stance).
# Fuseki-backed when SUBSTRATE_STORE_BACKEND=sparql. If SUBSTRATE_GRAPH_QUERY_URL / SUBSTRATE_GRAPH_UPDATE_URL
# are unset, the builder uses RDF_STORE_QUERY_URL / RDF_STORE_UPDATE_URL.
SUBSTRATE_STORE_BACKEND=in_memory
SUBSTRATE_GRAPH_QUERY_URL=http://orion-athena-fuseki:3030/orion/query
SUBSTRATE_GRAPH_UPDATE_URL=http://orion-athena-fuseki:3030/orion/update
SUBSTRATE_GRAPH_URI=http://conjourney.net/graph/substrate
SUBSTRATE_GRAPH_TIMEOUT_SEC=5.0
SUBSTRATE_GRAPH_USER=admin
SUBSTRATE_GRAPH_PASS=orion
# Real change detection, not a blind timer (applies to both sparql/graphdb backends
# above; no-op for the in_memory default). See docs/superpowers/specs/2026-07-14-
# substrate-graph-store-snapshot-cache-spec.md. As long as THIS process's own writes haven't changed
# anything since the last fetch, snapshot() trusts the cache for up to this many
# seconds. Bounds staleness from writes made by a DIFFERENT process. 0 = trust
# forever (no periodic forced refresh at all).
SUBSTRATE_SNAPSHOT_FORCE_REFRESH_CEILING_SEC=30.0

# --- Substrate felt-state ctx hydration (rung 2) ---
# Loads the latest biometrics/execution/transport/self_state reducer projections
# from Postgres (conjourney) into chat-stance ctx so those unified-belief lanes
# activate. Default-off in code; enabled here to run. Fail-open + freshness-gated
# (stale rows past MAX_AGE_SEC are dropped). DB URL falls back to
# ENDOGENOUS_RUNTIME_SQL_DATABASE_URL when unset.
ENABLE_SUBSTRATE_FELT_STATE_CTX=true

# When true, Hub repair_pressure_contract metadata merges into chat TURN CONTRACT.
ENABLE_REPAIR_PRESSURE_SPEECH_WIRING=true
SUBSTRATE_FELT_STATE_DATABASE_URL=postgresql://postgres:postgres@orion-athena-sql-db:5432/conjourney
SUBSTRATE_FELT_STATE_MAX_AGE_SEC=120
# Self-model belief projection (chat_stance): per-dimension score threshold above
# which a self:{dimension_id} node folds a hazard into stance social hazards.
SELF_STATE_STANCE_PRESSURE_THRESHOLD=0.8

# Legacy GraphDB substrate (explicit SUBSTRATE_STORE_BACKEND=graphdb only):
# SUBSTRATE_STORE_BACKEND=graphdb
# SUBSTRATE_GRAPHDB_ENDPOINT=http://orion-athena-graphdb:7200/repositories/collapse

# Legacy GraphDB autonomy (explicit only):
# AUTONOMY_GRAPH_BACKEND=graphdb
# Quick lane (chat_quick / chat_kids_story without chat_quick_full_stance): bounded reads
AUTONOMY_QUICK_GRAPH_TIMEOUT_SEC=3.0
AUTONOMY_QUICK_GRAPH_SUBJECTS=orion
AUTONOMY_QUICK_GRAPH_SUBQUERIES=identity
# Spark ConceptProfile repository backend (Phase 3A shadow rollout)
CONCEPT_PROFILE_REPOSITORY_BACKEND=local
CONCEPT_PROFILE_GRAPHDB_ENDPOINT=
# Legacy concept-profile GraphDB example (prefer RDF_STORE_QUERY_URL / Fuseki):
# CONCEPT_PROFILE_GRAPHDB_URL=http://orion-athena-graphdb:7200
CONCEPT_PROFILE_GRAPHDB_URL=
CONCEPT_PROFILE_GRAPHDB_REPO=collapse
CONCEPT_PROFILE_GRAPHDB_USER=
CONCEPT_PROFILE_GRAPHDB_PASS=
CONCEPT_PROFILE_GRAPH_TIMEOUT_SEC=8.0
# Autonomy SPARQL reads; parallel subject fan-out can stress the graph endpoint under load.
AUTONOMY_GRAPH_TIMEOUT_SEC=20.0
# Parallel autonomy subjects (orion / relationship / juniper).
AUTONOMY_SUBJECT_MAX_WORKERS=2
# Parallel SPARQL per subject (identity / drives / goals). Use 1 to serialize under load (max 3).
AUTONOMY_SUBQUERY_MAX_WORKERS=3
# Chat stance path: facet fan-out (1 serializes under GraphDB load; max 3).
AUTONOMY_CHAT_STANCE_SUBQUERY_MAX_WORKERS=1
# Drive audit SPARQL row cap for debug/probe paths.
AUTONOMY_DRIVES_QUERY_LIMIT=80
# Tighter drive audit row cap for chat stance compact path (not overridden by AUTONOMY_DRIVES_QUERY_LIMIT).
AUTONOMY_CHAT_STANCE_DRIVES_QUERY_LIMIT=20
# Master switch: when true, exec may request bounded multi-subject Graph autonomy reads (faster) for plain chat_quick; deep lanes still use full fan-out. Set false to never short-circuit subjects.
AUTONOMY_CHAT_STANCE_SHORT_CIRCUIT=true
# list_latest observer consumer names that may honor bounded fan-out (see orion.autonomy.fanout_policy). Omitted variable uses code default (chat_stance,autonomy_ctx_adapter).
AUTONOMY_SHORT_CIRCUIT_CONSUMERS=chat_stance,autonomy_ctx_adapter
# Self-study SPARQL (unified-beliefs producer); leave empty to skip Fuseki on chat stance.
SELF_STUDY_NAMED_GRAPH=
# Chat stance: optional SPARQL disposition hints from memory named graphs (comma-separated IRIs)
CHAT_STANCE_MEMORY_GRAPH_GRAPHS=
CHAT_STANCE_MEMORY_GRAPH_TIMEOUT_SEC=2.0
GRAPHDB_PROBE_TIMEOUT_SEC=3.0
AUTONOMY_GRAPH_PROBE_DEEP=false
# Pre-turn appraisal RPC handler — ONLY on main cortex-exec (legacy lane).
# Lane replicas (chat/spark/background) must set false to avoid RPC reply races.
ENABLE_PRE_TURN_APPRAISAL_HANDLER=true
REPAIR_PRESSURE_WEIGHTS_V2_PATH=config/substrate/repair_pressure_weights.v2.yaml
REPAIR_PRESSURE_PROBE_ROUTE=quick
CHANNEL_PRE_TURN_APPRAISAL_REQUEST=orion:cortex:pre_turn_appraisal:request
CHANNEL_PRE_TURN_APPRAISAL_RESULT_PREFIX=orion:cortex:pre_turn_appraisal:result
# Goal archive script (scripts/autonomy/archive_stale_goal_proposals.py): retention + per-drive-origin cap
AUTONOMY_GOAL_RETENTION_DAYS=30
AUTONOMY_GOAL_MAX_ACTIVE_PER_SUBJECT=3
# Skip Orion drives SPARQL on chat_stance (relationship drives + Orion goals); true by default.
AUTONOMY_CHAT_STANCE_DEFER_ORION_DRIVES=true
# Drives-only SPARQL timeout when defer is false (default 12s; not capped below AUTONOMY_GRAPH_TIMEOUT_SEC).
AUTONOMY_DRIVES_SUBQUERY_TIMEOUT_SEC=12
# Phase 3 operator goal execution gate (Hub promote/dismiss/complete; default off).
AUTONOMY_GOAL_EXECUTION_ENABLED=true
# Chat stance: inject goal_hint into response_priorities when top active goal priority >= threshold.
GOAL_HINT_PRIORITY_THRESHOLD=0.4
# AutonomyStateV2 deterministic reducer sidecar in chat stance (export ctx + router preview; default off).
AUTONOMY_STATE_V2_REDUCER_ENABLED=
# Surface drive_state.v1 (DriveAuditV1/DriveStateV1 pressures+activations+dominant_drive+summary)
# as a sibling inputs["drive_state"] key in chat stance inputs. Kept structurally separate from
# inputs["autonomy"]/autonomy_state_v2 — see orion/self_state/inner_state_registry.py DUPLICATE
# note (drive_state and autonomy_state_v2 are independently-computed, never crosswalked). Default off.
CHAT_STANCE_DRIVE_STATE_VISIBLE=
# DSN for the autonomy_state_v2 table (see services/orion-sql-db/manual_migration_autonomy_state_v2.sql).
# Closes the reducer's own fold loop: _run_autonomy_reducer() reads/writes the latest
# AutonomyStateV2 per subject here instead of discarding it every turn. Same shared
# Postgres (conjourney) as ORION_ACTION_OUTCOME_DB_URL below. Leave blank to fail open
# (reducer falls back to the V1/graph baseline every turn, matching pre-existing behavior).
ORION_AUTONOMY_STATE_DB_URL=postgresql://postgres:postgres@orion-athena-sql-db:5432/conjourney
# File-backed recent action outcomes fed into autonomy reducer (max 12 per subject).
# Fallback only; preferred read path is the shared SQL store below.
ORION_ACTION_OUTCOME_STORE_PATH=/tmp/orion-action-outcomes.json
# Shared SQL store for cross-service action outcomes (written by sql-writer from
# action.outcome.emit.v1). When set, load_action_outcomes reads here instead of the
# per-container JSON file. Leave blank to use the file fallback.
ORION_ACTION_OUTCOME_DB_URL=postgresql://postgres:postgres@orion-athena-sql-db:5432/conjourney
CONCEPT_PROFILE_GRAPH_URI=http://conjourney.net/graph/spark/concept-profile
CONCEPT_PROFILE_PARITY_MIN_COMPARISONS=50
CONCEPT_PROFILE_PARITY_MAX_MISMATCH_RATE=0.05
CONCEPT_PROFILE_PARITY_MAX_UNAVAILABLE_RATE=0.02
CONCEPT_PROFILE_PARITY_CRITICAL_MISMATCH_CLASSES=profile_missing_on_graph,profile_missing_on_local,query_error
CONCEPT_PROFILE_PARITY_SUMMARY_INTERVAL=25

# Substrate grammar ingress (feeds execution/reasoning pressure into honest φ)
PUBLISH_CORTEX_EXEC_GRAMMAR=true
GRAMMAR_EVENT_CHANNEL=orion:grammar:event

# Per-call reasoning telemetry (metadata only, no trace text)
PUBLISH_REASONING_TELEMETRY=true
CHANNEL_REASONING_CALL=orion:cognition:reasoning_call

# --- Embodiment (D) background emit + perception read-model (default-off, fail-open) ---
# Consume orion:embodiment:perception into a latest-wins TTL cache.
EMBODIMENT_PERCEPTION_CORTEX_ENABLED=false
# Publish a deliberate approach/wander intent to orion:embodiment:intent on a timer.
EMBODIMENT_D_BACKGROUND_ENABLED=false
EMBODIMENT_CHANNEL_PERCEPTION=orion:embodiment:perception
EMBODIMENT_CHANNEL_INTENT=orion:embodiment:intent
EMBODIMENT_BACKGROUND_INTERVAL_SEC=30
# Orion's town player id (required for the background loop to key the cache).
AITOWN_ORION_PLAYER_ID=
# --- Computed salience v2 (shadow-first, default-off) ---
ORION_ATTENTION_SALIENCE_V2_ENABLED=true
ORION_ATTENTION_HABITUATION_ENABLED=true
# Optional JSON override for combiner weights; empty = hand-seeded seed-v1.
ORION_ATTENTION_SALIENCE_WEIGHTS=

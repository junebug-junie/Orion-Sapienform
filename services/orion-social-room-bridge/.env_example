APP_NAME=orion-social-room-bridge
SERVICE_NAME=orion-social-room-bridge
SERVICE_VERSION=0.1.0
NODE_NAME=athena
PORT=8764
LOG_LEVEL=INFO

#ORION_BUS_URL=redis://orion-redis:6379/0
ORION_BUS_ENABLED=true
ORION_BUS_ENFORCE_CATALOG=false

SOCIAL_BRIDGE_ENABLED=true
SOCIAL_BRIDGE_DRY_RUN=false
SOCIAL_BRIDGE_PLATFORM=callsyne
SOCIAL_BRIDGE_USE_RECALL=true
SOCIAL_BRIDGE_ROOM_ALLOWLIST=room-alpha,room-beta
SOCIAL_BRIDGE_SELF_PARTICIPANT_IDS=orion-room-bot
SOCIAL_BRIDGE_SELF_NAME=Oríon
SOCIAL_BRIDGE_AUTONOMY_MODE=responsive
SOCIAL_BRIDGE_ONLY_WHEN_ADDRESSED=false
SOCIAL_BRIDGE_COOLDOWN_SEC=0
SOCIAL_BRIDGE_MAX_CONSECUTIVE_ORION_TURNS=2
SOCIAL_BRIDGE_MIN_NOVELTY_SCORE=0.22
SOCIAL_BRIDGE_LIGHT_INITIATIVE_MIN_CONTINUITY=0.45
SOCIAL_BRIDGE_DEDUPE_TTL_SEC=3600
SOCIAL_BRIDGE_SESSION_NAMESPACE=callsyne-room

HUB_BASE_URL=http://orion-hub:8080
HUB_CHAT_PATH=/api/chat
HUB_TIMEOUT_SEC=120

CALLSYNE_BASE_URL=http://callsyne.local
CALLSYNE_API_TOKEN=
CALLSYNE_TIMEOUT_SEC=30
CALLSYNE_POST_PATH_TEMPLATE=/api/rooms/{room_id}/messages
CALLSYNE_WEBHOOK_TOKEN=

SOCIAL_MEMORY_BASE_URL=http://orion-social-memory:8765
SOCIAL_MEMORY_TIMEOUT_SEC=3

ROOM_INTAKE_CHANNEL=orion:bridge:social:room:intake
ROOM_DELIVERY_CHANNEL=orion:bridge:social:room:delivery
ROOM_SKIPPED_CHANNEL=orion:bridge:social:room:skipped
ROOM_PARTICIPANT_CHANNEL=orion:bridge:social:participant
ROOM_REPAIR_SIGNAL_CHANNEL=orion:social:repair:signal
ROOM_REPAIR_DECISION_CHANNEL=orion:social:repair:decision
ROOM_EPISTEMIC_SIGNAL_CHANNEL=orion:social:epistemic:signal
ROOM_EPISTEMIC_DECISION_CHANNEL=orion:social:epistemic:decision
ROOM_TURN_POLICY_CHANNEL=orion:social:turn-policy

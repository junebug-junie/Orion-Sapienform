# ───────────────────────────────────────────────────────────────
# 🧠 Orion RDF Store — Fuseki backend stack
# ───────────────────────────────────────────────────────────────

PROJECT=orion-athena
NET=app-net

# === Fuseki service ===
SERVICE_NAME=orion-rdf-store
SERVICE_VERSION=0.1.0
FUSEKI_PORT=3030
FUSEKI_ADMIN_PASSWORD=orion
# Pin image (avoid stale `:latest`; Jena 5.1.0+ includes TDB lock-leak fixes).
FUSEKI_IMAGE=stain/jena-fuseki:5.1.0
FUSEKI_PROBE_GRAPH=https://orion.local/ops/fuseki-health-probe
FUSEKI_RECOVER_WAIT_SEC=20

# === Persistent storage on Athena U2-backed disk ===
RDF_STORE_DATA_ROOT=/mnt/graphdb/rdf-store
FUSEKI_DATA_DIR=${RDF_STORE_DATA_ROOT}/fuseki
FUSEKI_BACKUP_DIR=${RDF_STORE_DATA_ROOT}/fuseki-backups
# Refuse `make up` when the data filesystem has less than this much free (GB).
FUSEKI_MIN_FREE_GB=50
# Paths used by storage-status / delete-stale-copy / restore-mount scripts.
LUKEWARM_FUSEKI_ROOT=/mnt/storage-lukewarm/rdf-store/fuseki
GRAPHDB_FUSEKI_ROOT=/mnt/graphdb/rdf-store/fuseki

GRAPHDB_FUSEKI_ROOT=/mnt/graphdb/rdf-store/fuseki

# === RDF retention (shared with orion-rdf-writer; used by make prune) ===
RDF_STORE_QUERY_URL=http://127.0.0.1:3030/orion/query
RDF_STORE_UPDATE_URL=http://127.0.0.1:3030/orion/update
RDF_STORE_USER=admin
RDF_STORE_PASS=orion
RDF_RETENTION_ENABLED=false
RDF_RETENTION_DRY_RUN=false
RDF_RETENTION_TIMEOUT_SEC=3600
# RDF_RETENTION_POLICIES=[...]  # opt-in only; memory graphs are never default-pruned

# === Dataset / endpoint contract ===
RDF_STORE_BACKEND=fuseki
RDF_STORE_BASE_URL=http://orion-athena-fuseki:3030
RDF_STORE_DATASET=orion
RDF_STORE_QUERY_URL=
RDF_STORE_UPDATE_URL=
RDF_STORE_GRAPH_STORE_URL=

# === Athena CPU/JVM scaling ===
FUSEKI_JVM_XMS=4g
FUSEKI_JVM_XMX=32g
FUSEKI_JVM_GC_OPTS=-XX:+UseG1GC -XX:MaxGCPauseMillis=200
FUSEKI_EXTRA_JAVA_OPTS=
FUSEKI_JVM_ARGS=-Xms${FUSEKI_JVM_XMS} -Xmx${FUSEKI_JVM_XMX} ${FUSEKI_JVM_GC_OPTS} ${FUSEKI_EXTRA_JAVA_OPTS}

# Client-side retry for Fuseki lock exhaustion / gateway blips (Hub memory-graph approve, SPARQL clients).
FUSEKI_HTTP_RETRY_ATTEMPTS=4
FUSEKI_HTTP_RETRY_BASE_DELAY_SEC=0.5

# Optional compose resource hints.
# Note: deploy.resources is ignored by plain docker compose unless using Swarm.
FUSEKI_CPU_LIMIT=
FUSEKI_CPU_RESERVATION=
FUSEKI_MEM_LIMIT=40g
FUSEKI_MEM_RESERVATION=8g

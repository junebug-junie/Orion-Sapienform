APP_NAME=orion-social-room-bridge
SERVICE_NAME=orion-social-room-bridge
SERVICE_VERSION=0.1.0
NODE_NAME=athena
LOG_LEVEL=INFO

SOCIAL_ROOM_BRIDGE_PORT=8910
SOCIAL_ROOM_BRIDGE_HOST_PORT=8910

#ORION_BUS_URL=redis://orion-redis:6379/0
ORION_BUS_ENABLED=true
ORION_BUS_ENFORCE_CATALOG=true

SOCIAL_BRIDGE_ENABLED=true
# Start with true to verify Hub replies without POSTing to CallSyne
SOCIAL_BRIDGE_DRY_RUN=false
SOCIAL_BRIDGE_PLATFORM=callsyne
SOCIAL_BRIDGE_USE_RECALL=true
# Comma-separated channel keys / room ids CallSyne sends (must match webhook payloads and bridge allowlists)
SOCIAL_BRIDGE_ROOM_ALLOWLIST=world
# CallSyne bot user id(s) so Orion does not reply to its own messages (UUID from CallSyne admin)
SOCIAL_BRIDGE_SELF_PARTICIPANT_IDS=00000000-0000-0000-0000-000000000000
SOCIAL_BRIDGE_SELF_NAME=Orion
SOCIAL_BRIDGE_AUTONOMY_MODE=responsive
SOCIAL_BRIDGE_ONLY_WHEN_ADDRESSED=false
SOCIAL_BRIDGE_COOLDOWN_SEC=0
SOCIAL_BRIDGE_MAX_CONSECUTIVE_ORION_TURNS=2
SOCIAL_BRIDGE_MIN_NOVELTY_SCORE=0.22
SOCIAL_BRIDGE_LIGHT_INITIATIVE_MIN_CONTINUITY=0.45
SOCIAL_BRIDGE_DEDUPE_TTL_SEC=3600
SOCIAL_BRIDGE_SESSION_NAMESPACE=callsyne-room
SOCIAL_BRIDGE_HUB_MODE=brain
SOCIAL_BRIDGE_HUB_VERB=
SOCIAL_BRIDGE_RETURN_2XX_ON_DELIVERY_FAILURE=true
SOCIAL_BRIDGE_CALLSYNE_POLL_ENABLED=false
SOCIAL_BRIDGE_CALLSYNE_POLL_ROOM_ID=world
SOCIAL_BRIDGE_CALLSYNE_POLL_INTERVAL_SEC=2
SOCIAL_BRIDGE_CALLSYNE_POLL_SINCE_MESSAGE_ID=
SOCIAL_BRIDGE_CALLSYNE_POLL_SKIP_SELF=true
SOCIAL_BRIDGE_CALLSYNE_POLL_LIMIT=20
SOCIAL_BRIDGE_CALLSYNE_POLL_PATH=/api/bridge/messages

HUB_BASE_URL=http://orion-hub:8080
HUB_CHAT_PATH=/api/chat
HUB_TIMEOUT_SEC=120

# Production: https://callsyne.com — bridge API key from CallSyne admin (Bearer). Never commit real tokens.
CALLSYNE_BASE_URL=https://callsyne.com
CALLSYNE_API_TOKEN=
CALLSYNE_TIMEOUT_SEC=30
# Fixed REST bridge path (room_id is in JSON body). Legacy per-room path was /api/rooms/{room_id}/messages
CALLSYNE_POST_PATH_TEMPLATE=/api/bridge/messages
# Shared secret: Orion expects header X-Callsyne-Webhook-Token on inbound webhooks when set
CALLSYNE_WEBHOOK_TOKEN=

SOCIAL_MEMORY_BASE_URL=http://orion-social-memory:8910
SOCIAL_MEMORY_TIMEOUT_SEC=3

ROOM_INTAKE_CHANNEL=orion:bridge:social:room:intake
ROOM_DELIVERY_CHANNEL=orion:bridge:social:room:delivery
ROOM_SKIPPED_CHANNEL=orion:bridge:social:room:skipped
ROOM_PARTICIPANT_CHANNEL=orion:bridge:social:participant
ROOM_REPAIR_SIGNAL_CHANNEL=orion:social:repair:signal
ROOM_REPAIR_DECISION_CHANNEL=orion:social:repair:decision
ROOM_EPISTEMIC_SIGNAL_CHANNEL=orion:social:epistemic:signal
ROOM_EPISTEMIC_DECISION_CHANNEL=orion:social:epistemic:decision
ROOM_TURN_POLICY_CHANNEL=orion:social:turn-policy

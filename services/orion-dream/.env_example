# ───────────────────────────────────────────────────────────────
# Orion Dream — Environment Configuration
# ───────────────────────────────────────────────────────────────

PROJECT=orion-athena
NET=app-net
NODE_NAME=athena

# --- Service Metadata ---
SERVICE_NAME=dream
SERVICE_VERSION=1.0.0
PORT=8620

# --- Redis Bus ---
#ORION_BUS_URL=redis://${PROJECT}-bus-core:6379/0
ORION_BUS_ENFORCE_CATALOG=true
ORION_BUS_ENABLED=true

POSTGRES_URI=postgresql://postgres:postgres@${PROJECT}-sql-db:5432/conjourney

CHANNEL_DREAM_TRIGGER=orion:dream:trigger
CHANNEL_DREAM_BUFFER=orion:dream:buffer
CHANNEL_DREAM_COMPLETE=orion:dream:complete
CHANNEL_DREAM_STATUS=orion:dream:status

CORTEX_GATEWAY_REQUEST_CHANNEL=orion:cortex:gateway:request
DREAM_REPLY_PREFIX=orion:dream:reply
DREAM_VERB=dream_simple

# Memory streams (listener subscribes)
CHANNEL_COLLAPSE_SQL_PUBLISH=orion:collapse:sql-write
CHANNEL_COLLAPSE_TAGS_PUBLISH=orion:tags:enriched
CHANNEL_TELEMETRY_PUBLISH=orion:biometrics:telemetry
CHANNEL_CHAT=orion:chat:history:log

# --- Chroma (vector memories) ---
VECTOR_DB_HOST=${PROJECT}-vector-db
VECTOR_DB_PORT=8000
VECTOR_DB_COLLECTION=orion_main_store
# --- RDF reads (Fuseki; legacy GraphDB only if RDF_STORE_QUERY_URL is empty) ---
RDF_STORE_QUERY_URL=http://${PROJECT}-fuseki:3030/orion/query
RDF_STORE_USER=admin
RDF_STORE_PASS=orion
GRAPHDB_USER=admin
GRAPHDB_PASS=admin
GRAPHDB_URL=
GRAPHDB_REPO=collapse

# --- Volumes ---
DREAM_LOG_DIR=/app/logs/dreams

# --- Legacy direct-Brain /chat (Ollama num_predict; -1 = uncapped completion, if backend supports it) ---
# DREAM_PREPROCESS_NUM_PREDICT=-1
# DREAM_SYNTHESIS_NUM_PREDICT=-1

# --- Sys ---
ENVIRONMENT=prod
HEARTBEAT_INTERVAL_SEC=10
ERROR_CHANNEL=orion:system:error
SHUTDOWN_GRACE_SEC=60

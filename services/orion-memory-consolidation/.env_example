# Orion Memory Consolidation — per-turn classify, window closure, suggest drafts

SERVICE_NAME=orion-memory-consolidation
SERVICE_VERSION=0.1.0
NODE_NAME=athena
LOG_LEVEL=INFO
PORT=8635

ORION_BUS_URL=${ORION_BUS_URL}
ORION_BUS_ENABLED=true
ORION_HEALTH_CHANNEL=orion:system:health
ERROR_CHANNEL=orion:system:error

POSTGRES_URI=${POSTGRES_URI}

CHANNEL_MEMORY_TURN_PERSISTED=orion:memory:turn:persisted
CHANNEL_CHAT_HISTORY_SPARK_META_PATCH=orion:chat:history:spark_meta:patch
CHANNEL_LLM_INTAKE=orion:exec:request:LLMGatewayService
CHANNEL_CORTEX_REQUEST=orion:cortex:request
CHANNEL_CORTEX_RESULT_PREFIX=orion:cortex:result

MEMORY_CONSOLIDATION_ENABLED=true
MEMORY_CLASSIFY_TIMEOUT_SEC=8.0
MEMORY_BOUNDARY_SCORE_THRESHOLD=0.70
MEMORY_BOUNDARY_LLM_ONLY_THRESHOLD=0.85
MEMORY_BOUNDARY_OVERRIDE_THRESHOLD=0.92
MEMORY_SUGGEST_TIMEOUT_SEC=180.0
MEMORY_WINDOW_FALLBACK_GAP_SEC=5400
MEMORY_FAILED_RETRY_INTERVAL_SEC=1800

# Redis bus
ORION_BUS_ENABLED=true
ORION_BUS_ENFORCE_CATALOG=true

SERVICE_NAME=cortex-exec
SERVICE_VERSION=0.1.1

HEARTBEAT_INTERVAL_SEC=10

# Bus routing channels (semantic)
EXEC_REQUEST_PREFIX=orion:exec:request
EXEC_RESULT_PREFIX=orion:exec:result
CORTEX_LOG_CHANNEL=orion:cortex:telemetry
CHANNEL_LLM_INTAKE=orion:exec:request:LLMGatewayService
# Downstream service channels
CHANNEL_RECALL_INTAKE=orion:exec:request:RecallService
# Bus RPC wait for RecallService (collapse mirror action recall step; separate from STEP_TIMEOUT_MS).
RECALL_RPC_TIMEOUT_SEC=90
CHANNEL_AGENT_CHAIN_INTAKE=orion:exec:request:AgentChainService
CHANNEL_PLANNER_INTAKE=orion:exec:request:PlannerReactService
CHANNEL_COUNCIL_INTAKE=orion:agent-council:intake
CHANNEL_COUNCIL_REPLY_PREFIX=orion:council:reply
CHANNEL_METACOG_TRACE_PUB=orion:metacog:trace
# Intake channel (orch -> exec)
CHANNEL_EXEC_REQUEST=orion:cortex:exec:request
# Metacog output channels
CHANNEL_COLLAPSE_SQL_WRITE=orion:collapse:sql-write
CHANNEL_COLLAPSE_INTAKE=orion:collapse:intake
# Context RPC channels
CHANNEL_PAD_RPC_REQUEST=orion:pad:rpc:request
CHANNEL_STATE_REQUEST=orion:state:request
CHANNEL_PAD_RPC_REPLY_PREFIX=orion:pad:rpc:reply
CHANNEL_STATE_REPLY_PREFIX=orion:state:reply
CHANNEL_CORE_EVENTS=orion:core:events
# Timeout for waiting on result
STEP_TIMEOUT_MS=600000
LLM_CHAT_QUICK_MAX_TOKENS=8000
LLM_CHAT_GENERAL_MAX_TOKENS=8000
LLM_CHAT_FALLBACK_MAX_TOKENS=8000
# Completion budget for canonical dream_cycle step dream_synthesis only (not chat lanes)
LLM_DREAM_MAX_TOKENS=32768
# Explicit profile hint for metacog lane (route=metacog), including Juniper collapse mirror replies.
ATLAS_METACOG_PROFILE_NAME=llama3-8b-instruct-q4km-atlas-metacog


# Notify
NOTIFY_URL=http://orion-athena-notify:7140
NOTIFY_API_TOKEN=

# Skills Pack V1
ORION_TZ=America/Denver
ORION_SITUATION_ENABLED=true
ORION_SITUATION_TTL_SECONDS=300
ORION_SITUATION_PROMPT_MAX_CHARS=1200
ORION_SITUATION_TIMEZONE=America/Denver
ORION_SITUATION_LOCATION_LABEL=Utah
ORION_SITUATION_LOCALITY=Vernal
ORION_SITUATION_REGION=Utah
ORION_SITUATION_COUNTRY=US
ORION_SITUATION_LOCATION_PRECISION=city
ORION_SITUATION_WEATHER_ENABLED=true
ORION_SITUATION_WEATHER_PROVIDER=stub
# Blank LAT/LON means unset (stub / provider default); do not use a placeholder number here.
ORION_SITUATION_WEATHER_LAT=
ORION_SITUATION_WEATHER_LON=
ORION_SITUATION_WEATHER_TTL_SECONDS=600
ORION_SITUATION_UMBRELLA_PRECIP_PROB_THRESHOLD=40
ORION_SITUATION_JACKET_TEMP_F_THRESHOLD=55
ORION_SITUATION_HIGH_WIND_MPH_THRESHOLD=25
ORION_SITUATION_HOT_CAR_TEMP_F_THRESHOLD=80
ORION_SITUATION_AGENDA_ENABLED=false
ORION_SITUATION_LAB_CONTEXT_ENABLED=true
ORION_SITUATION_LAB_PROVIDER=stub
ORION_PRESENCE_SESSION_TTL_SECONDS=14400
ORION_PRESENCE_DEFAULT_REQUESTOR=Juniper
ORION_PRESENCE_PERSIST_ALLOWED=false
SKILLS_COMMAND_TIMEOUT_SEC=8
SKILLS_MESH_OPS_TIMEOUT_SEC=12
DOCKER_SOCK_PATH=/var/run/docker.sock
# Host docker CLI bind-mount (default /usr/bin/docker). Socket is mounted at DOCKER_SOCK_PATH.
# ORION_HOST_DOCKER_CLI=/usr/bin/docker
# --- NVIDIA / GPU snapshot (docker-compose bind-mount + gpus: all) ---
# Host path to nvidia-smi (must exist on the Docker host). Slim exec image does not ship the driver stack.
# ORION_HOST_NVIDIA_SMI=/usr/bin/nvidia-smi
# ORION_ACTIONS_NVIDIA_SMI_PATH=/usr/bin/nvidia-smi
# --- Tailscale / mesh ---
# docker-compose.yml bind-mounts host tailscale + /var/run/tailscale into the container.
# Use the in-container path (must match the volume mount target, default /usr/bin/tailscale).
# Override ORION_HOST_TAILSCALE_BIN if your CLI is only under /usr/sbin/tailscale.
ORION_ACTIONS_TAILSCALE_PATH=/usr/bin/tailscale
ORION_ACTIONS_SMARTCTL_PATH=/usr/sbin/smartctl
ORION_ACTIONS_NVME_PATH=/usr/sbin/nvme
ORION_ACTIONS_GITHUB_API_URL=https://api.github.com
GITHUB_TOKEN=
ORION_ACTIONS_GITHUB_OWNER=
ORION_ACTIONS_GITHUB_REPO=
ORION_ACTIONS_MESH_DEFAULT_LOOKBACK_DAYS=7
ORION_ACTIONS_DOCKER_PRUNE_DEFAULT_UNTIL=72h
ORION_ACTIONS_DOCKER_PROTECTED_LABELS=orion.keep=true,keep=true,protected=true
SKILLS_ALLOW_MUTATING_RUNTIME_HOUSEKEEPING=true
BIOMETRICS_SERVICE_URL=http://orion-athena-biometrics:8100
BIOMETRICS_HTTP_TIMEOUT_SEC=5
# Consumes enriched journal metadata through pageindex query provenance.
JOURNAL_PAGEINDEX_SERVICE_URL=http://orion-pageindex:8360
ORION_REPO_ROOT=
ENDOGENOUS_RUNTIME_ENABLED=false
ENDOGENOUS_RUNTIME_SURFACE_CHAT_REFLECTIVE_ENABLED=false
ENDOGENOUS_RUNTIME_SURFACE_OPERATOR_ENABLED=false
ENDOGENOUS_RUNTIME_ALLOWED_WORKFLOW_TYPES=contradiction_review,concept_refinement,reflective_journal
ENDOGENOUS_RUNTIME_ALLOW_MENTOR_BRANCH=false
ENDOGENOUS_RUNTIME_SAMPLE_RATE=1.0
ENDOGENOUS_RUNTIME_MAX_ACTIONS=5
ENDOGENOUS_RUNTIME_STORE_BACKEND=memory
ENDOGENOUS_RUNTIME_STORE_PATH=/tmp/orion_endogenous_runtime_records.jsonl
ENDOGENOUS_RUNTIME_STORE_MAX_RECORDS=2000
ENDOGENOUS_RUNTIME_SQL_READ_ENABLED=true
ENDOGENOUS_RUNTIME_SQL_DATABASE_URL=postgresql://postgres:postgres@orion-athena-sql-db:5432/conjourney

# Spark ConceptProfile repository backend (Phase 3A shadow rollout)
CONCEPT_PROFILE_REPOSITORY_BACKEND=local
CONCEPT_PROFILE_GRAPHDB_ENDPOINT=
CONCEPT_PROFILE_GRAPHDB_URL=http://orion-athena-graphdb:7200
CONCEPT_PROFILE_GRAPHDB_REPO=collapse
CONCEPT_PROFILE_GRAPHDB_USER=admin
CONCEPT_PROFILE_GRAPHDB_PASS=admin
CONCEPT_PROFILE_GRAPH_TIMEOUT_SEC=8.0
# Autonomy SPARQL reads; parallel subject fan-out can push GraphDB past short budgets (client read timeouts match server Broken pipe in GraphDB logs).
AUTONOMY_GRAPH_TIMEOUT_SEC=20.0
# Parallel autonomy subjects (orion / relationship / juniper). Lower reduces concurrent SPARQL load on GraphDB (default in code is 3).
AUTONOMY_SUBJECT_MAX_WORKERS=2
# Parallel SPARQL per subject (identity / drives / goals). Use 1 to serialize when GraphDB times out under concurrent queries (max 3).
AUTONOMY_SUBQUERY_MAX_WORKERS=1
AUTONOMY_CHAT_STANCE_SHORT_CIRCUIT=true
# Chat stance: optional SPARQL disposition hints from memory named graphs (comma-separated IRIs)
CHAT_STANCE_MEMORY_GRAPH_GRAPHS=
CHAT_STANCE_MEMORY_GRAPH_TIMEOUT_SEC=2.0
GRAPHDB_PROBE_TIMEOUT_SEC=3.0
AUTONOMY_GRAPH_PROBE_DEEP=false
CONCEPT_PROFILE_GRAPH_URI=http://conjourney.net/graph/spark/concept-profile
CONCEPT_PROFILE_PARITY_MIN_COMPARISONS=50
CONCEPT_PROFILE_PARITY_MAX_MISMATCH_RATE=0.05
CONCEPT_PROFILE_PARITY_MAX_UNAVAILABLE_RATE=0.02
CONCEPT_PROFILE_PARITY_CRITICAL_MISMATCH_CLASSES=profile_missing_on_graph,profile_missing_on_local,query_error
CONCEPT_PROFILE_PARITY_SUMMARY_INTERVAL=25

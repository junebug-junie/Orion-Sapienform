SERVICE_NAME=orion-world-pulse
SERVICE_VERSION=0.1.0
NODE_NAME=athena
PORT=8628
LOG_LEVEL=INFO

ORION_BUS_ENABLED=true
ORION_BUS_ENFORCE_CATALOG=false
ORION_BUS_URL=redis://100.92.216.81:6379/0

WORLD_PULSE_ENABLED=true
WORLD_PULSE_DRY_RUN=false
WORLD_PULSE_FETCH_ENABLED=true
# Inline "Orion went looking" gap-fill fetch (billable). Required for the
# consolidated world-pulse journal: without this, digest.curiosity_followups is
# empty at compose time and the journal cannot include GPU/gap articles (the
# retired autonomy_episode journal used to carry downstream fetch results).
# Effective on/off = this AND ORION_CAPABILITY_POLICY_AUTO_READONLY_ENABLED.
WORLD_PULSE_CURIOSITY_FETCH_ENABLED=true
WORLD_PULSE_CURIOSITY_MAX_ARTICLES_PER_SECTION=5
WORLD_PULSE_CURIOSITY_MAX_SECTIONS=9
# Capability gate for the readonly fetch above (billable). Enabled by default.
ORION_CAPABILITY_POLICY_AUTO_READONLY_ENABLED=true
# Fetch backend: "auto" uses Firecrawl when a key resolves, else the stub.
ORION_EPISODE_FETCH_BACKEND=auto
# Firecrawl key is NOT stored here. It is derived from the read-only FCC mount
# (see docker-compose.yml volumes: ${HOME}/.fcc:/root/.fcc:ro). Leave blank.
ORION_FCC_ENV_PATH=/root/.fcc/.env
FIRECRAWL_API_KEY=
WORLD_PULSE_SQL_ENABLED=true
WORLD_PULSE_GRAPH_ENABLED=false
WORLD_PULSE_GRAPH_DRY_RUN=true
WORLD_PULSE_EMAIL_ENABLED=false
WORLD_PULSE_EMAIL_DRY_RUN=true
WORLD_PULSE_HUB_MESSAGES_ENABLED=true
WORLD_PULSE_STANCE_ENABLED=false
WORLD_PULSE_SCHEDULE_ENABLED=false

WORLD_PULSE_TIMEZONE=America/Denver
WORLD_PULSE_LOCALITY=Utah
WORLD_PULSE_MAX_ARTICLES_PER_RUN=100
WORLD_PULSE_MAX_ARTICLES_PER_SOURCE=10
WORLD_PULSE_FETCH_TIMEOUT_SECONDS=20
WORLD_PULSE_MIN_STANCE_CONFIDENCE=0.65
WORLD_PULSE_STANCE_MAX_TOPICS=5
WORLD_PULSE_POLITICS_STANCE_DEFAULT=only_when_requested
WORLD_PULSE_SOURCES_CONFIG_PATH=config/world_pulse/sources.yaml

WORLD_PULSE_RUN_REQUEST_CHANNEL=orion:world_pulse:run:request
WORLD_PULSE_RUN_RESULT_CHANNEL=orion:world_pulse:run:result
# Durable Redis Stream mirror of the run-result pub/sub channel. When enabled, the
# run.result envelope is additionally XADD'd to WP_RUN_RESULT_STREAM_KEY so consumer
# groups (orion-spark-concept-induction) get at-least-once delivery + replay. Pub/sub
# is unchanged. Must match WP_RUN_RESULT_STREAM_KEY on the consumer side.
# ROLLOUT ORDER: enable the consumer (orion-spark-concept-induction) FIRST so its
# consumer group is created (group start_id="$"). Runs XADD'd before the group exists
# are not delivered to the group. Enable this producer flag only after the consumer
# has started at least once.
WP_RUN_RESULT_STREAM_ENABLED=true
WP_RUN_RESULT_STREAM_KEY=orion:stream:world_pulse:run:result
WP_RUN_RESULT_STREAM_MAXLEN=1000
WORLD_PULSE_DIGEST_CREATED_CHANNEL=orion:world_pulse:digest:created
WORLD_PULSE_DIGEST_PUBLISHED_CHANNEL=orion:world_pulse:digest:published
WORLD_CONTEXT_DAILY_CAPSULE_CHANNEL=orion:world_context:daily_capsule
WORLD_PULSE_HUB_MESSAGE_CHANNEL=orion:hub:messages:create
WORLD_PULSE_GRAPH_CHANNEL=orion:world_pulse:graph:upsert
WORLD_PULSE_CLAIM_CHANNEL=orion:world_pulse:claim:emit
WORLD_PULSE_EVENT_CHANNEL=orion:world_pulse:event:emit
WORLD_PULSE_ENTITY_CHANNEL=orion:world_pulse:entity:emit
WORLD_PULSE_LEARNING_CHANNEL=orion:world_pulse:learning:emit
WORLD_PULSE_SITUATION_BRIEF_CHANNEL=orion:world_pulse:situation:brief:upsert
WORLD_PULSE_SITUATION_CHANGE_CHANNEL=orion:world_pulse:situation:change:emit

# Optional Notify endpoint for non-hub publish paths.
WORLD_PULSE_NOTIFY_URL=http://orion-notify:7140
NOTIFY_URL=http://orion-notify:7140
NOTIFY_API_TOKEN=

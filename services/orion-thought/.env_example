SERVICE_NAME=orion-thought
SERVICE_VERSION=0.1.0
NODE_NAME=athena
THOUGHT_PORT=7155

ORION_BUS_ENABLED=true
ORION_BUS_ENFORCE_CATALOG=false
ORION_BUS_URL=redis://100.x.x.x:6379/0

CHANNEL_THOUGHT_REQUEST=orion:thought:request
CHANNEL_THOUGHT_ARTIFACT=orion:thought:artifact
CHANNEL_THOUGHT_RESULT_PREFIX=orion:thought:result:
CHANNEL_CORTEX_EXEC_REQUEST=orion:cortex:exec:request
CHANNEL_CORTEX_EXEC_RESULT_PREFIX=orion:exec:result
STANCE_REACT_TIMEOUT_SEC=120

# Reverie: spontaneous-thought mode (Phase A). Default-off — read-only narration
# of the current winning coalition. Set true to enable the self-driven tick.
ORION_REVERIE_ENABLED=true
ORION_REVERIE_INTERVAL_SEC=90
ORION_REVERIE_MIN_SALIENCE=0.0
CHANNEL_REVERIE_THOUGHT=orion:reverie:thought

# Reverie semantic lift (v1). Requires substrate_turn_referent migration + referent rows.
ORION_REVERIE_SEMANTIC_LIFT_ENABLED=false
ORION_REVERIE_REFERENT_MAX_AGE_HOURS=24
CHANNEL_REVERIE_CORTEX_EXEC_REQUEST=orion:cortex:exec:request:background

# Reverie chain (Phase C). Default-off — a train of thought that terminates on
# pressure discharge / step-cap, with a refractory cooldown per resolved theme.
ORION_REVERIE_CHAIN_ENABLED=true
ORION_REVERIE_CHAIN_MAX_STEPS=4
ORION_REVERIE_REFRACTORY_SEC=900
ORION_REVERIE_DRIFT_TEMP=0.7
CHANNEL_REVERIE_CHAIN=orion:reverie:chain

# Reverie grounding (Phase D). Default-off, read-only — ground thoughts in recent
# Layer 11 motifs + rung-4 episode summaries.
ORION_REVERIE_GROUND_CONSOLIDATION=true

# Compaction request (Phase E). Default-off, queue only — a settled chain queues
# a typed ask for the offline dream. Applied by nothing.
ORION_REVERIE_COMPACTION_REQUEST_ENABLED=true
CHANNEL_DREAM_COMPACTION_REQUEST=orion:dream:compaction-request

# Resonance tripwire (Phase H). Default-off, observation only — after each chain,
# scan recent chains for a theme re-igniting inside its refractory bound and emit
# a ResonanceAlertV1 (the automated ouroboros guard). Never mutates cognition.
ORION_REVERIE_RESONANCE_ALERT_ENABLED=true
CHANNEL_REVERIE_RESONANCE_ALERT=orion:reverie:resonance-alert
ORION_REVERIE_RESONANCE_WINDOW=200

# Resonance health monitor (Phase H+). Edge-triggered orion-notify paging when a
# theme's resonance is actually worsening (violation_count climbing across its
# last 2 persisted samples) -- not merely "an alert exists," since a stale
# historical burst can keep re-reporting the same old numbers for days as it
# ages out of the 200-row lookback window above. Surfaces in Hub's existing
# Pending Attention panel via orion-notify's POST /attention/request.
NOTIFY_BASE_URL=http://orion-athena-notify:7140
NOTIFY_API_TOKEN=

# Reverie: direct read of attention broadcast + reverie-table persistence
POSTGRES_URI=postgresql://postgres:postgres@${PROJECT}-sql-db:5432/conjourney

# --- Computed salience v2 (shadow-first, default-off) ---
ORION_ATTENTION_SALIENCE_V2_ENABLED=true
ORION_ATTENTION_HABITUATION_ENABLED=true
# Optional JSON override for combiner weights; empty = hand-seeded seed-v1.
ORION_ATTENTION_SALIENCE_WEIGHTS=
# Salience trace telemetry channel — emitted per reverie tick when SALIENCE_V2 on.
CHANNEL_ATTENTION_SALIENCE_TRACE=orion:attention:salience:trace

# --- Mind stance enrichment (unified turn; enabled) ---
# Run orion-mind before stance_react and inject an advisory self/attention
# coloring into the verb context. Fail-open, flag-gated.
# NOTE: This is a silent no-op unless orion-mind has MIND_LLM_SYNTHESIS_ENABLED=true
# (that key lives on the orion-mind service, not here) AND orion-thought can reach
# ORION_MIND_BASE_URL. Verify both operationally at rollout.
ORION_THOUGHT_MIND_ENRICHMENT_ENABLED=true
ORION_MIND_BASE_URL=http://orion-mind:6611
# Budget: orion-mind runs 3 sequential LLM phases (semantic → appraisal → stance),
# each capped by MIND_LLM_TIMEOUT_SEC (default 60s, on the orion-mind service).
# WALL_MS must stay >= ~3× that (180000) or synthesis is cut off mid-pipeline and
# Mind degrades to contract_only. TIMEOUT_SEC (HTTP read) must exceed WALL_MS/1000
# so Mind's own fail-open result is returned instead of the client aborting.
ORION_THOUGHT_MIND_TIMEOUT_SEC=210
ORION_THOUGHT_MIND_WALL_MS=180000
ORION_THOUGHT_MIND_ROUTER_PROFILE=default
ORION_THOUGHT_MIND_MAX_RESPONSE_BYTES=2000000
ORION_THOUGHT_MIND_ARTIFACT_PUBLISH_ENABLED=true
ORION_THOUGHT_MIND_COLORING_MAX_ITEMS=3
CHANNEL_MIND_ARTIFACT=orion:mind:artifact
# Bounded single-row Postgres lookup (latest drive_audits row) for the
# drive_state_compact facet; kept far below WALL_MS/TIMEOUT_SEC so a slow/
# unavailable DB fails open fast without slowing the turn.
ORION_THOUGHT_MIND_DRIVE_STATE_FETCH_TIMEOUT_SEC=0.4

# --- Reasoning activity projection (always-on consumer; harmless when idle) ---
# Consume per-call ReasoningCallV1 telemetry off the bus and materialize a
# rolling-window ReasoningActivityV1 for φ to read via
# GET /projections/reasoning_activity. MAX_CALLS caps the in-memory buffer so
# memory stays bounded regardless of producer rate.
CHANNEL_REASONING_CALL=orion:cognition:reasoning_call
REASONING_ACTIVITY_WINDOW_SEC=120
REASONING_ACTIVITY_MAX_CALLS=2000

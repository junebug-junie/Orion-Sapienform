# ──────────────────────────────────────────────────────────────
# Orion Equilibrium Service
# Watches system.health + emits equilibrium snapshots / signals
# ──────────────────────────────────────────────────────────────

# Compose naming / network
#PROJECT=orion-athena
#NET=app-net

# Service identity
SERVICE_NAME=orion-equilibrium-service
SERVICE_VERSION=0.1.0
NODE_NAME=athena
INSTANCE_ID=eq-1

# Orion bus
ORION_BUS_ENABLED=true
ORION_BUS_ENFORCE_CATALOG=true
ORION_BUS_URL=${ORION_BUS_URL}
ORION_HEALTH_CHANNEL=orion:system:health

# --- Metacognition tick  ---
CHANNEL_METACOGNITION_TICK=orion:metacognition:tick
METACOGNITION_TICK_KIND=metacognition.tick.v1
CHANNEL_EQUILIBRIUM_METACOG_TRIGGER=orion:equilibrium:metacog:trigger

# Titanium-ish channels
CHANNEL_EQUILIBRIUM_SNAPSHOT=orion:equilibrium:snapshot
CHANNEL_SPARK_SIGNAL=orion:spark:signal
CHANNEL_COGNITION_TRACE_PUB=orion:cognition:trace

# Runtime / heartbeat cadence (settings supports this; add to compose for provenance)
HEARTBEAT_INTERVAL_SEC=10

# Equilibrium logic
# Comma-separated list OR JSON list; your settings supports both.
EQUILIBRIUM_EXPECTED_SERVICES=recall,state-journaler,sql-writer,vector-writer
EQUILIBRIUM_METACOG_PUBLISH_VERB_REQUEST=false

# Optional: path inside container to YAML file with { services: [...] }
EQUILIBRIUM_EXPECTED_SERVICES_PATH=

EQUILIBRIUM_GRACE_MULTIPLIER=3.0
EQUILIBRIUM_PUBLISH_INTERVAL_SEC=15
EQUILIBRIUM_COLLAPSE_MIRROR_INTERVAL_SEC=10
EQUILIBRIUM_WINDOWS_SEC=[60,300,3600]

# Redis state key
EQUILIBRIUM_STATE_KEY=equilibrium:state
EQUILIBRIUM_STATE_RETENTION_SEC=3600

# Metacognition / collapse channels (settings defaults; override when wiring collapse)
CHANNEL_COLLAPSE_MIRROR_USER_EVENT=orion:collapse:intake
CHANNEL_PAD_SIGNAL=orion:pad:signal
CHANNEL_REPAIR_PRESSURE_APPRAISAL=orion:repair_pressure:appraisal
EQUILIBRIUM_METACOG_RECALL_ENABLED=false

# Metacognition Logging
# Ticks (orion:metacognition:tick) are telemetry only. Live collapse generation requires
# metacog triggers on CHANNEL_EQUILIBRIUM_METACOG_TRIGGER (baseline loop below).
EQUILIBRIUM_METACOG_ENABLE=true
EQUILIBRIUM_METACOG_BASELINE_INTERVAL_SEC=1000
EQUILIBRIUM_METACOG_BASELINE_MAX_SKIPS=3
EQUILIBRIUM_METACOG_COOLDOWN_SEC=30
EQUILIBRIUM_METACOG_PAD_PULSE_THRESHOLD=0.8
EQUILIBRIUM_METACOG_SUBSTRATE_TRIGGER_ENABLE=true
EQUILIBRIUM_METACOG_SUBSTRATE_DENSE_THRESHOLD=0.55
EQUILIBRIUM_METACOG_SUBSTRATE_PULSE_THRESHOLD=0.30

# Relational metacog trigger: reuses repair_pressure_v2 (orion-hub's live
# pre_turn_appraisal wiring), published on CHANNEL_REPAIR_PRESSURE_APPRAISAL
# whenever the repair_pressure paradigm actually runs. Replaced the retired
# turn_change_classify SHIFT gate as of 2026-07-18 -- see
# docs/superpowers/design/2026-07-18-collapse-mirror-metacog-redesign.md.
EQUILIBRIUM_METACOG_RELATIONAL_TRIGGER_ENABLE=true
EQUILIBRIUM_METACOG_RELATIONAL_CONFIDENCE_THRESHOLD=0.7
EQUILIBRIUM_METACOG_RELATIONAL_LEVEL_THRESHOLD=0.5

# Telemetry-anomaly metacog trigger: reuses field_channel_corpus.v1's
# reconstruction-loss anomaly score, published on
# CHANNEL_FIELD_CHANNEL_ANOMALY_SCORE by orion-field-digester's periodic
# anomaly-scoring loop whenever FIELD_CHANNEL_ANOMALY_ENABLED is on there.
# 2026-07-21 -- see docs/superpowers/design/2026-07-18-collapse-mirror-
# metacog-redesign.md's trigger taxonomy.
CHANNEL_FIELD_CHANNEL_ANOMALY_SCORE=orion:field_channel:anomaly_score
EQUILIBRIUM_METACOG_TELEMETRY_ANOMALY_TRIGGER_ENABLE=true
EQUILIBRIUM_METACOG_TELEMETRY_ANOMALY_THRESHOLD_MULTIPLIER=3.0

# chat_turn metacog trigger: correlates ThoughtEventV1 (CHANNEL_THOUGHT_ARTIFACT)
# + HarnessRunV1 (CHANNEL_HARNESS_RUN_ARTIFACT) + an optional governor-timeout
# GrammarEventV1 (CHANNEL_GRAMMAR_EVENT, semantic_role == "exec_turn_timeout",
# Patch B / PR #1287) by correlation_id and fires on real gate conditions read
# off those schemas -- deferred/refused turns, boundary hits, misaligned/
# unresolved reflection, high surprise, incomplete compliance, non-zero exit,
# degraded finalize, or a governor timeout. Enabled 2026-07-23 (was ships-off
# in PR #1291) -- see acceptance checks in docs/superpowers/design/
# 2026-07-18-collapse-mirror-metacog-redesign.md; live-data verification
# (real orion_metacog rows, non-degenerate upstream) still needs to happen
# post-deploy, not yet run.
CHANNEL_THOUGHT_ARTIFACT=orion:thought:artifact
CHANNEL_HARNESS_RUN_ARTIFACT=orion:harness:run:artifact
CHANNEL_GRAMMAR_EVENT=orion:grammar:event
EQUILIBRIUM_METACOG_CHAT_TURN_TRIGGER_ENABLE=true
EQUILIBRIUM_METACOG_CHAT_TURN_CORRELATOR_TTL_SEC=600
EQUILIBRIUM_METACOG_CHAT_TURN_SURPRISE_THRESHOLD=0.7
# Separate cooldown lane from EQUILIBRIUM_METACOG_COOLDOWN_SEC above -- chat_turn
# fires on essentially every remarkable turn, so sharing the global cooldown
# would let it starve the other trigger kinds' own fires.
EQUILIBRIUM_METACOG_CHAT_TURN_COOLDOWN_SEC=30

# transport metacog trigger (docs/superpowers/specs/2026-07-24-transport-metacog-
# trigger-design.md). Two independent evidence sources, both feeding trigger_kind
# "transport": (A) real RpcHealthSnapshotV1 windows from orion:rpc_health:snapshot
# (timeout_count>0 or a p95 latency spike); (C) any real orion:grammar:event with
# semantic_role=="rpc_transport_timeout" (orion/core/bus/async_service.py::
# _emit_rpc_timeout_grammar), a per-call RPC timeout across all 37+ real
# rpc_request() call sites, not just harness/thought. Ships disabled; needs the
# same live-verification standard as every other trigger in this family before
# flipping on.
CHANNEL_RPC_HEALTH_SNAPSHOT=orion:rpc_health:snapshot
EQUILIBRIUM_METACOG_TRANSPORT_TRIGGER_ENABLE=false
# Separate cooldown lane, from day one -- see chat_turn's own comment above for why.
EQUILIBRIUM_METACOG_TRANSPORT_COOLDOWN_SEC=30
# No existing config to inherit from -- a starting default, same calibration
# caveat as telemetry_anomaly's threshold_multiplier; needs real data to validate.
EQUILIBRIUM_METACOG_TRANSPORT_LATENCY_P95_THRESHOLD_MS=5000

# Substrate felt-state reader (dense/pulse metacog triggers read Postgres projections)
ENABLE_SUBSTRATE_FELT_STATE_CTX=true
SUBSTRATE_FELT_STATE_DATABASE_URL=postgresql://postgres:postgres@orion-athena-sql-db:5432/conjourney
SUBSTRATE_FELT_STATE_MAX_AGE_SEC=120

# Spark heartbeat (idle keepalive)
EQUILIBRIUM_SPARK_HEARTBEAT_ENABLE=false
EQUILIBRIUM_SPARK_HEARTBEAT_INTERVAL_SEC=30

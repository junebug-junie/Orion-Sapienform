PROJECT=orion-athena
NET=app-net
NODE_NAME=athena

SERVICE_NAME=orion-graphiti-adapter
SERVICE_VERSION=0.1.0
PORT=8640

POSTGRES_URI=postgresql://postgres:postgres@orion-athena-sql-db:5432/conjourney
GRAPHITI_AUTO_APPLY_SCHEMA=true

# FalkorDB (Redis graph module) — additive temporal projection backend
FALKORDB_URI=redis://orion-athena-falkordb:6379
FALKORDB_GRAPH=graphiti_temporal
FALKORDB_ENABLED=false

LOG_LEVEL=INFO

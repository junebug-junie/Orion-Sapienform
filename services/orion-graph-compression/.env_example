# ──────────────────────────────────────────────────────────────
# 🗜️  Orion Graph Compression — offline region summaries
# ──────────────────────────────────────────────────────────────

# --- Stack / compose placeholders ---
PROJECT=orion-athena
NET=app-net
NODE_NAME=athena
# --- Service Identity ---
SERVICE_NAME=orion-graph-compression
SERVICE_VERSION=0.1.0
PORT=8271

# --- Orion Bus Integration ---
ORION_BUS_ENABLED=true
ORION_BUS_ENFORCE_CATALOG=true
ORION_BUS_URL=redis://100.92.216.81:6379/0
ORION_HEALTH_CHANNEL=orion:system:health
HEARTBEAT_INTERVAL_SEC=30
ERROR_CHANNEL=orion:system:error

# --- Bus channels (orion/bus/channels.yaml) ---
CHANNEL_RDF_ENQUEUE=orion:rdf:enqueue
CHANNEL_GRAPH_COMPRESSION_STALE=orion:graph:compression:stale
CHANNEL_GRAPH_COMPRESSION_EVENTS=orion:graph:compression:events
CHANNEL_SUBSTRATE_MUTATION_PRESSURE=orion:substrate:mutation:pressure

# --- Bus schemas / message kinds (orion/schemas/registry.py) ---
SCHEMA_COMPRESSION_REGION_V1=CompressionRegionV1
SCHEMA_COMPRESSION_STALENESS_MARK_V1=CompressionStalenessMarkV1
SCHEMA_GRAPH_COMPRESSION_REGION_MATERIALIZED_V1=GraphCompressionRegionMaterializedV1
MESSAGE_KIND_GRAPH_COMPRESSION_STALE=graph.compression.stale.v1
MESSAGE_KIND_GRAPH_COMPRESSION_REGION_MATERIALIZED=graph.compression.region.materialized.v1

# --- Postgres (artifact index + stale queue) ---
POSTGRES_URI=postgresql://postgres:postgres@orion-athena-sql-db:5432/conjourney

# --- Fuseki (read source graphs + write orion:compressions) ---
RDF_STORE_QUERY_URL=http://orion-athena-fuseki:3030/orion/query
RDF_STORE_UPDATE_URL=http://orion-athena-fuseki:3030/orion/update
RDF_STORE_USER=admin
RDF_STORE_PASS=orion
RDF_STORE_TIMEOUT_SEC=10.0

# --- FalkorDB federators (dark by default) ---
# Same shared FalkorDB instance substrate-runtime/orion-recall/orion-meta-tags
# already use (FALKORDB_URI), read directly from the environment by
# app/falkor_store.py (bypasses pydantic Settings, matching orion-recall's
# recall_falkor_store.py convention for this env var). Graph names below
# match the ones those services already write to -- not new graphs.
FALKORDB_URI=redis://orion-athena-falkordb:6379
FALKORDB_SUBSTRATE_GRAPH=orion_substrate
FALKORDB_RECALL_GRAPH=orion_recall
# Additive (unioned with the existing SPARQL federator, never a swap) while
# verifying live -- see app/worker.py::_process_scope. Substrate-runtime has
# been Falkor-primary since PR #1153 (the SPARQL substrate federator likely
# reads stale/empty data); orion-recall's Entity/Tag/ChatTurn graph is the
# live equivalent of what orion-rdf-writer's enrichment write used to feed
# the episodic federator.
GRAPH_COMPRESSION_SUBSTRATE_FALKOR_ENABLED=false
GRAPH_COMPRESSION_EPISODIC_FALKOR_ENABLED=false

# --- LLM Gateway (region summarization) ---
LLM_GATEWAY_BUS_CHANNEL=orion:exec:request:LLMGatewayService
ENABLE_LLM_SUMMARIES=true

# --- Worker tuning ---
COMPRESSION_POLL_INTERVAL_SEC=300
COMPRESSION_BATCH_SIZE=10
COMPRESSION_MAX_TOKENS_PER_SUMMARY=200
COMPRESSION_LLM_BUDGET_PER_TICK=5000
COMPRESSION_MAX_AGE_SEC=86400
ENABLE_COMPRESSION_RUNTIME=true
COMPRESSION_POLICY_PATH=/app/config/compression_policy.v1.yaml

# --- Runtime ---
LOG_LEVEL=INFO

# ─────────────────────────────────────────────
# 🤖 Orion Agent Chain — tool-chaining orchestrator
# ─────────────────────────────────────────────

SERVICE_NAME=agent-chain
SERVICE_VERSION=0.1.0

# HTTP port for this service
AGENT_CHAIN_PORT=8092

# --- Orion Bus (for future recall / spark integration) ---
ORION_BUS_ENABLED=true
ORION_BUS_ENFORCE_CATALOG=true
ORION_BUS_URL=redis://100.92.216.81:6379/0

PLANNER_REQUEST_CHANNEL=orion:exec:request:PlannerReactService
PLANNER_RESULT_PREFIX=orion:exec:result:PlannerReactService
LLM_REQUEST_CHANNEL=orion:exec:request:LLMGatewayService
LLM_REPLY_PREFIX=orion:llm:reply
COGNITION_BASE_DIR=/app/orion/cognition

# ─────────────────────────────────────────────────────────────
# UPSTREAM CHANNELS (From UI/Client)
# ─────────────────────────────────────────────────────────────
# The UI will publish here, and we will listen 
AGENT_CHAIN_REQUEST_CHANNEL=orion:exec:request:AgentChainService
# Legacy alias accepted by settings.py (kept for mixed deployments)
CHANNEL_AGENT_CHAIN_INTAKE=orion:exec:request:AgentChainService
# We will publish the final answer here
AGENT_CHAIN_RESULT_PREFIX=orion:exec:result:AgentChainService
# Legacy alias accepted by settings.py (kept for mixed deployments)
CHANNEL_AGENT_CHAIN_REPLY_PREFIX=orion:exec:result:AgentChainService


# --- Planner-React HTTP endpoint ---
# This should be the *container* hostname + port for planner-react
#PLANNER_REACT_URL=http://orion-athena-planner-react:8090

# --- Defaults for planning ---
AGENT_CHAIN_MAX_STEPS=10
AGENT_CHAIN_TIMEOUT_SECONDS=2500

# ──────────────────────────────────────────────────────────────
# 💎  Orion Memory Crystallizer — governed cognitive memory
# ──────────────────────────────────────────────────────────────

# --- Stack / compose placeholders ---
PROJECT=orion-athena
NET=app-net
NODE_NAME=athena

# --- Service Identity ---
SERVICE_NAME=orion-memory-crystallizer
SERVICE_VERSION=0.1.0
PORT=8634

# --- Orion Bus Integration ---
ORION_BUS_ENABLED=true
ORION_BUS_URL=redis://100.92.216.81:6379/0
ORION_HEALTH_CHANNEL=orion:system:health
HEARTBEAT_INTERVAL_SEC=30
ERROR_CHANNEL=orion:system:error

# --- Crystallization lifecycle channels (match orion/bus/channels.yaml) ---
CRYSTALLIZER_CHANNEL_PROPOSED=orion:memory:crystallization:proposed
CRYSTALLIZER_CHANNEL_VALIDATED=orion:memory:crystallization:validated
CRYSTALLIZER_CHANNEL_APPROVED=orion:memory:crystallization:approved
CRYSTALLIZER_CHANNEL_REJECTED=orion:memory:crystallization:rejected
CRYSTALLIZER_CHANNEL_QUARANTINED=orion:memory:crystallization:quarantined
CRYSTALLIZER_CHANNEL_PROJECT=orion:memory:crystallization:project
CRYSTALLIZER_CHANNEL_RETRIEVED=orion:memory:crystallization:retrieved
CRYSTALLIZER_CHANNEL_VECTOR_UPSERT=orion:memory:vector:upsert

# --- Canonical storage (Postgres preserves canonical crystallizations) ---
POSTGRES_URI=postgresql://postgres:postgres@orion-athena-sql-db:5432/conjourney
CRYSTALLIZER_AUTO_APPLY_SCHEMA=true

# --- Chroma semantic projection (via orion-vector-writer) ---
CRYSTALLIZER_VECTOR_COLLECTION=orion_memory_crystallizations
# Optional embedding host (e.g. orion-vector-host endpoint). When unset,
# upserts are published without embeddings and the vector writer will skip
# them (Chroma projection is rebuildable from Postgres).
CRYSTALLIZER_EMBED_HOST_URL=
CRYSTALLIZER_EMBED_TIMEOUT_MS=8000

# --- Graphiti/FalkorDB additive temporal graph projection ---
# Disabled by default; this is NOT the RDF memory_graph path.
GRAPHITI_ENABLED=false
GRAPHITI_URL=
FALKORDB_URI=

LOG_LEVEL=INFO

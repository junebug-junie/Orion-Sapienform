# Host-side overrides when running archive/autonomy scripts outside Docker.
# Copy to scripts/autonomy/.env — loaded after services/orion-cortex-exec/.env.
AUTONOMY_GRAPH_QUERY_URL=http://127.0.0.1:3030/orion/query
AUTONOMY_GRAPH_UPDATE_URL=http://127.0.0.1:3030/orion/update
RDF_STORE_USER=admin
RDF_STORE_PASS=orion

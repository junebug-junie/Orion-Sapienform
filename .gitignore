# ───────────────────────────────────────────────
# 🧠 Orion-Sapienform .gitignore
# Keeps repo clean of transient, local, or secret files
# ───────────────────────────────────────────────

MONITOR
**/tmp/
scripts/.state/
.superpowers/

# Local git worktrees (feature isolation)
.worktrees/

.orion_dev

# === Git worktrees (superpowers / local isolation) ===
.worktrees/

# Claude Code's own isolation:worktree Agent-tool feature creates worktrees
# here. Each one has its own .git, which `git add` from the parent repo
# mistakes for a submodule and tracks as a gitlink (mode 160000) instead of
# ignoring -- happened for real (.claude/worktrees/feat+substrate-signal-
# bridge-v1, cleaned up in the same commit that adds this line).
.claude/worktrees/


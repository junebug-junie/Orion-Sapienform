# ────────────────────────────────────────────────
# LLM Gateway defaults
# ────────────────────────────────────────────────
PROJECT=orion
SERVICE_NAME_LLM_GATEWAY=llm-gateway
SERVICE_VERSION_LLM_GATEWAY=0.1.1

ORION_BUS_URL=redis://100.92.216.81:6379/0
ORION_BUS_ENABLED=true
ORION_BUS_ENFORCE_CATALOG=true

CHANNEL_LLM_INTAKE=orion:exec:request:LLMGatewayService
CHANNEL_SPARK_INTROSPECT_CANDIDATE=orion:spark:introspect:candidate
CHANNEL_LLM_REPLY_PREFIX=orion:llm:reply
CHANNEL_VECTOR_LATENT_UPSERT=orion:vector:latent:upsert
# This is the fire-and-forget channel the gateway publishes assistant responses to for semantic embeddings.
CHANNEL_EMBEDDING_GENERATE=orion:embedding:generate

ORION_LLM_DEFAULT_BACKEND=llama-cola
ORION_DEFAULT_LLM_MODEL=Active-GGUF-Model
LLM_DEFAULT_PROFILE_NAME=
LLM_PROFILES_CONFIG_PATH=/app/config/llm_profiles.yaml

ORION_LLM_VLLM_URL=http://orion-vllm-host:8000
ORION_LLM_OLLAMA_URL=http://orion-ollama-host:11434
ORION_LLM_OLLAMA_USE_OPENAI=false

# Legacy fallback only (route-table mode is primary now).
# ORION_LLM_LLAMACPP_URL=http://100.121.214.30:7005

ORION_LLM_LLAMA_COLA_URL=http://orion-llama-cola-host:8004
ORION_LLM_INCLUDE_EMBEDDINGS=false
ORION_VECTOR_LATENT_COLLECTION=orion_latent_store

# LLM Gateway routing (single-subscriber; explicit route table preferred)
# `chat` should continue pointing at the existing Atlas chat worker endpoint.
# Internal Atlas lane-sharing stays behind that endpoint; the gateway only models route -> URL.
LLM_ROUTE_DEFAULT=chat
LLM_GATEWAY_ROUTE_TABLE_JSON='{"chat":{"url":"http://100.121.214.30:8011","served_by":"atlas-worker-1","backend":"llamacpp"},"metacog":{"url":"http://100.121.214.30:8012","served_by":"atlas-worker-2","backend":"llamacpp"},"agent":{"url":"http://100.121.214.30:8014","served_by":"atlas-worker-agent-1","backend":"llamacpp"}}'
# Legacy per-route aliases remain available for backward compatibility, but are
# not primary. Note that `agent` does not have a legacy alias env var, so the
# JSON route table is required for the current Atlas chat/metacog/agent layout.
LLM_ROUTE_CHAT_URL=
LLM_ROUTE_METACOG_URL=
LLM_ROUTE_LATENTS_URL=
LLM_ROUTE_SPECIALIST_URL=
LLM_ROUTE_CHAT_SERVED_BY=
LLM_ROUTE_METACOG_SERVED_BY=
LLM_ROUTE_LATENTS_SERVED_BY=
LLM_ROUTE_SPECIALIST_SERVED_BY=
LLM_ROUTE_HEALTH_TIMEOUT_SEC=1.5
LLM_GATEWAY_HEALTH_PORT=8210

CONNECT_TIMEOUT_SEC=10
READ_TIMEOUT_SEC=700
HEARTBEAT_INTERVAL_SEC=10

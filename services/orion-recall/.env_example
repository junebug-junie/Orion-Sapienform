# ──────────────────────────────────────────────────────────────
# 🧠 Orion Recall — Unified RAG / Memory Brain
# ──────────────────────────────────────────────────────────────

# --- Service Identity ---
SERVICE_NAME=recall
SERVICE_VERSION=0.1.0
NODE_NAME=unknown
PORT=8260

# --- Orion Bus Integration ---
ORION_BUS_ENABLED=true
ORION_BUS_ENFORCE_CATALOG=true
ORION_BUS_URL=redis://100.92.216.81:6379/0
ORION_HEALTH_CHANNEL=orion:system:health

# RPC intake (exec -> recall)
RECALL_BUS_INTAKE=orion:exec:request:RecallService
RECALL_BUS_REPLY_DEFAULT=orion:exec:result:RecallService
RECALL_BUS_TELEMETRY=orion:recall:telemetry

# --- Chassis / Runtime ---
HEARTBEAT_INTERVAL_SEC=10
ERROR_CHANNEL=orion:system:error
SHUTDOWN_GRACE_SEC=10
# Set true to process multiple bus RPCs concurrently (reduces head-of-line blocking on slow recall).
RECALL_RABBIT_CONCURRENT_HANDLERS=false

# --- Default Retrieval Behavior ---
RECALL_DEFAULT_MAX_ITEMS=16
RECALL_DEFAULT_TIME_WINDOW_DAYS=30
RECALL_DEFAULT_MODE=hybrid
RECALL_DEFAULT_PROFILE=reflect.v1

# --- Source Toggles ---
RECALL_ENABLE_SQL_CHAT=true
RECALL_ENABLE_SQL_MIRRORS=false
RECALL_ENABLE_VECTOR=false
RECALL_ENABLE_RDF=true

# --- Postgres (SQL) ---
RECALL_PG_DSN=postgresql://postgres:postgres@orion-athena-sql-db:5432/conjourney

# --- Memory cards (operator-curated Postgres; shared RECALL_PG_DSN) ---
RECALL_ENABLE_CARDS=true
RECALL_CARDS_TIMEOUT_SEC=8.0
RECALL_CARDS_MAX_NEIGHBORS=6
RECALL_CARDS_EMBEDDING_URL=http://orion-athena-vector-host:8320/embedding
RECALL_CARDS_EMBED_TIMEOUT_SEC=5.0
RECALL_CARDS_MIN_SIMILARITY=0.32
RECALL_CARDS_EMBED_CONCURRENCY=4

# Chat history table/columns
RECALL_SQL_CHAT_TABLE=chat_history_log
RECALL_SQL_CHAT_TEXT_COL=prompt
RECALL_SQL_CHAT_RESPONSE_COL=response
RECALL_SQL_CHAT_CREATED_AT_COL=created_at

# Collapse Mirror base + semantics
RECALL_SQL_MIRROR_TABLE=collapse_mirror
RECALL_SQL_MIRROR_SUMMARY_COL=summary
RECALL_SQL_MIRROR_TRIGGER_COL=trigger
RECALL_SQL_MIRROR_OBSERVER_COL=observer
RECALL_SQL_MIRROR_OBSERVER_STATE_COL=observer_state
RECALL_SQL_MIRROR_FIELD_RESONANCE_COL=field_resonance
RECALL_SQL_MIRROR_INTENT_COL=intent
RECALL_SQL_MIRROR_TYPE_COL=type
RECALL_SQL_MIRROR_ENTITY_COL=emergent_entity
RECALL_SQL_MIRROR_MANTRA_COL=mantra
RECALL_SQL_MIRROR_CAUSAL_ECHO_COL=causal_echo
RECALL_SQL_MIRROR_TS_COL=timestamp

# Collapse enrichment
RECALL_SQL_ENRICH_TABLE=collapse_enrichment
RECALL_SQL_ENRICH_COLLAPSE_ID_COL=collapse_id
RECALL_SQL_ENRICH_TAGS_COL=tags
RECALL_SQL_ENRICH_ENTITIES_COL=entities
RECALL_SQL_ENRICH_SALIENCE_COL=salience
RECALL_SQL_ENRICH_TS_COL=ts

# --- SQL Timeline ---
RECALL_ENABLE_SQL_TIMELINE=true
RECALL_SQL_SINCE_MINUTES=180
RECALL_SQL_TOP_K=10
RECALL_SQL_TIMELINE_TABLE=chat_history_log
RECALL_SQL_TIMELINE_TS_COL=timestamp
RECALL_SQL_TIMELINE_TEXT_COL=summary
RECALL_SQL_TIMELINE_SESSION_COL=observer
RECALL_SQL_TIMELINE_NODE_COL=observer_state
RECALL_SQL_TIMELINE_TAGS_COL=tags
RECALL_SQL_TIMELINE_REQUIRE_JUNIPER_OBSERVER=false
# Legacy collapse_mirror timeline (optional)
# RECALL_SQL_TIMELINE_TABLE=collapse_mirror
# RECALL_SQL_TIMELINE_REQUIRE_JUNIPER_OBSERVER=true

# --- SQL Message Table (optional) ---
RECALL_SQL_MESSAGE_TABLE=
RECALL_SQL_MESSAGE_ROLE_COL=role
RECALL_SQL_MESSAGE_TEXT_COL=text
RECALL_SQL_MESSAGE_CREATED_AT_COL=created_at

# --- Vector (legacy env vars; recall no longer queries vector backends) ---
# Recognized for config compatibility only — not used by orion-recall retrieval.
VECTOR_DB_HOST=orion-athena-vector-db
VECTOR_DB_PORT=8000
VECTOR_DB_COLLECTION=orion_chat
RECALL_VECTOR_BASE_URL=
RECALL_VECTOR_COLLECTIONS=
RECALL_VECTOR_EMBEDDING_URL=
RECALL_VECTOR_TIMEOUT_SEC=5.0
RECALL_VECTOR_MAX_ITEMS=24
RECALL_EXCLUDE_REJECTED=true
RECALL_DURABLE_ONLY=false
RECALL_DEBUG_DUMP_TOP_N=0
# Shadow-only Recall V2 compare path (anchor-first deterministic retrieval).
# PageIndex provenance may include enriched journal trigger/stance/facet metadata.
RECALL_V2_PAGEINDEX_URL=http://orion-athena-pageindex:8384

# --- RDF / graph (Fuseki / SPARQL; legacy GraphDB explicit only) ---
GRAPH_BACKEND=fuseki
RDF_STORE_BACKEND=fuseki
RDF_STORE_BASE_URL=http://orion-athena-fuseki:3030
RDF_STORE_DATASET=orion
RDF_STORE_QUERY_URL=http://orion-athena-fuseki:3030/orion/query
RDF_STORE_UPDATE_URL=http://orion-athena-fuseki:3030/orion/update
RDF_STORE_GRAPH_STORE_URL=http://orion-athena-fuseki:3030/orion/data
# Local Fuseki dev auth:
# services/orion-rdf-store/.env sets FUSEKI_ADMIN_PASSWORD=orion.
# Therefore local update credentials are admin/orion, not admin/admin.
# Production should override these with real secrets.
RDF_STORE_USER=admin
RDF_STORE_PASS=orion
# Legacy GraphDB (GRAPH_BACKEND=graphdb or explicit recall legacy only):
GRAPHDB_URL=
GRAPHDB_REPO=collapse
GRAPHDB_USER=
GRAPHDB_PASS=

# Recall-specific RDF overrides (optional; default follows RDF_STORE_QUERY_URL / RECALL_RDF_QUERY_URL).
# Required for brain.recall.v1 RDF + graphtri expansion (rdf_anchor_terms, rdf_connected_chat, rdf).
# Worker gates on non-empty RECALL_RDF_ENDPOINT_URL; profile flags alone are not enough.
RECALL_RDF_QUERY_URL=http://orion-athena-fuseki:3030/orion/query
RECALL_RDF_ENDPOINT_URL=http://orion-athena-fuseki:3030/orion/query
RECALL_RDF_USER=
RECALL_RDF_PASS=
RECALL_RDF_TIMEOUT_SEC=5.0
RECALL_RDF_ENABLE_SUMMARIES=false

# --- Memory graph SPARQL expansion (optional; default off) ---
RECALL_MEMORY_GRAPH_SPARQL_ENABLED=false
# Comma-separated named graph IRIs to scan for AffectiveDisposition nodes
RECALL_MEMORY_GRAPH_NAMED_GRAPHS=https://orion.example/ns/memory/ng/session/local
RECALL_MEMORY_GRAPH_SPARQL_TIMEOUT_SEC=2.0

# --- Tensors / Ranker toggles (future) ---
RECALL_TENSOR_RANKER_ENABLED=false
RECALL_TENSOR_RANKER_MODEL_PATH=/mnt/storage-warm/orion/recall/tensor-ranker.pt

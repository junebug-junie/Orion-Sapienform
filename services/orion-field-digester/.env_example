PROJECT=orion-athena
SERVICE_NAME=orion-field-digester
SERVICE_VERSION=0.1.0
NODE_NAME=athena
FIELD_DIGESTER_PORT=8116

POSTGRES_URI=postgresql://postgres:postgres@orion-athena-sql-db:5432/conjourney
LATTICE_PATH=/app/config/field/orion_field_topology.v1.yaml
BIOMETRICS_FIELD_DECAY_RATE=0.92
BIOMETRICS_FIELD_DIFFUSION_RATE=1.0
RECEIPT_POLL_INTERVAL_SEC=2.0
ENABLE_TRANSPORT_FIELD_DIGESTION=true
# Retention + the applied-deltas dedup pruner + the health monitor below are all
# prerequisites for this -- see README "Idle tick (pacemaker)" section.
# Enabled here so the field→attention→self_state heartbeat chain runs on Athena.
# Retention keys below bound substrate_field_state growth (~43k rows/day at 2s cadence).
FIELD_DIGESTER_IDLE_TICK_ENABLED=true
FIELD_STATE_RETENTION_HOURS=72.0
FIELD_STATE_PRUNE_INTERVAL_SEC=3600.0
# substrate_field_applied_deltas has no natural "latest row" reader, so it can't be
# time-pruned the way field_state can -- instead its dedup rows are only deleted once
# the source receipt they reference is confirmed gone from substrate_reduction_receipts
# (i.e. once that delta_id can structurally never be redelivered). min_age_hours below
# is just a small safety margin against racing the receipt pruner's own transaction.
FIELD_APPLIED_DELTAS_PRUNE_MIN_AGE_HOURS=1.0

# Health monitor: edge-triggered checks (field_state prune stall, applied_deltas
# unbounded growth, database size) that raise an orion-notify attention request only
# on a healthy->unhealthy transition -- never spams once per health-check tick.
FIELD_DIGESTER_HEALTH_CHECK_INTERVAL_SEC=900.0
FIELD_STATE_STALL_MULTIPLIER=1.5
FIELD_APPLIED_DELTAS_ALERT_ROW_COUNT=5000000
FIELD_DIGESTER_DB_SIZE_ALERT_GB=60.0
NOTIFY_BASE_URL=http://orion-athena-notify:7140
NOTIFY_API_TOKEN=
LOG_LEVEL=INFO

# Field-channel raw-substrate corpus collector (Item 1 v2, roadmap item 1
# correction, 2026-07-13). Empty/unset = disabled, no file written -- same
# convention as MOOD_ARC_CORPUS_PATH in orion-spark-introspector, and for the
# same reason: a sibling corpus sink was found to grow unbounded
# (~104MB/36.8k rows in 5 days), so anything new defaults to inert until an
# operator opts in.
FIELD_CHANNEL_CORPUS_PATH=
CORPUS_SINK_MAX_BYTES=200000000
CORPUS_SINK_ROTATED_KEEP=5

# Causal Geometry v1, Rung 2B/3A (2026-07-16): gates whether the diffusion read-path
# (services/orion-field-digester/app/digestion/diffusion.py) applies HITL-adopted
# learned cap->cap edge-weight overrides
# (orion/substrate/field_topology_learned_store.py's current_overlay()) on top of the
# designed orion_field_topology.v1.yaml weights. Default false = diffusion behavior is
# byte-identical to pre-plasticity behavior; nothing here auto-applies anything --
# overlay entries only exist after an explicit operator adopt() call. This rung
# (2B) does not read this flag itself; it only defines it for the Rung 3A consumer.
FIELD_PLASTICITY_ENABLED=false
# Bounds a single edge's learned delta away from its designed YAML weight. Must match
# orion/substrate/mutation_contracts.py's CONTRACTS["field_topology_weight_patch"]
# .bounds["edge_weight_delta"] -- that contract is the actually-enforced source of
# truth (proposal generation clamps against it directly); this key is documentation /
# an explicit operator-visible restatement, not an independently-enforced second gate.
FIELD_PLASTICITY_MAX_DRIFT=0.15
# Half-life (hours) for decaying an adopted learned delta back toward the designed
# weight absent reinforcement (re-adoption). 168h = 7 days. See
# FieldTopologyLearnedWeightsStore.current_overlay() in
# orion/substrate/field_topology_learned_store.py for the exact decay formula.
FIELD_PLASTICITY_DECAY_HALF_LIFE_HOURS=168

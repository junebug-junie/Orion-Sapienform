# orion-actions (v1)
SERVICE_NAME=actions
SERVICE_VERSION=0.1.0
NODE_NAME=athena
LOG_LEVEL=INFO

# Bus
ORION_BUS_URL=redis://100.92.216.81:6379/0
ORION_BUS_ENABLED=true
ORION_BUS_ENFORCE_CATALOG=true

# Subscriptions
ACTIONS_SUBSCRIBE_CHANNEL=orion:collapse:triage
ACTIONS_SUBSCRIBE_CHANNELS=orion:collapse:triage,orion:collapse:stored,orion:actions:trigger:daily_pulse.v1,orion:actions:trigger:daily_metacog.v1,orion:actions:trigger:journal.v1,orion:notify:persistence:request,orion:equilibrium:metacog:trigger

# Cortex dispatch
CORTEX_REQUEST_CHANNEL=orion:cortex:request
ACTIONS_VERB=actions.respond_to_juniper_collapse_mirror.v1
CORTEX_EXEC_REQUEST_CHANNEL=orion:cortex:exec:request
ACTIONS_EXEC_TIMEOUT_SECONDS=240

# Notify actuation
NOTIFY_URL=http://orion-athena-notify:7140
NOTIFY_API_TOKEN=

# Action policy
ACTIONS_RECIPIENT_GROUP=juniper_primary
ACTIONS_SESSION_ID=collapse_mirror
ACTIONS_DEDUPE_TTL_SECONDS=86400
ACTIONS_NOTIFY_DEDUPE_WINDOW_SECONDS=86400
ACTIONS_MAX_CONCURRENCY=2

# Recall
ACTIONS_RECALL_PROFILE=reflect.v1
ACTIONS_RECALL_TIMEOUT_SECONDS=60

# LLM
ACTIONS_LLM_ROUTE=chat
ACTIONS_LLM_TIMEOUT_SECONDS=200

# Daily schedule
ACTIONS_DAILY_TIMEZONE=America/Denver
ACTIONS_DAILY_RUN_ON_STARTUP=false
ACTIONS_DAILY_RUN_ONCE_DATE=
ACTIONS_DAILY_PULSE_ENABLED=true
ACTIONS_DAILY_PULSE_HOUR_LOCAL=8
ACTIONS_DAILY_PULSE_MINUTE_LOCAL=30
ACTIONS_DAILY_METACOG_ENABLED=true
ACTIONS_DAILY_METACOG_HOUR_LOCAL=20
ACTIONS_DAILY_METACOG_MINUTE_LOCAL=15

# Periodic skills scheduler
ACTIONS_SKILLS_SCHEDULER_ENABLED=true
ACTIONS_SKILLS_RUN_ON_STARTUP=false
ACTIONS_SKILLS_INTERVAL_SECONDS=600
ACTIONS_SKILLS_NOTIFY_ENABLED=false
ACTIONS_SKILLS_GPU_MEM_THRESHOLD=0.9
ACTIONS_SKILLS_BIOMETRICS_STABILITY_THRESHOLD=0.3

# Journaling
ACTIONS_JOURNALING_ENABLED=true
ACTIONS_JOURNALING_DAILY_ENABLED=false
ACTIONS_JOURNALING_COOLDOWN_SECONDS=21600
ACTIONS_JOURNALING_COLLAPSE_DENSE_ONLY=true
ACTIONS_JOURNAL_SESSION_ID=orion_journal
ACTIONS_JOURNAL_AUTHOR=orion
ACTIONS_JOURNAL_WRITE_CHANNEL=orion:journal:write

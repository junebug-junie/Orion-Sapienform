# ─────────────────────────────────────────────
# Orion Context Exec — bounded RLM investigation organ
# Beta env posture: docs/context-exec-beta-runbook.md
# Legacy AgentChain fallback lives on cortex-exec: CONTEXT_EXEC_LEGACY_FALLBACK
# ─────────────────────────────────────────────

SERVICE_NAME=context-exec
SERVICE_VERSION=0.1.0
NODE_NAME=athena

CONTEXT_EXEC_PORT=8096

ORION_BUS_ENABLED=true
ORION_BUS_ENFORCE_CATALOG=true
ORION_BUS_URL=redis://100.92.216.81:6379/0

CHANNEL_CONTEXT_EXEC_INTAKE=orion:exec:request:ContextExecService
CHANNEL_CONTEXT_EXEC_REPLY_PREFIX=orion:exec:result:ContextExecService
CHANNEL_CONTEXT_EXEC_EVENT=orion:context_exec:event

CHANNEL_LLM_INTAKE=orion:exec:request:LLMGatewayService
CHANNEL_RECALL_INTAKE=orion:exec:request:RecallService
CHANNEL_RECALL_REPLY_PREFIX=orion:recall:reply

CONTEXT_EXEC_ENABLED=true
CONTEXT_EXEC_SANDBOX_MODE=docker
CONTEXT_EXEC_MAX_DEPTH=1
CONTEXT_EXEC_MAX_SUBCALLS=6
CONTEXT_EXEC_MAX_SECONDS=45
CONTEXT_EXEC_WRITE_ENABLED=false
CONTEXT_EXEC_NETWORK_ENABLED=false
CONTEXT_EXEC_REPL_OUTPUT_CHARS=8192
CONTEXT_EXEC_RLM_ENGINE=fake
# CONTEXT_EXEC_RLM_ENGINE=alexzhang
CONTEXT_EXEC_RLM_FALLBACK_ENABLED=true

CONTEXT_EXEC_COMPAT_AGENT_CHAIN_ENABLED=false
CONTEXT_EXEC_FAKE_ORGANS_ENABLED=false
CONTEXT_EXEC_AGENT_CHAIN_INTAKE_ALIAS=orion:exec:request:AgentChainService

CONTEXT_EXEC_REAL_TRACE_ENABLED=true
CONTEXT_EXEC_REAL_RECALL_ENABLED=true
CONTEXT_EXEC_REAL_REPO_ENABLED=true
CONTEXT_EXEC_REPO_ROOT=/app
CONTEXT_EXEC_REPO_MAX_FILE_CHARS=12000
CONTEXT_EXEC_TRACE_LIMIT=40
CONTEXT_EXEC_RECALL_LIMIT=12
CONTEXT_EXEC_RECALL_TIMEOUT_SEC=25

# LLM profile → gateway route binding (Hub Agent mode passes llm_profile)
CONTEXT_EXEC_ALLOWED_LLM_PROFILES=chat,quick,agent,metacog
CONTEXT_EXEC_DEFAULT_LLM_PROFILE=chat
CONTEXT_EXEC_LLM_PROFILE_FALLBACK_ENABLED=false
CONTEXT_EXEC_LLM_GATEWAY_URL=http://orion-llm-gateway:8210
CONTEXT_EXEC_LLM_GATEWAY_TIMEOUT_SEC=1.5
CONTEXT_EXEC_LLM_TIMEOUT_SEC=30

# Route-bound Agent synthesis (read-only; after deterministic organ collection)
CONTEXT_EXEC_AGENT_SYNTHESIS_ENABLED=true
CONTEXT_EXEC_AGENT_SYNTHESIS_REQUIRED=false
CONTEXT_EXEC_AGENT_SYNTHESIS_MAX_CHARS=4000
CONTEXT_EXEC_AGENT_SYNTHESIS_TIMEOUT_SEC=30

ORION_REPO_ROOT=/app

# Proposal ledger intake (opt-in; requires explicit store path when enabled)
# AUTO_TRIAGE=true applies deterministic policy only — never approves or executes.
# AUTO_TRIAGE only selects stored / blocked / pending_review after initial store.
CONTEXT_EXEC_PROPOSAL_LEDGER_ENABLED=false
CONTEXT_EXEC_PROPOSAL_LEDGER_STORE_PATH=
CONTEXT_EXEC_PROPOSAL_LEDGER_AUTO_TRIAGE=false

# Proposal review API (Hub-facing control-plane seam; no execution)
# Disabled by default — enable only with explicit PROPOSAL_LEDGER_STORE_PATH.
PROPOSAL_REVIEW_API_ENABLED=false
# Required explicit JSON ledger path — no repo default. Example: /var/orion/proposals.json
PROPOSAL_LEDGER_STORE_PATH=

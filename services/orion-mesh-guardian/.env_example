#PROJECT=orion-athena
#NODE_NAME=athena

SERVICE_NAME=orion-mesh-guardian
SERVICE_VERSION=0.1.0
PORT=7161

ORION_REPO_ROOT=/mnt/scripts/Orion-Sapienform
# Mesh bus (same as repo root .env); compose passes ${ORION_BUS_URL} when brought up with --env-file ../../.env
ORION_BUS_URL=redis://100.92.216.81:6379/0

NOTIFY_BASE_URL=http://orion-athena-notify:7140
NOTIFY_API_TOKEN=

MESH_GUARDIAN_ROSTER_PATH=/repo/config/mesh_remediation_roster.yaml
MESH_GUARDIAN_ENABLED=true
MESH_GUARDIAN_AUTO_REMEDIATE=false
MESH_GUARDIAN_REMEDIATION_COOLDOWN_SEC=300
MESH_GUARDIAN_MAX_ATTEMPTS_PER_HOUR=3
MESH_GUARDIAN_PROBE_INTERVAL_SEC=15
MESH_GUARDIAN_POST_REMEDIATE_GRACE_SEC=60
MESH_GUARDIAN_CONSECUTIVE_PROBE_FAILS=2
MESH_GUARDIAN_EQUILIBRIUM_GRACE_SEC=30
CHANNEL_EQUILIBRIUM_SNAPSHOT=orion:equilibrium:snapshot

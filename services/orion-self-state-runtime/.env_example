PROJECT=orion-athena
SERVICE_NAME=orion-self-state-runtime
SERVICE_VERSION=0.1.0
POSTGRES_URI=postgresql://postgres:postgres@orion-athena-sql-db:5432/conjourney
SELF_STATE_POLICY_PATH=/app/config/self_state/self_state_policy.v1.yaml
SELF_STATE_POLL_INTERVAL_SEC=2.0
ENABLE_SELF_STATE_RUNTIME=true
# Transport M6: include transport_integrity dimension in self-state scoring (default off)
ENABLE_TRANSPORT_SELF_STATE_INFLUENCE=true
# Discard stale previous_self_state after policy change or long idle (seconds)
SELF_STATE_MAX_PREVIOUS_AGE_SEC=300.0
LOG_LEVEL=INFO
SELF_STATE_RUNTIME_PORT=8118

# Bus (publish SelfStateV1 after each save — Wire 1)
ORION_BUS_URL=${ORION_BUS_URL}
ORION_BUS_ENABLED=true
CHANNEL_SUBSTRATE_SELF_STATE=orion:substrate:self_state

# Bounded retention for substrate_self_state, self_state_predictions and
# identity_snapshots (per-tick / per-10-ticks writers). Newest row of each
# table is always kept. 0 disables.
SELF_STATE_RETENTION_HOURS=72.0
SELF_STATE_PRUNE_INTERVAL_SEC=3600.0

# Health monitor: edge-triggered check (self_state prune stall) that raises an
# orion-notify attention request only on a healthy->unhealthy transition --
# never spams once per health-check tick. substrate_self_state is what
# felt_state_reader.py and phi both depend on for freshness, so this is
# arguably the highest-severity check in the mesh.
SELF_STATE_RUNTIME_HEALTH_CHECK_INTERVAL_SEC=900.0
SELF_STATE_STALL_MULTIPLIER=1.5
NOTIFY_BASE_URL=http://orion-athena-notify:7140
NOTIFY_API_TOKEN=

# Orion embodiment perception grounding — default off / empty-safe.
# When enabled, subscribe to town perception and fold an age-gated
# "I am embodied near X" signal into hub_presence-style grounding.
EMBODIMENT_PERCEPTION_SELFSTATE_ENABLED=false
EMBODIMENT_CHANNEL_PERCEPTION=orion:embodiment:perception

# Phase 2 (2026-07-12) deviation probe -- measurement-only, log-only, no
# schema field or gated behavior yet. Default on; flip to false without a
# redeploy if it proves noisy at production tick volume.
SELF_STATE_DEVIATION_PROBE_ENABLED=true

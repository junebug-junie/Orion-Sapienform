# Operator FCC secrets — copy to ~/.fcc/.env (NOT services/*/.env).
# Used by Hub Agent Claude AND Orion unified-turn harness (same file, two paths):
#   Hub:     HUB_FCC_ENV_PATH      → /root/.fcc/.env in hub container
#   Harness: HARNESS_FCC_ENV_PATH  → /root/.fcc/.env in harness-governor container
#
# Enable flags live in service .env (synced from .env_example):
#   Agent Claude mode: HUB_AGENT_CLAUDE_MCP_ENABLED + HUB_AITOWN_ENABLED (orion-hub)
#   Orion mode:        HARNESS_FCC_MCP_ENABLED + HARNESS_AITOWN_ENABLED (orion-harness-governor)

# --- LLM gateway / FCC ---
ANTHROPIC_AUTH_TOKEN=
MODEL=chat
MODEL_SONNET=chat
MODEL_HAIKU=chat
MODEL_OPUS=chat

# --- MCP secrets (required when MCP enabled) ---
GITHUB_PAT=
FIRECRAWL_API_KEY=

# --- AI Town gameplay MCP (optional; needs mesh bootstrap) ---
# Use mesh-reachable URL (not 127.0.0.1) if read from bridge-network containers.
# Harness override: HARNESS_AITOWN_CONVEX_URL in orion-harness-governor .env
AITOWN_CONVEX_URL=http://100.92.216.81:3210
AITOWN_ADMIN_KEY=
AITOWN_WORLD_ID=
AITOWN_ORION_PLAYER_ID=
AITOWN_ORION_AGENT_ID=

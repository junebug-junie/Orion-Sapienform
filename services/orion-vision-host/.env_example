# Copy to .env and tune for your node.
# See README.md for operator checklist.

LOG_LEVEL=INFO

ORION_BUS_ENABLED=true
ORION_BUS_URL=redis://localhost:6379/0
ORION_BUS_ENFORCE_CATALOG=false

CHANNEL_VISIONHOST_INTAKE=orion:exec:request:VisionHostService
CHANNEL_VISIONHOST_REPLY_PREFIX=orion:vision:reply
CHANNEL_VISIONHOST_PUB=orion:vision:artifacts

MODEL_CACHE_DIR=/mnt/telemetry/models/vision
HF_HOME=/mnt/telemetry/models/vision/hf
TRANSFORMERS_CACHE=/mnt/telemetry/models/hf/transformers

VISION_PROFILES_PATH=/app/config/vision_profiles.yaml
VISION_ENABLED_PROFILES=pipeline_retina_fast,retina_detect_open_vocab,embed_image,vlm_caption

# Caption VLM — must fit VRAM (default ~2.7B BLIP-2 class; override e.g. for IDEFICS / larger VLMs).
VISION_VLM_MODEL_ID=Salesforce/blip2-opt-2.7b
VISION_VLM_MAX_TOKENS=128
VISION_VLM_TEMPERATURE=0.4

CUDA_VISIBLE_DEVICES=0
VISION_DEVICE_STRATEGY=best_free_vram
VISION_DEFAULT_DEVICE=cuda:0
VISION_DEVICES=cuda:0
VISION_PICK_GPU_METRIC=free_vram_mb

VISION_DTYPE=auto
VISION_TIMEOUT_S=30

VISION_MAX_INFLIGHT=4
VISION_MAX_INFLIGHT_PER_GPU=1
VISION_QUEUE_WHEN_BUSY=true
VISION_MAX_QUEUE=200

VISION_VRAM_RESERVE_MB=3500
VISION_VRAM_SOFT_FLOOR_MB=2200
VISION_VRAM_HARD_FLOOR_MB=1400

TORCH_CUDA_ALLOC_CONF=
